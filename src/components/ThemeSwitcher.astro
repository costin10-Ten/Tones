---
// ThemeSwitcher — single-click cycles through themes
---

<div class="theme-switcher" id="theme-switcher">
  <button
    class="theme-toggle-btn"
    id="theme-toggle"
    aria-label="切換主題"
    title="點擊切換主題"
    style="touch-action:manipulation"
  >
    <span id="theme-icon">◐</span>
    <span id="theme-label" class="mono" style="font-size:0.75rem;">DARK</span>
  </button>
</div>

<script>
  import '../scripts/theme-switcher.js';
</script>
