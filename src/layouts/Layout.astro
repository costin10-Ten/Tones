---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  theme?: string;
  ogImage?: string;
  ogType?: string;
  articleMeta?: { publishedTime?: string; author?: string; tags?: string[] };
}

const {
  title = '弦音異象 — 心理驚悚與推理短篇',
  description = '五分鐘，一個細思極恐的故事，一塊拼湊瘋狂的碎片。',
  theme = 'dark',
  ogImage,
  ogType = 'website',
  articleMeta,
} = Astro.props;

const nonce = Astro.locals.nonce || undefined;

// Strip query params from canonical — ?cat= is UI state, not content
const canonical = Astro.url.origin + Astro.url.pathname;
const siteName = '弦音異象';
const defaultOgImage = new URL('/og-default.png', Astro.url).href;
---

<!DOCTYPE html>
<html lang="zh-TW" data-theme={theme}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonical} />
  <link rel="sitemap" href="/sitemap.xml" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <title>{title}</title>

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:locale" content="zh_TW" />
  <meta property="og:image" content={ogImage ?? defaultOgImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  {articleMeta?.publishedTime && <meta property="article:published_time" content={articleMeta.publishedTime} />}
  {articleMeta?.author && <meta property="article:author" content={articleMeta.author} />}
  {articleMeta?.tags?.map(tag => <meta property="article:tag" content={tag} />)}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage ?? defaultOgImage} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;700;900&family=Noto+Sans+TC:wght@400;700&family=Share+Tech+Mono&display=swap"
    rel="stylesheet"
  />
  <slot name="head" />
  <ViewTransitions />
  <!-- Apply theme + plain mode before first paint to avoid flash -->
  <script is:inline nonce={nonce}>
    (function () {
      try {
        var t = localStorage.getItem('hz-theme');
        if (t) document.documentElement.setAttribute('data-theme', t);
        var p = localStorage.getItem('hz-plain');
        if (p === '1') document.documentElement.setAttribute('data-plain', '1');
        else document.documentElement.removeAttribute('data-plain');
      } catch (_) {}
    })();
  </script>
</head>
<body>
  <div id="progress" aria-hidden="true"></div>
  <slot />

  <script is:inline nonce={nonce}>
    // Re-apply theme + plain mode after each ViewTransitions page swap
    document.addEventListener('astro:after-swap', function () {
      try {
        var t = localStorage.getItem('hz-theme');
        if (t) document.documentElement.setAttribute('data-theme', t);
        var p = localStorage.getItem('hz-plain');
        if (p === '1') document.documentElement.setAttribute('data-plain', '1');
        else document.documentElement.removeAttribute('data-plain');
      } catch (_) {}
    });
  </script>

  <script is:inline nonce={nonce}>
    // Reading progress bar
    function updateProgress() {
      const el = document.getElementById('progress');
      if (!el) return;
      const scrollTop = window.scrollY;
      const docHeight = document.body.scrollHeight - window.innerHeight;
      const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      el.style.width = pct + '%';
    }
    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
  </script>

  <script is:inline nonce={nonce}>
    // Global plain text mode intercept
    // Intercepts story links and redirects to /plain when mode is enabled
    (function interceptPlainMode() {
      function isPlain() {
        try { return localStorage.getItem('hz-plain') === '1'; } catch(_) { return false; }
      }
      function attachLinks() {
        document.querySelectorAll('a[href]').forEach(function(link) {
          var href = link.getAttribute('href') || '';
          var match = href.match(/^\/stories\/([^\/]+)$/);
          if (!match) return;
          // avoid double-binding
          if (link.dataset.plainBound) return;
          link.dataset.plainBound = '1';
          link.addEventListener('click', function(e) {
            if (isPlain()) {
              e.preventDefault();
              window.location.href = '/stories/' + match[1] + '/plain';
            }
          });
        });
      }
      attachLinks();
      document.addEventListener('astro:after-swap', attachLinks);
    })();
  </script>

  <script is:inline nonce={nonce}>
    // ─── Proactive Clerk JWT refresh before ViewTransitions navigation ───
    // Root cause of "suddenly logged out" bug:
    //   Clerk's session JWT has a ~60-second lifetime. When the user navigates
    //   via ViewTransitions (background fetch), the fetch may fire with an
    //   already-expired JWT if Clerk hasn't auto-refreshed yet. The server
    //   receives the expired token → userId = null → shows logged-out state.
    // Fix:
    //   Intercept astro:before-preparation (fires before the fetch is sent)
    //   and call clerk.session.getToken() which returns the cached token or
    //   silently fetches a fresh one from Clerk, updating the cookie BEFORE
    //   the ViewTransitions request reaches the server.
    document.addEventListener('astro:before-preparation', function(ev) {
      var clerk = window.Clerk;
      if (!clerk || !clerk.session) return; // Not signed in — nothing to do
      var origLoader = ev.loader;
      if (typeof origLoader !== 'function') return; // Guard for API differences
      ev.loader = async function() {
        try {
          await clerk.session.getToken(); // Refresh JWT if expired; no-op if valid
        } catch (_) {}
        return origLoader();
      };
    });
  </script>
</body>
</html>
