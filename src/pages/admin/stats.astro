---
import Layout from '../../layouts/Layout.astro';
import ThemeSwitcher from '../../components/ThemeSwitcher.astro';
import { getCollection } from 'astro:content';

export const prerender = false;

const userId = Astro.locals.auth?.()?.userId ?? null;
if (!userId) {
  return Astro.redirect('/sign-in?redirect_url=/admin/stats');
}
// Only the configured admin user may access this page
const adminId = import.meta.env.ADMIN_USER_ID ?? '';
if (!adminId || userId !== adminId) {
  return Astro.redirect('/');
}

// Build title map from content collection
const allStories = await getCollection('stories', ({ data }) => data.published);
const titleMap = Object.fromEntries(allStories.map(s => [s.slug, s.data.title]));
const totalStories = allStories.length;
---

<Layout title="故事統計 — 弦音異象" description="故事閱讀數與金幣統計">
  <header>
    <a href="/member" class="back-btn" title="返回會員頁">&lt;</a>
    <a href="/" class="rdr-logo">弦音<em>異象</em></a>
    <div class="rdr-ttl">故事統計後台</div>
    <ThemeSwitcher />
  </header>

  <main class="stats-main">
    <div class="stats-wrap">

      <div class="page-hd">
        <div class="page-title">卷宗閱讀統計</div>
        <div class="page-sub" id="statsSummary">載入中…</div>
      </div>

      <div class="summary-grid">
        <div class="sum-box">
          <div class="sum-num" id="sumTotalViews">—</div>
          <div class="sum-lbl">總瀏覽數</div>
        </div>
        <div class="sum-box">
          <div class="sum-num" id="sumTotalTokens">—</div>
          <div class="sum-lbl">總金幣數</div>
        </div>
        <div class="sum-box">
          <div class="sum-num" id="sumActiveStories">—</div>
          <div class="sum-lbl">有紀錄卷宗</div>
        </div>
        <div class="sum-box">
          <div class="sum-num">{totalStories}</div>
          <div class="sum-lbl">總卷宗數</div>
        </div>
      </div>

      <div class="table-controls">
        <div class="sort-row">
          <span class="sort-label">排序：</span>
          <button class="sort-btn active" data-sort="views">瀏覽數 ↓</button>
          <button class="sort-btn" data-sort="tokens">金幣 ↓</button>
          <button class="sort-btn" data-sort="title">標題</button>
        </div>
        <input type="text" id="searchInput" class="search-input" placeholder="搜尋卷宗…" />
      </div>

      <div class="stats-table-wrap">
        <table class="stats-table" id="statsTable">
          <thead>
            <tr>
              <th>卷宗</th>
              <th class="num-col">瀏覽</th>
              <th class="num-col">金幣</th>
              <th class="num-col">最後更新</th>
            </tr>
          </thead>
          <tbody id="statsBody">
            <tr><td colspan="4" class="loading-row">載入統計資料…</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </main>

  <footer>
    <div class="ft-logo">弦音<em>異象</em></div>
  </footer>
</Layout>

<script define:vars={{ titleMap }} nonce={Astro.locals.nonce || undefined}>
  function fmtN(n) { return n >= 1000 ? (n / 1000).toFixed(1) + 'K' : String(n); }
  function fmtDate(iso) {
    var d = new Date(iso);
    return d.getFullYear() + '.' + String(d.getMonth()+1).padStart(2,'0') + '.' + String(d.getDate()).padStart(2,'0');
  }
  function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  var allData = [];
  var currentSort = 'views';
  var searchTerm = '';

  function getSortedFiltered() {
    var filtered = searchTerm
      ? allData.filter(function(r) {
          var title = (titleMap[r.story_slug] || r.story_slug).toLowerCase();
          return title.includes(searchTerm) || r.story_slug.includes(searchTerm);
        })
      : allData.slice();
    filtered.sort(function(a, b) {
      if (currentSort === 'views') return b.views - a.views;
      if (currentSort === 'tokens') return b.tokens - a.tokens;
      var ta = titleMap[a.story_slug] || a.story_slug;
      var tb = titleMap[b.story_slug] || b.story_slug;
      return ta.localeCompare(tb, 'zh-TW');
    });
    return filtered;
  }

  function renderTable() {
    var body = document.getElementById('statsBody');
    if (!body) return;
    var rows = getSortedFiltered();
    if (!rows.length) {
      body.innerHTML = '<tr><td colspan="4" class="loading-row">查無資料</td></tr>';
      return;
    }
    body.innerHTML = rows.map(function(r) {
      var slug = escHtml(r.story_slug);
      var title = escHtml(titleMap[r.story_slug] || r.story_slug);
      var maxViews = allData[0]?.views ?? 1;
      var pct = maxViews > 0 ? Math.round((r.views / maxViews) * 100) : 0;
      return '<tr>' +
        '<td class="title-cell">' +
          '<a href="/stories/' + slug + '" class="story-link">' + title + '</a>' +
          '<div class="view-bar-wrap"><div class="view-bar" style="width:' + pct + '%"></div></div>' +
        '</td>' +
        '<td class="num-col accent-num">' + fmtN(r.views) + '</td>' +
        '<td class="num-col">' + fmtN(r.tokens) + '</td>' +
        '<td class="num-col dim-num">' + (r.updated_at ? fmtDate(r.updated_at) : '—') + '</td>' +
        '</tr>';
    }).join('');
  }

  fetch('/api/admin/story-stats')
    .then(function(r) { return r.ok ? r.json() : Promise.reject(r.status); })
    .then(function(data) {
      allData = Array.isArray(data) ? data : [];
      var totalViews = allData.reduce(function(s, r) { return s + (r.views || 0); }, 0);
      var totalTokens = allData.reduce(function(s, r) { return s + (r.tokens || 0); }, 0);
      var el = function(id) { return document.getElementById(id); };
      if (el('sumTotalViews'))   el('sumTotalViews').textContent   = fmtN(totalViews);
      if (el('sumTotalTokens'))  el('sumTotalTokens').textContent  = fmtN(totalTokens);
      if (el('sumActiveStories')) el('sumActiveStories').textContent = String(allData.length);
      if (el('statsSummary'))    el('statsSummary').textContent    = '資料已載入 · ' + allData.length + ' 筆紀錄';
      renderTable();
    })
    .catch(function(err) {
      var body = document.getElementById('statsBody');
      if (body) body.innerHTML = '<tr><td colspan="4" class="loading-row err-row">載入失敗（' + escHtml(String(err)) + '）</td></tr>';
    });

  document.querySelectorAll('.sort-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.sort-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      currentSort = btn.dataset.sort;
      renderTable();
    });
  });

  document.getElementById('searchInput')?.addEventListener('input', function(e) {
    searchTerm = e.target.value.toLowerCase().trim();
    renderTable();
  });
</script>

<style>
  header {
    position: sticky; top: 0; z-index: 100;
    height: 56px; display: flex; align-items: center; gap: 12px;
    padding: 0 16px; background: var(--bg); border-bottom: 1px solid var(--border);
  }
  .rdr-logo {
    font-family: 'Noto Serif TC', serif; font-weight: 900; font-size: 1rem;
    color: var(--text); text-decoration: none; letter-spacing: .08em; flex-shrink: 0;
  }
  .rdr-logo em { color: var(--accent); font-style: normal; }
  .rdr-ttl {
    flex: 1; font-family: 'Noto Serif TC', serif; font-size: .85rem;
    font-weight: 700; color: var(--text); text-align: center; letter-spacing: .04em;
  }
  .back-btn {
    font-family: 'Share Tech Mono', monospace; font-size: .9rem;
    color: var(--text-muted); text-decoration: none;
    border: 1px solid var(--border); padding: 5px 9px;
    min-width: 30px; display: inline-flex; align-items: center; justify-content: center;
    flex-shrink: 0; transition: all .2s;
  }
  .back-btn:hover { border-color: var(--accent); color: var(--accent); }

  .stats-main { min-height: 100vh; background: var(--bg); }
  .stats-wrap { max-width: 860px; margin: 0 auto; padding: 48px 24px 100px; }

  .page-hd { margin-bottom: 28px; border-bottom: 1px solid var(--border); padding-bottom: 14px; }
  .page-title {
    font-family: 'Share Tech Mono', monospace; font-size: .95rem;
    letter-spacing: .2em; color: var(--text); font-weight: bold; text-transform: uppercase;
  }
  .page-title::before { content: '[ '; color: var(--accent); }
  .page-title::after  { content: ' ]'; color: var(--accent); }
  .page-sub { font-family: 'Share Tech Mono', monospace; font-size: .62rem; color: var(--text-muted); margin-top: 6px; }

  .summary-grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 28px;
  }
  .sum-box {
    background: var(--surface); border: 1px solid var(--border);
    padding: 16px 12px; text-align: center;
  }
  .sum-num {
    font-family: 'Share Tech Mono', monospace; font-size: 1.4rem;
    color: var(--accent); font-weight: bold; margin-bottom: 4px;
  }
  .sum-lbl {
    font-family: 'Share Tech Mono', monospace; font-size: .58rem;
    color: var(--text-muted); letter-spacing: .1em; text-transform: uppercase;
  }

  .table-controls {
    display: flex; align-items: center; justify-content: space-between;
    gap: 12px; margin-bottom: 12px; flex-wrap: wrap;
  }
  .sort-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .sort-label { font-family: 'Share Tech Mono', monospace; font-size: .65rem; color: var(--text-muted); }
  .sort-btn {
    font-family: 'Share Tech Mono', monospace; font-size: .65rem;
    padding: 5px 10px; border: 1px solid var(--border); background: var(--surface);
    color: var(--text-dim); cursor: pointer; transition: all .18s; letter-spacing: .05em;
  }
  .sort-btn:hover { border-color: var(--text); color: var(--text); }
  .sort-btn.active { border-color: var(--accent); color: var(--accent); }
  .search-input {
    background: var(--bg2); border: 1px solid var(--border); color: var(--text);
    font-family: 'Share Tech Mono', monospace; font-size: .72rem;
    padding: 6px 12px; outline: none; width: 180px; transition: border-color .18s;
  }
  .search-input:focus { border-color: var(--accent); }

  .stats-table-wrap { overflow-x: auto; }
  .stats-table {
    width: 100%; border-collapse: collapse;
    font-family: 'Share Tech Mono', monospace; font-size: .72rem;
  }
  .stats-table th {
    background: var(--surface); border: 1px solid var(--border);
    padding: 10px 14px; text-align: left; color: var(--text-muted);
    letter-spacing: .1em; text-transform: uppercase; font-size: .6rem; white-space: nowrap;
  }
  .stats-table td {
    border: 1px solid var(--border); padding: 10px 14px;
    background: var(--bg); transition: background .15s;
  }
  .stats-table tr:hover td { background: var(--surface); }
  .num-col { text-align: right; white-space: nowrap; }
  .accent-num { color: var(--accent); font-weight: bold; }
  .dim-num { color: var(--text-muted); font-size: .62rem; }
  .title-cell { min-width: 200px; }
  .story-link {
    font-family: 'Noto Serif TC', serif; font-size: .82rem; font-weight: 700;
    color: var(--text); text-decoration: none; display: block; margin-bottom: 4px;
  }
  .story-link:hover { color: var(--accent); }
  .view-bar-wrap {
    height: 2px; background: var(--border); border-radius: 1px; overflow: hidden;
  }
  .view-bar { height: 100%; background: var(--accent); border-radius: 1px; }
  .loading-row { text-align: center; color: var(--text-muted); padding: 24px; }
  .err-row { color: var(--danger); }

  footer { text-align: center; padding: 32px; border-top: 1px solid var(--border); }
  .ft-logo {
    font-family: 'Noto Serif TC', serif; font-weight: 900;
    font-size: 1rem; color: var(--text); letter-spacing: .08em;
  }
  .ft-logo em { color: var(--accent); font-style: normal; }

  @media (max-width: 600px) {
    .summary-grid { grid-template-columns: repeat(2, 1fr); }
    .search-input { width: 100%; }
    .dim-num { display: none; }
  }
</style>
