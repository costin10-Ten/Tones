---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';

export const prerender = true;
---

<Layout title="關於作者 — 弦音異象" description="弦音異象的世界觀與創作歷程">
  <PageHeader active="about" />

  <main style="padding-top: 56px;">
    <div class="about-content">
      <div class="about-intro">
        <h2>深淵的凝視，<br><em class="hl">從未停止</em></h2>
        <p>「弦音異象」收集了現代/近未來人心的各種異象。觀測 2040 年生活周遭發生的所有相變、深邃、與科技反噬相關的短篇紀錄。</p>
        <p>
          請記住：你在這裡看到的所有文字，都可能帶有
          <span class="redacted">不寒而慄的既視感</span>。
          當你自以為在閱讀別人的悲劇時，弦音也正在反向解析你的心理弱點。
        </p>
      </div>

      <div class="tl-head">作者日誌</div>
      <div class="timeline">
        {[
          { date: '2026.03.23', text: '上傳 FILE-103〈深夜的凝視(1)--序〉。' },
          { date: '2026.03.22', text: '上傳 FILE-102〈永不到達的螢火谷〉。' },
          { date: '2026.03.18', text: '上傳 FILE-101〈好好的〉。' },
          { date: '2026.03.10', text: '網站第一次成功掛上網路，我現在有點搞不清楚自己是小說作者還是程式設計師，都是文字的奴隸不是嗎？' },
          { date: '2026.02.15', text: '寫了五十篇短篇，丟掉四十九篇，剩下的那一篇只是因為它剛好沒有標題。' },
          { date: '2025.09.22', text: '編撰關於世界的聖經，一度不知道：是我在編輯它，還是它在編輯我。' },
          { date: '2025.07.22', text: '本網站成立：於作者腦中。' },
        ].map((log, i) => (
          <div class={`tl-item${i === 0 ? ' ms' : ''}`}>
            <div class="tl-dot"></div>
            <div class="tl-year">[ LOG: {log.date} ]</div>
            <div class="tl-desc">{log.text}</div>
          </div>
        ))}
      </div>
    </div>
  </main>

  <footer>
    <div class="ft-logo">弦音<em>異象</em></div>
    <div class="ft-txt">ANOMALY ARCHIVES · CLASSIFIED<br>一切皆為虛構，除非你相信。</div>
  </footer>
</Layout>

<style>
  /* ─── Main & Footer ────────────────────────────── */
  .about-content {
    max-width: 760px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }
  .about-intro { margin-bottom: 48px; }
  .about-intro h2 {
    font-family: 'Noto Serif TC', serif;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 900;
    line-height: 1.25;
    color: var(--text);
    margin-bottom: 20px;
  }
  .about-intro h2 em.hl { color: var(--accent); font-style: normal; }
  .about-intro p {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.82rem;
    color: var(--text-dim);
    line-height: 1.9;
    letter-spacing: 0.04em;
    margin-bottom: 14px;
  }
  .redacted {
    background: var(--text); color: transparent; user-select: none;
    transition: all 0.3s; cursor: pointer; border-radius: 2px;
  }
  .redacted:hover { background: transparent; color: var(--text); }
  .tl-head {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    color: var(--text-muted);
    text-transform: uppercase;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 24px;
  }
  .tl-head::before { content: '[ '; color: var(--accent); }
  .tl-head::after  { content: ' ]'; color: var(--accent); }
  .timeline { display: flex; flex-direction: column; gap: 0; }
  .tl-item {
    display: flex;
    flex-direction: column;
    padding: 20px 0 20px 28px;
    border-left: 1px solid var(--border);
    position: relative;
  }
  .tl-dot {
    position: absolute;
    left: -5px;
    top: 24px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--border);
    border: 2px solid var(--bg);
  }
  .tl-item.ms .tl-dot { background: var(--accent); }
  .tl-year {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.62rem;
    color: var(--accent);
    letter-spacing: 0.15em;
    margin-bottom: 6px;
  }
  .tl-desc {
    font-family: 'Noto Serif TC', serif;
    font-size: 0.88rem;
    color: var(--text-dim);
    line-height: 1.8;
  }
  footer { text-align: center; padding: 48px 24px; border-top: 1px solid var(--border); }
  .ft-logo { font-family: 'Noto Serif TC', serif; font-size: 1.2rem; font-weight: 900; color: var(--text); letter-spacing: .1em; margin-bottom: 10px; }
  .ft-logo em { color: var(--accent); font-style: normal; }
  .ft-txt { font-family: 'Share Tech Mono', monospace; font-size: .65rem; color: var(--text-muted); letter-spacing: .1em; line-height: 1.8; }
  @media (max-width: 600px) {
    .top-nav { display: none; }
    header { padding: 0 10px; }
  }
</style>
