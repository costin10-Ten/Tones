---
import Layout from '../../layouts/Layout.astro';
import ThemeSwitcher from '../../components/ThemeSwitcher.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const allStories = await getCollection('stories', ({ data }) => data.published);
const stories = allStories.sort((a, b) => a.data.fileNum.localeCompare(b.data.fileNum));

const categories = [
  { key: '記憶科技', label: '精神汙染',      code: 'PSY-CONT'   },
  { key: '地下城市', label: '深淵建築',      code: 'ABYSS-ARCH' },
  { key: 'AI社會',   label: '人工意識',      code: 'SYNTH-MIND' },
  { key: '生態復育', label: '異變生態',      code: 'BIO-ANML'   },
  { key: '情感科技', label: '情緒操縱',      code: 'EMO-CTRL'   },
  { key: '🔍 彩蛋',  label: '[ 最高機密 ]',  code: 'TOP-SECRET' },
];

const _tagCounts: Record<string, number> = {};
for (const s of stories) {
  for (const t of s.data.tags) _tagCounts[t] = (_tagCounts[t] ?? 0) + 1;
}
const catCounts = Object.fromEntries(categories.map(c => [c.key, _tagCounts[c.key] ?? 0]));
---

<Layout title="卷宗總覽 — 弦音異象">
  <!-- ─── Header ─── -->
  <header>
    <a href="/" class="logo-back" aria-label="返回首頁">
      <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"
           stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 4L6 10l6 6"/>
      </svg>
    </a>
    <a href="/" class="logo-text-btn">弦音<em>異象</em></a>
    <div class="header-mid">
      <span class="hdr-badge">ANOMALY ARCHIVES</span>
    </div>
    <ThemeSwitcher />
  </header>

  <!-- ─── Explorer Address Bar ─── -->
  <div class="explorer-bar">
    <div class="addr-bar">
      <span class="addr-proto">ARCHIVE://</span>
      <span class="addr-sep">&nbsp;›&nbsp;</span>
      <span class="addr-root">ANOMALY-ARCHIVES</span>
      <span class="addr-sep">&nbsp;›&nbsp;</span>
      <span class="addr-current" id="addrCurrent">全部卷宗</span>
      <span class="addr-cursor">_</span>
    </div>
    <div class="addr-meta">
      <span id="addrCount">{stories.length} 件</span>
    </div>
  </div>

  <!-- ─── Directory Navigator ─── -->
  <div class="dir-nav">
    <div class="dir-row-all">
      <button class="dir-all on" id="dirAll" data-cat="全部">
        <span class="dir-folder-icon">▣</span>
        <span class="dir-name">全部卷宗<span class="dir-slash">/</span></span>
        <span class="dir-count">{stories.length}</span>
      </button>
    </div>
    <div class="dir-row-cats">
      {categories.map(cat => (
        <button class="dir-cat" data-cat={cat.key} data-code={cat.code} data-label={cat.label}>
          <span class="dir-folder-icon">▷</span>
          <span class="dir-name">{cat.label}<span class="dir-slash">/</span></span>
          <span class="dir-count">{catCounts[cat.key]}</span>
        </button>
      ))}
    </div>

    <!-- ─── My Lists panel (populated by JS when logged in) ─── -->
    <div class="my-lists-wrap" id="myListsWrap" style="display:none">
      <div class="my-lists-divider"></div>
      <div class="my-lists-head">
        <span class="my-lists-label">我的清單</span>
        <button class="my-lists-add-btn" id="myListsAddBtn" title="建立新清單">＋</button>
      </div>
      <div id="myListsBody"><!-- rendered by JS --></div>
      <!-- New list inline form -->
      <div class="my-lists-new-form" id="myListsNewForm" style="display:none">
        <input class="my-lists-input" id="myListsInput" type="text" maxlength="40" placeholder="清單名稱…" />
        <button class="my-lists-confirm" id="myListsConfirm">確認</button>
        <button class="my-lists-cancel" id="myListsCancel">✕</button>
      </div>
    </div>
  </div>

  <!-- ─── Directory Divider ─── -->
  <div class="dir-divider">
    <span class="dir-divider-path" id="dirPath">/ 全部卷宗</span>
    <span class="dir-divider-line"></span>
    <span class="dir-file-count"><span id="fileCount">{stories.length}</span> 件卷宗</span>
  </div>

  <!-- ─── File List ─── -->
  <main>
    <!-- Column header -->
    <div class="list-header">
      <span class="lh-check"></span>
      <span class="lh-icon"></span>
      <span class="lh-num">編號</span>
      <span class="lh-title">標題</span>
      <span class="lh-tags">分類</span>
      <span class="lh-time">時長</span>
      <span class="lh-date">日期</span>
      <span class="lh-arrow"></span>
    </div>

    <div class="file-list" id="fileList">
      {stories.map(story => (
        <div
          class="file-row"
          data-slug={story.slug}
          data-tags={story.data.tags.join(',')}
          data-base-href={`/stories/${story.slug}`}
        >
          <label class="file-ck-wrap" title="加入閱讀清單">
            <input type="checkbox" class="file-ck" data-slug={story.slug} />
            <span class="file-ck-box"></span>
          </label>

          <a class="file-row-link" href={`/stories/${story.slug}`}>
            <span class="file-icon" aria-hidden="true">{story.data.icon}</span>
            <span class="file-num">{story.data.fileNum}</span>
            <span class="file-title">{story.data.title}</span>
            <div class="file-tags">
              {story.data.tags.slice(0, 2).map(tag => (
                <span class="file-tag">{tag}</span>
              ))}
            </div>
            <span class="file-time">{story.data.readTime}</span>
            <span class="file-date">{story.data.date.slice(0, 7).replace('-', '.')}</span>
            <span class="file-arrow">›</span>
          </a>

          <div class="file-prog-wrap">
            <div class="file-prog-bar" data-slug={story.slug}></div>
          </div>
        </div>
      ))}
    </div>

    <div id="noResults" style="display:none">
      <div class="no-results-inner">
        <div class="no-results-icon">⊘</div>
        <div class="no-results-msg">[ 查無符合權限的檔案 ]</div>
      </div>
    </div>
  </main>

  <footer>
    <div class="ft-txt">ANOMALY ARCHIVES · CLASSIFIED · {stories.length} FILES INDEXED</div>
  </footer>

  <!-- ─── Selection Bar ─── -->
  <div class="sel-bar" id="selBar">
    <span class="sel-info">已標記 <strong id="selCount">0</strong> 件卷宗</span>
    <div class="sel-actions">
      <!-- Add to list picker (only when logged in, rendered by JS) -->
      <div class="sel-picker-wrap" id="selPickerWrap" style="display:none">
        <button class="sel-btn" id="selPickerBtn">＋ 加入清單 ▾</button>
        <div class="sel-picker-drop" id="selPickerDrop" style="display:none">
          <!-- rendered by JS -->
        </div>
      </div>
      <button class="sel-btn" id="selClear">清除</button>
      <button class="sel-btn accent" id="selRead">[ → 開始閱讀 ]</button>
    </div>
  </div>
</Layout>

<script>
  // ─── Explorer (category filter) ──────────────────────────
  function initExplorer() {
    const dirAll  = document.getElementById('dirAll') as HTMLButtonElement | null;
    const catBtns = document.querySelectorAll<HTMLButtonElement>('.dir-cat');
    const rows    = document.querySelectorAll<HTMLElement>('.file-row');
    const list    = document.getElementById('fileList');
    const noRes   = document.getElementById('noResults');
    const addrCurrent = document.getElementById('addrCurrent');
    const addrCount   = document.getElementById('addrCount');
    const dirPath     = document.getElementById('dirPath');
    const fileCount   = document.getElementById('fileCount');
    if (!dirAll || !list) return;

    function selectCat(cat: string, label: string, _code: string) {
      const url = cat === '全部' ? '/stories' : `/stories?cat=${encodeURIComponent(cat)}`;
      history.replaceState(null, '', url);

      dirAll!.classList.toggle('on', cat === '全部');
      catBtns.forEach(b => b.classList.toggle('on', b.dataset.cat === cat));

      dirAll!.querySelector('.dir-folder-icon')!.textContent = cat === '全部' ? '▣' : '▷';
      catBtns.forEach(b => {
        (b.querySelector('.dir-folder-icon') as HTMLElement).textContent =
          b.dataset.cat === cat ? '▣' : '▷';
      });

      let visible = 0;
      rows.forEach(row => {
        const tags = row.dataset.tags?.split(',') ?? [];
        const show = cat === '全部' || tags.includes(cat);
        row.style.display = show ? '' : 'none';
        if (show) visible++;

        // Update link href to carry ?cat= into story page
        const link = row.querySelector<HTMLAnchorElement>('.file-row-link');
        if (!link) return;
        const base = row.dataset.baseHref ?? link.href.split('?')[0];
        row.dataset.baseHref = base;
        link.href = cat === '全部'
          ? base
          : `${base}?cat=${encodeURIComponent(cat)}`;
      });

      if (addrCurrent) addrCurrent.textContent = cat === '全部' ? '全部卷宗' : label;
      if (addrCount)   addrCount.textContent   = `${visible} 件`;
      if (dirPath)     dirPath.textContent      = cat === '全部' ? '/ 全部卷宗' : `/ ${label}`;
      if (fileCount)   fileCount.textContent    = String(visible);
      if (noRes)       noRes.style.display      = visible === 0 ? 'block' : 'none';
    }

    dirAll.addEventListener('click', () => selectCat('全部', '全部卷宗', 'ALL'));
    catBtns.forEach(btn => {
      btn.addEventListener('click', () =>
        selectCat(btn.dataset.cat ?? '全部', btn.dataset.label ?? '', btn.dataset.code ?? '')
      );
    });

    const urlCat = new URLSearchParams(location.search).get('cat') ?? '全部';
    const savedBtn = document.querySelector<HTMLButtonElement>(`.dir-cat[data-cat="${urlCat}"]`);
    if (urlCat !== '全部' && savedBtn) {
      selectCat(urlCat, savedBtn.dataset.label ?? '', savedBtn.dataset.code ?? '');
    }
  }

  // ─── Progress bars from localStorage ─────────────────────
  function applyLocalProgress() {
    document.querySelectorAll<HTMLElement>('.file-prog-bar[data-slug]').forEach(bar => {
      const pct = parseInt(localStorage.getItem('hz-progress:' + bar.dataset.slug) || '0', 10);
      bar.style.width = pct > 0 ? pct + '%' : '0';

      // Bookmark dot on file-num
      if (localStorage.getItem('hz-bookmark:' + bar.dataset.slug) === '1') {
        const row = bar.closest('.file-row');
        const numEl = row?.querySelector('.file-num');
        if (numEl && !numEl.querySelector('.bm-dot')) {
          const dot = document.createElement('span');
          dot.className = 'bm-dot';
          dot.textContent = ' ☑';
          numEl.appendChild(dot);
        }
      }
    });
  }

  // ─── Reading list selection ───────────────────────────────
  function initSelection() {
    const selBar     = document.getElementById('selBar');
    const selCountEl = document.getElementById('selCount');
    const selClear   = document.getElementById('selClear');
    const selRead    = document.getElementById('selRead');

    let readlist: string[] = [];
    try { readlist = JSON.parse(localStorage.getItem('hz-readlist') ?? '[]'); } catch (_) {}

    function save() {
      try { localStorage.setItem('hz-readlist', JSON.stringify(readlist)); } catch (_) {}
    }

    function updateBar() {
      if (!selBar || !selCountEl) return;
      selBar.classList.toggle('visible', readlist.length > 0);
      selCountEl.textContent = String(readlist.length);
    }

    document.querySelectorAll<HTMLInputElement>('.file-ck').forEach(ck => {
      const slug = ck.dataset.slug ?? '';
      ck.checked = readlist.includes(slug);
      ck.closest<HTMLElement>('.file-row')?.classList.toggle('selected', ck.checked);

      ck.addEventListener('change', () => {
        if (ck.checked) {
          if (!readlist.includes(slug)) readlist.push(slug);
        } else {
          readlist = readlist.filter(s => s !== slug);
        }
        ck.closest<HTMLElement>('.file-row')?.classList.toggle('selected', ck.checked);
        save();
        updateBar();
      });
    });

    selClear?.addEventListener('click', () => {
      readlist = [];
      save();
      document.querySelectorAll<HTMLInputElement>('.file-ck').forEach(ck => { ck.checked = false; });
      document.querySelectorAll<HTMLElement>('.file-row.selected').forEach(r => r.classList.remove('selected'));
      updateBar();
    });

    selRead?.addEventListener('click', () => {
      if (readlist.length === 0) return;
      window.location.href = '/stories/' + readlist[0] + '?ref=readlist';
    });

    updateBar();
  }

  // ─── Multi-list (logged-in only) ─────────────────────────
  type ListItem = { id: string; name: string; slugs: string[]; is_public: boolean; share_token: string | null };

  let _lists: ListItem[] = [];
  let _activeListId: string | null = null; // null = show all / category view

  async function fetchLists(): Promise<ListItem[]> {
    try {
      const r = await fetch('/api/lists');
      if (!r.ok) return [];
      return await r.json();
    } catch (_) { return []; }
  }

  async function createList(name: string, slugs: string[] = []): Promise<ListItem | null> {
    try {
      const r = await fetch('/api/lists', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, slugs }),
      });
      if (!r.ok) return null;
      return await r.json();
    } catch (_) { return null; }
  }

  async function updateList(id: string, patch: object): Promise<ListItem | null> {
    try {
      const r = await fetch(`/api/lists/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(patch),
      });
      if (!r.ok) return null;
      return await r.json();
    } catch (_) { return null; }
  }

  async function deleteList(id: string): Promise<boolean> {
    try {
      const r = await fetch(`/api/lists/${id}`, { method: 'DELETE' });
      return r.ok;
    } catch (_) { return false; }
  }

  function renderMyLists() {
    const body = document.getElementById('myListsBody');
    if (!body) return;

    if (_lists.length === 0) {
      body.innerHTML = '<div class="my-lists-empty">尚無清單</div>';
      return;
    }

    body.innerHTML = _lists.map(list => {
      const isActive = list.id === _activeListId;
      return `<div class="my-list-item${isActive ? ' active' : ''}" data-id="${list.id}">
        <button class="mli-name-btn" data-id="${list.id}">
          <span class="mli-folder">${isActive ? '▣' : '▷'}</span>
          <span class="mli-name">${escHtml(list.name)}</span>
          <span class="mli-count">${list.slugs.length}</span>
        </button>
        <div class="mli-actions">
          ${list.share_token
            ? `<button class="mli-act share active" data-id="${list.id}" title="複製分享連結">⎘</button>`
            : `<button class="mli-act share" data-id="${list.id}" title="開啟分享連結">⎘</button>`}
          <button class="mli-act del" data-id="${list.id}" title="刪除清單">✕</button>
        </div>
      </div>`;
    }).join('');

    // Name button → filter file list to show only this list's slugs
    body.querySelectorAll<HTMLButtonElement>('.mli-name-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.id ?? '';
        _activeListId = _activeListId === id ? null : id;
        filterByActiveList();
        renderMyLists();
      });
    });

    // Share button
    body.querySelectorAll<HTMLButtonElement>('.mli-act.share').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id ?? '';
        const list = _lists.find(l => l.id === id);
        if (!list) return;
        if (list.share_token) {
          // Already public: copy link
          const url = location.origin + '/lists/' + list.share_token;
          try { await navigator.clipboard.writeText(url); } catch (_) {}
          btn.textContent = '✓';
          setTimeout(() => { btn.textContent = '⎘'; }, 1500);
        } else {
          // Enable sharing
          const updated = await updateList(id, { is_public: true });
          if (updated) {
            _lists = _lists.map(l => l.id === id ? updated : l);
            renderMyLists();
            const url = location.origin + '/lists/' + updated.share_token;
            try { await navigator.clipboard.writeText(url); } catch (_) {}
          }
        }
      });
    });

    // Delete button
    body.querySelectorAll<HTMLButtonElement>('.mli-act.del').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id ?? '';
        if (!confirm('確定要刪除這個清單？')) return;
        const ok = await deleteList(id);
        if (ok) {
          _lists = _lists.filter(l => l.id !== id);
          if (_activeListId === id) { _activeListId = null; filterByActiveList(); }
          renderMyLists();
        }
      });
    });
  }

  function filterByActiveList() {
    const rows = document.querySelectorAll<HTMLElement>('.file-row');
    const list = _activeListId ? _lists.find(l => l.id === _activeListId) : null;
    const slugSet = list ? new Set(list.slugs) : null;
    let visible = 0;
    rows.forEach(row => {
      const show = !slugSet || slugSet.has(row.dataset.slug ?? '');
      row.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    const fileCount = document.getElementById('fileCount');
    const addrCount = document.getElementById('addrCount');
    if (fileCount) fileCount.textContent = String(visible);
    if (addrCount) addrCount.textContent = `${visible} 件`;
  }

  function renderPickerDrop() {
    const drop = document.getElementById('selPickerDrop');
    if (!drop) return;
    if (_lists.length === 0) {
      drop.innerHTML = '<div class="picker-empty">尚無清單 — 請先建立</div>';
    } else {
      drop.innerHTML = _lists.map(l =>
        `<button class="picker-item" data-id="${l.id}">${escHtml(l.name)} <span class="picker-count">(${l.slugs.length})</span></button>`
      ).join('') + '<div class="picker-sep"></div><button class="picker-item picker-new" id="pickerNewBtn">＋ 建立新清單</button>';

      drop.querySelectorAll<HTMLButtonElement>('.picker-item:not(.picker-new)').forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = btn.dataset.id ?? '';
          const selected = getSelectedSlugs();
          if (selected.length === 0) { closePicker(); return; }
          const updated = await updateList(id, { add: selected });
          if (updated) {
            _lists = _lists.map(l => l.id === id ? updated : l);
            renderMyLists();
          }
          closePicker();
        });
      });

      drop.querySelector<HTMLButtonElement>('#pickerNewBtn')?.addEventListener('click', () => {
        closePicker();
        openNewListForm(getSelectedSlugs());
      });
    }
  }

  function getSelectedSlugs(): string[] {
    try { return JSON.parse(localStorage.getItem('hz-readlist') ?? '[]'); } catch (_) { return []; }
  }

  function closePicker() {
    const drop = document.getElementById('selPickerDrop');
    if (drop) drop.style.display = 'none';
  }

  function openNewListForm(initialSlugs: string[] = []) {
    const wrap = document.getElementById('myListsWrap');
    const form = document.getElementById('myListsNewForm');
    const input = document.getElementById('myListsInput') as HTMLInputElement | null;
    if (wrap) wrap.style.display = '';
    if (form) form.style.display = 'flex';
    if (input) { input.value = ''; input.focus(); input.dataset.initialSlugs = JSON.stringify(initialSlugs); }
  }

  function escHtml(s: string) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  async function initLists() {
    // Check if logged in via Clerk
    let isLoggedIn = false;
    try {
      // @ts-ignore
      await new Promise<void>(resolve => {
        // @ts-ignore
        if (window.Clerk?.loaded) { resolve(); return; }
        let tries = 0;
        const t = setInterval(() => {
          // @ts-ignore
          if (window.Clerk?.loaded || ++tries > 20) { clearInterval(t); resolve(); }
        }, 200);
      });
      // @ts-ignore
      isLoggedIn = !!(await window.Clerk?.user);
    } catch (_) {}

    if (!isLoggedIn) return;

    // Show my lists panel and selection picker
    const wrap = document.getElementById('myListsWrap');
    const pickerWrap = document.getElementById('selPickerWrap');
    if (wrap) wrap.style.display = '';
    if (pickerWrap) pickerWrap.style.display = '';

    _lists = await fetchLists();
    renderMyLists();

    // New list form
    const addBtn   = document.getElementById('myListsAddBtn');
    const newForm  = document.getElementById('myListsNewForm');
    const input    = document.getElementById('myListsInput') as HTMLInputElement | null;
    const confirm  = document.getElementById('myListsConfirm');
    const cancel   = document.getElementById('myListsCancel');

    addBtn?.addEventListener('click', () => {
      if (newForm) newForm.style.display = 'flex';
      input?.focus();
    });

    cancel?.addEventListener('click', () => {
      if (newForm) newForm.style.display = 'none';
      if (input) input.value = '';
    });

    async function submitNewList() {
      const name = input?.value.trim() ?? '';
      if (!name) { input?.focus(); return; }
      let initialSlugs: string[] = [];
      try { initialSlugs = JSON.parse(input?.dataset.initialSlugs ?? '[]'); } catch (_) {}
      const created = await createList(name, initialSlugs);
      if (created) {
        _lists = [..._lists, created];
        renderMyLists();
      }
      if (newForm) newForm.style.display = 'none';
      if (input) { input.value = ''; input.dataset.initialSlugs = ''; }
    }

    confirm?.addEventListener('click', submitNewList);
    input?.addEventListener('keydown', e => { if (e.key === 'Enter') submitNewList(); if (e.key === 'Escape') cancel?.click(); });

    // Picker dropdown
    const pickerBtn  = document.getElementById('selPickerBtn');
    const pickerDrop = document.getElementById('selPickerDrop');

    pickerBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = pickerDrop?.style.display !== 'none';
      if (!isOpen) {
        renderPickerDrop();
        if (pickerDrop) pickerDrop.style.display = 'flex';
      } else {
        closePicker();
      }
    });

    document.addEventListener('click', (e) => {
      const wrap = document.getElementById('selPickerWrap');
      if (wrap && !wrap.contains(e.target as Node)) closePicker();
    });
  }

  function init() {
    initExplorer();
    applyLocalProgress();
    initSelection();
    initLists();
  }

  document.addEventListener('astro:after-swap', init);
  init();
</script>

<style>
  /* ─── Header ─────────────────────────────────────── */
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: 52px;
    display: flex;
    align-items: center;
    padding: 0 16px;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    gap: 12px;
  }
  .logo-back {
    display: flex;
    align-items: center;
    color: var(--text-muted);
    transition: color 0.2s;
    flex-shrink: 0;
  }
  .logo-back:hover { color: var(--accent); }
  .logo-back svg { width: 18px; height: 18px; }
  a.logo-text-btn {
    font-family: 'Noto Serif TC', serif;
    font-weight: 900;
    font-size: 1rem;
    color: var(--text);
    text-decoration: none;
    letter-spacing: 0.1em;
    flex-shrink: 0;
  }
  a.logo-text-btn em { color: var(--accent); font-style: normal; }
