---
import Layout from '../../layouts/Layout.astro';
import StoryCard from '../../components/StoryCard.astro';
import ThemeSwitcher from '../../components/ThemeSwitcher.astro';
import { getCollection } from 'astro:content';

const allStories = await getCollection('stories', ({ data }) => data.published);
const stories = allStories.sort((a, b) => b.data.date.localeCompare(a.data.date));

const categories = [
  { key: '記憶科技', label: '精神汙染',      code: 'PSY-CONT'   },
  { key: '地下城市', label: '深淵建築',      code: 'ABYSS-ARCH' },
  { key: 'AI社會',   label: '人工意識',      code: 'SYNTH-MIND' },
  { key: '生態復育', label: '異變生態',      code: 'BIO-ANML'   },
  { key: '情感科技', label: '情緒操縱',      code: 'EMO-CTRL'   },
  { key: '🔍 彩蛋',  label: '[ 最高機密 ]',  code: 'TOP-SECRET' },
];

const catCounts = Object.fromEntries(
  categories.map(c => [c.key, stories.filter(s => s.data.tags.includes(c.key)).length])
);
---

<Layout title="卷宗總覽 — 弦音異象">
  <!-- ─── Header ─── -->
  <header>
    <a href="/" class="logo-back" aria-label="返回首頁">
      <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"
           stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 4L6 10l6 6"/>
      </svg>
    </a>
    <a href="/" class="logo-text-btn">弦音<em>異象</em></a>
    <div class="header-mid">
      <span class="hdr-badge">ANOMALY ARCHIVES</span>
    </div>
    <ThemeSwitcher />
  </header>

  <!-- ─── Explorer Toolbar ─── -->
  <div class="explorer-bar">
    <!-- Address bar -->
    <div class="addr-bar">
      <span class="addr-proto">ARCHIVE://</span>
      <span class="addr-sep">&nbsp;›&nbsp;</span>
      <span class="addr-root">ANOMALY-ARCHIVES</span>
      <span class="addr-sep">&nbsp;›&nbsp;</span>
      <span class="addr-current" id="addrCurrent">全部卷宗</span>
      <span class="addr-cursor">_</span>
    </div>
    <div class="addr-meta">
      <span id="addrCount">{stories.length} 件</span>
    </div>
  </div>

  <!-- ─── Directory Navigator ─── -->
  <div class="dir-nav">
    <!-- Row 1: Root / All -->
    <div class="dir-row-all">
      <button class="dir-all on" id="dirAll" data-cat="全部">
        <span class="dir-folder-icon">▣</span>
        <span class="dir-name">全部卷宗<span class="dir-slash">/</span></span>
        <span class="dir-count">{stories.length}</span>
      </button>
    </div>
    <!-- Row 2: Categories -->
    <div class="dir-row-cats">
      {categories.map(cat => (
        <button class="dir-cat" data-cat={cat.key} data-code={cat.code} data-label={cat.label}>
          <span class="dir-folder-icon">▷</span>
          <span class="dir-name">{cat.label}<span class="dir-slash">/</span></span>
          <span class="dir-count">{catCounts[cat.key]}</span>
        </button>
      ))}
    </div>
  </div>

  <!-- ─── Directory Divider ─── -->
  <div class="dir-divider">
    <span class="dir-divider-path" id="dirPath">/ 全部卷宗</span>
    <span class="dir-divider-line"></span>
    <span class="dir-file-count"><span id="fileCount">{stories.length}</span> 件卷宗</span>
  </div>

  <!-- ─── Stories Grid ─── -->
  <main>
    <div class="cards-grid" id="storiesGrid">
      {stories.map(story => (
        <StoryCard
          title={story.data.title}
          fileNum={story.data.fileNum}
          date={story.data.date}
          readTime={story.data.readTime}
          tags={story.data.tags}
          level={story.data.level}
          excerpt={story.data.excerpt}
          vis={story.data.vis}
          icon={story.data.icon}
          slug={story.slug}
        />
      ))}
    </div>
    <div id="noResults" style="display:none">
      <div class="no-results-inner">
        <div class="no-results-icon">⊘</div>
        <div class="no-results-msg">[ 查無符合權限的檔案 ]</div>
      </div>
    </div>
  </main>

  <footer>
    <div class="ft-txt">ANOMALY ARCHIVES · CLASSIFIED · {stories.length} FILES INDEXED</div>
  </footer>
</Layout>

<script>
  function sGet(k: string) { try { return localStorage.getItem(k); } catch(_) { return null; } }
  function sSet(k: string, v: string) { try { localStorage.setItem(k, v); } catch(_) {} }

  function initExplorer() {
    const dirAll  = document.getElementById('dirAll') as HTMLButtonElement | null;
    const catBtns = document.querySelectorAll<HTMLButtonElement>('.dir-cat');
    const cards   = document.querySelectorAll<HTMLElement>('.story-card');
    const grid    = document.getElementById('storiesGrid');
    const noRes   = document.getElementById('noResults');
    const addrCurrent = document.getElementById('addrCurrent');
    const addrCount   = document.getElementById('addrCount');
    const dirPath     = document.getElementById('dirPath');
    const fileCount   = document.getElementById('fileCount');
    if (!dirAll || !grid) return;

    // Build tag index once
    cards.forEach(card => {
      if (!card.dataset.tags) {
        card.dataset.tags = Array.from(card.querySelectorAll('.tag'))
          .map(t => t.textContent?.trim() ?? '').join(',');
      }
    });

    const total = cards.length;

    function selectCat(cat: string, label: string, code: string) {
      sSet('hz-archive-cat', cat);

      // Update active state
      dirAll!.classList.toggle('on', cat === '全部');
      catBtns.forEach(b => b.classList.toggle('on', b.dataset.cat === cat));

      // Update folder icon
      dirAll!.querySelector('.dir-folder-icon')!.textContent = cat === '全部' ? '▣' : '▷';
      catBtns.forEach(b => {
        (b.querySelector('.dir-folder-icon') as HTMLElement).textContent =
          b.dataset.cat === cat ? '▣' : '▷';
      });

      // Filter cards
      let visible = 0;
      cards.forEach(card => {
        const tags = card.dataset.tags?.split(',') ?? [];
        const show = cat === '全部' || tags.includes(cat);
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      // Update address bar + divider
      if (addrCurrent) addrCurrent.textContent = cat === '全部' ? '全部卷宗' : label;
      if (addrCount)   addrCount.textContent   = `${visible} 件`;
      if (dirPath)     dirPath.textContent      = cat === '全部' ? '/ 全部卷宗' : `/ ${label}`;
      if (fileCount)   fileCount.textContent    = String(visible);

      if (noRes) noRes.style.display = visible === 0 ? 'block' : 'none';
    }

    dirAll.addEventListener('click', () => selectCat('全部', '全部卷宗', 'ALL'));
    catBtns.forEach(btn => {
      btn.addEventListener('click', () =>
        selectCat(btn.dataset.cat ?? '全部', btn.dataset.label ?? '', btn.dataset.code ?? '')
      );
    });

    // Restore last selection
    const saved = sGet('hz-archive-cat') ?? '全部';
    const savedBtn = document.querySelector<HTMLButtonElement>(`.dir-cat[data-cat="${saved}"]`);
    if (saved !== '全部' && savedBtn) {
      selectCat(saved, savedBtn.dataset.label ?? '', savedBtn.dataset.code ?? '');
    }
  }

  document.addEventListener('astro:after-swap', initExplorer);
  initExplorer();
</script>

<style>
  /* ─── Header ─────────────────────────────────────── */
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: 52px;
    display: flex;
    align-items: center;
    padding: 0 16px;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    gap: 12px;
  }
  .logo-back {
    display: flex;
    align-items: center;
    color: var(--text-muted);
    transition: color 0.2s;
    flex-shrink: 0;
  }
  .logo-back:hover { color: var(--accent); }
  .logo-back svg { width: 18px; height: 18px; }
  a.logo-text-btn {
    font-family: 'Noto Serif TC', serif;
    font-weight: 900;
    font-size: 1rem;
    color: var(--text);
    text-decoration: none;
    letter-spacing: 0.1em;
    flex-shrink: 0;
  }
  a.logo-text-btn em { color: var(--accent); font-style: normal; }
  .header-mid {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hdr-badge {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.25em;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 3px 10px;
  }

  /* ─── Explorer Address Bar ───────────────────────── */
  .explorer-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 24px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.72rem;
    gap: 16px;
  }
  .addr-bar {
    display: flex;
    align-items: center;
    gap: 0;
    overflow: hidden;
  }
  .addr-proto { color: var(--accent); font-weight: bold; }
  .addr-sep   { color: var(--text-muted); }
  .addr-root  { color: var(--text-dim); }
  .addr-current { color: var(--text); font-weight: bold; }
  .addr-cursor {
    color: var(--accent);
    animation: blink 1.1s step-end infinite;
    margin-left: 1px;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
  .addr-meta {
    font-size: 0.62rem;
    color: var(--text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ─── Directory Navigator ────────────────────────── */
  .dir-nav {
    padding: 16px 24px 12px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
  }
  .dir-row-all { display: flex; }
  .dir-row-cats {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  /* ─── All / Root Button ──────────────────────────── */
  .dir-all {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    padding: 8px 16px;
    cursor: pointer;
    transition: all 0.18s;
  }
  .dir-all:hover, .dir-all.on {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-dim);
  }

  /* ─── Category Folder Buttons ────────────────────── */
  .dir-cat {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: none;
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    padding: 7px 14px;
    cursor: pointer;
    transition: all 0.18s;
  }
  .dir-cat:hover {
    border-color: var(--text-dim);
    color: var(--text);
  }
  .dir-cat.on {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-dim);
  }

  /* ─── Shared folder button elements ─────────────── */
  .dir-folder-icon {
    font-size: 0.65rem;
    opacity: 0.7;
  }
  .dir-slash {
    color: var(--accent);
    opacity: 0.6;
  }
  .dir-count {
    font-size: 0.6rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 1px 5px;
    letter-spacing: 0;
  }
  .dir-all.on .dir-count,
  .dir-cat.on .dir-count {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ─── Directory Divider ──────────────────────────── */
  .dir-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 24px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.62rem;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
  }
  .dir-divider-path { color: var(--accent); white-space: nowrap; }
  .dir-divider-line { flex: 1; height: 1px; background: var(--border); }
  .dir-file-count { white-space: nowrap; }

  /* ─── Stories Grid ───────────────────────────────── */
  main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 32px 24px 60px;
  }
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }

  /* ─── No Results ─────────────────────────────────── */
  #noResults {
    text-align: center;
    padding: 80px 0;
  }
  .no-results-inner { display: inline-flex; flex-direction: column; align-items: center; gap: 12px; }
  .no-results-icon  { font-size: 2rem; color: var(--danger); font-family: 'Share Tech Mono', monospace; }
  .no-results-msg   { font-family: 'Share Tech Mono', monospace; font-size: 0.8rem; color: var(--danger); letter-spacing: 0.1em; }

  /* ─── Footer ─────────────────────────────────────── */
  footer {
    text-align: center;
    padding: 40px 24px;
    border-top: 1px solid var(--border);
  }
  .ft-txt {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.62rem;
    color: var(--text-muted);
    letter-spacing: 0.15em;
  }

  /* ─── Responsive ─────────────────────────────────── */
  @media (max-width: 600px) {
    .explorer-bar { padding: 8px 16px; }
    .dir-nav { padding: 12px 16px 10px; }
    .dir-cat { padding: 6px 10px; font-size: 0.68rem; }
    main { padding: 24px 16px 48px; }
    .cards-grid { grid-template-columns: 1fr; }
    .hdr-badge { display: none; }
  }
</style>
