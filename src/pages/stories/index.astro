---
import Layout from '../../layouts/Layout.astro';
import ThemeSwitcher from '../../components/ThemeSwitcher.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const allStories = await getCollection('stories', ({ data }) => data.published);
const stories = allStories.sort((a, b) => b.data.fileNum.localeCompare(a.data.fileNum));

const categories = [
  { key: '★ 精選',   label: '★ 精選',        code: 'FEATURED'   },
  { key: '記憶科技', label: '精神汙染',        code: 'PSY-CONT'   },
  { key: '地下城市', label: '深淵建築',        code: 'ABYSS-ARCH' },
  { key: 'AI社會',   label: '人工意識',        code: 'SYNTH-MIND' },
  { key: '生態復育', label: '異變生態',        code: 'BIO-ANML'   },
  { key: '情感科技', label: '情緒操縱',        code: 'EMO-CTRL'   },
  { key: '🔍 彩蛋',  label: '[ 最高機密 ]',   code: 'TOP-SECRET' },
];

const _tagCounts: Record<string, number> = {};
for (const s of stories) {
  for (const t of s.data.tags) _tagCounts[t] = (_tagCounts[t] ?? 0) + 1;
}
const catCounts: Record<string, number> = Object.fromEntries(categories.map(c => [c.key, _tagCounts[c.key] ?? 0]));
catCounts['★ 精選'] = stories.filter(s => s.data.featured).length;

// Site-curated lists — edited via Keystatic > 精選清單
import curatedData from '../../data/curated-lists.json';
const _publishedSlugs = new Set(stories.map(s => s.slug));
const curatedLists = [
  { id: 'starter',  label: curatedData.starter.label,  icon: curatedData.starter.icon,  slugs: curatedData.starter.slugs.filter(s => s && _publishedSlugs.has(s)) },
  { id: 'thriller', label: curatedData.thriller.label, icon: curatedData.thriller.icon, slugs: curatedData.thriller.slugs.filter(s => s && _publishedSlugs.has(s)) },
];

const paidStories = stories.filter(s => s.data.level === 'paid');
---

<Layout title="卷宗總覽 — 弦音異象">
  <!-- ─── Header ─── -->
  <header>
    <a href="/" class="logo-back" aria-label="返回首頁">
      <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"
           stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 4L6 10l6 6"/>
      </svg>
    </a>
    <a href="/" class="logo-text-btn">弦音<em>異象</em></a>
    <div class="header-mid">
      <span class="hdr-badge">ANOMALY ARCHIVES</span>
    </div>
    <ThemeSwitcher />
  </header>

  <!-- ─── Explorer Address Bar ─── -->
  <div class="explorer-bar">
    <div class="addr-bar">
      <span class="addr-proto">ARCHIVE://</span>
      <span class="addr-sep">&nbsp;›&nbsp;</span>
      <span class="addr-root">ANOMALY-ARCHIVES</span>
      <span class="addr-sep">&nbsp;›&nbsp;</span>
      <span class="addr-current" id="addrCurrent">全部卷宗</span>
      <span class="addr-cursor">_</span>
    </div>
    <div class="addr-meta">
      <span id="addrCount">{stories.length} 件</span>
    </div>
  </div>

  <!-- ─── Directory Navigator ─── -->
  <div class="dir-nav">
    <div class="dir-row-all">
      <button class="dir-all on" id="dirAll" data-cat="全部">
        <span class="dir-folder-icon">▣</span>
        <span class="dir-name">全部卷宗<span class="dir-slash">/</span></span>
        <span class="dir-count">{stories.length}</span>
      </button>
    </div>
    <div class="dir-row-cats">
      {categories.map(cat => (
        <button class="dir-cat" data-cat={cat.key} data-code={cat.code} data-label={cat.label}>
          <span class="dir-folder-icon">▷</span>
          <span class="dir-name">{cat.label}<span class="dir-slash">/</span></span>
          <span class="dir-count">{catCounts[cat.key]}</span>
        </button>
      ))}
    </div>

    <!-- ─── Site-curated Lists ─── -->
    <div class="dir-extra-wrap">
      <div class="dir-extra-divider"></div>
      <div class="dir-extra-label">站內精選</div>
      <div class="dir-row-cats">
        {curatedLists.map(list => (
          <button
            class="dir-cat dir-curated"
            data-curated-id={list.id}
            data-curated-slugs={JSON.stringify(list.slugs)}
            data-label={list.label}
          >
            <span class="dir-folder-icon">▷</span>
            <span class="dir-name">{list.label}<span class="dir-slash">/</span></span>
            <span class="dir-count">{list.slugs.length}</span>
          </button>
        ))}
      </div>
    </div>

    <!-- ─── Paid Zone ─── -->
    {paidStories.length > 0 && (
      <div class="dir-extra-wrap">
        <div class="dir-extra-divider"></div>
        <div class="dir-extra-label">付費專區</div>
        <div class="dir-row-cats">
          <button
            class="dir-cat dir-paid"
            id="dirPaid"
            data-paid-slugs={JSON.stringify(paidStories.map(s => s.slug))}
          >
            <span class="dir-folder-icon">⎔</span>
            <span class="dir-name">付費內容<span class="dir-slash">/</span></span>
            <span class="dir-count">{paidStories.length}</span>
          </button>
        </div>
      </div>
    )}

  </div>

  <!-- ─── Directory Divider ─── -->
  <div class="dir-divider">
    <span class="dir-divider-path" id="dirPath">/ 全部卷宗</span>
    <span class="dir-divider-line"></span>
    <span class="dir-file-count"><span id="fileCount">{stories.length}</span> 件卷宗</span>
  </div>

  <!-- ─── File List ─── -->
  <main>
    <!-- Column header -->
    <div class="list-header">
      <span class="lh-icon"></span>
      <span class="lh-num">編號</span>
      <span class="lh-title">標題</span>
      <span class="lh-tags">分類</span>
      <span class="lh-time">時長</span>
      <span class="lh-date">日期</span>
      <span class="lh-arrow"></span>
    </div>

    <div class="file-list" id="fileList">
      {stories.map(story => (
        <div
          class={`file-row${story.data.featured ? ' featured' : ''}`}
          data-slug={story.slug}
          data-tags={story.data.tags.join(',')}
          data-featured={story.data.featured ? '1' : '0'}
          data-base-href={`/stories/${story.slug}`}
        >
          <a class="file-row-link" href={`/stories/${story.slug}`}>
            <span class="file-icon" aria-hidden="true">{story.data.icon}</span>
            <span class="file-num">{story.data.fileNum}</span>
            <span class="file-title">{story.data.title}</span>
            <div class="file-tags">
              {story.data.tags.slice(0, 2).map(tag => (
                <span class="file-tag">{tag}</span>
              ))}
            </div>
            <span class="file-time">{story.data.readTime}</span>
            <span class="file-date">{story.data.date.slice(0, 7).replace('-', '.')}</span>
            <span class="file-arrow">›</span>
          </a>

          <div class="file-prog-wrap">
            <div class="file-prog-bar" data-slug={story.slug}></div>
          </div>
        </div>
      ))}
    </div>

    <div id="noResults" style="display:none">
      <div class="no-results-inner">
        <div class="no-results-icon">⊘</div>
        <div class="no-results-msg">[ 查無符合權限的檔案 ]</div>
      </div>
    </div>
  </main>

  <footer>
    <div class="ft-txt">ANOMALY ARCHIVES · CLASSIFIED · {stories.length} FILES INDEXED</div>
  </footer>

</Layout>

<script>
  // ─── Explorer (category filter) ──────────────────────────
  function initExplorer() {
    const dirAll  = document.getElementById('dirAll') as HTMLButtonElement | null;
    const catBtns = document.querySelectorAll<HTMLButtonElement>('.dir-cat');
    const rows    = document.querySelectorAll<HTMLElement>('.file-row');
    const list    = document.getElementById('fileList');
    const noRes   = document.getElementById('noResults');
    const addrCurrent = document.getElementById('addrCurrent');
    const addrCount   = document.getElementById('addrCount');
    const dirPath     = document.getElementById('dirPath');
    const fileCount   = document.getElementById('fileCount');
    if (!dirAll || !list) return;

    function selectCat(cat: string, label: string, _code: string) {
      const url = cat === '全部' ? '/stories' : `/stories?cat=${encodeURIComponent(cat)}`;
      history.replaceState(null, '', url);

      dirAll!.classList.toggle('on', cat === '全部');
      catBtns.forEach(b => b.classList.toggle('on', b.dataset.cat === cat));

      dirAll!.querySelector('.dir-folder-icon')!.textContent = cat === '全部' ? '▣' : '▷';
      catBtns.forEach(b => {
        (b.querySelector('.dir-folder-icon') as HTMLElement).textContent =
          b.dataset.cat === cat ? '▣' : '▷';
      });

      let visible = 0;
      rows.forEach(row => {
        const tags = row.dataset.tags?.split(',') ?? [];
        const show = cat === '全部' || tags.includes(cat) || (cat === '★ 精選' && row.dataset.featured === '1');
        row.style.display = show ? '' : 'none';
        if (show) visible++;

        // Update link href to carry list context into reader
        const link = row.querySelector<HTMLAnchorElement>('.file-row-link');
        if (!link) return;
        const base = row.dataset.baseHref ?? link.href.split('?')[0];
        row.dataset.baseHref = base;
        const ctx = cat === '全部' ? 'all' : 'cat:' + cat;
        link.href = base + '?list=' + encodeURIComponent(ctx) + '&ref=stories';
      });

      if (addrCurrent) addrCurrent.textContent = cat === '全部' ? '全部卷宗' : label;
      if (addrCount)   addrCount.textContent   = `${visible} 件`;
      if (dirPath)     dirPath.textContent      = cat === '全部' ? '/ 全部卷宗' : `/ ${label}`;
      if (fileCount)   fileCount.textContent    = String(visible);
      if (noRes)       noRes.style.display      = visible === 0 ? 'block' : 'none';
    }

    // ─── Curated list filter ──────────────────────────────
    function selectCurated(btn: HTMLButtonElement) {
      const slugSet    = new Set<string>(JSON.parse(btn.dataset.curatedSlugs ?? '[]'));
      const label      = btn.dataset.label ?? '';
      const curatedId  = btn.dataset.curatedId ?? '';
      const curatedCtx = curatedId ? 'curated:' + curatedId : 'all';
      history.replaceState(null, '', curatedId ? '/stories?curated=' + curatedId : '/stories');

      // Deactivate all dir buttons
      dirAll!.classList.remove('on');
      catBtns.forEach(b => b.classList.remove('on'));
      document.querySelectorAll<HTMLButtonElement>('.dir-curated,.dir-paid').forEach(b => b.classList.remove('on'));
      dirAll!.querySelector('.dir-folder-icon')!.textContent = '▷';
      catBtns.forEach(b => { (b.querySelector('.dir-folder-icon') as HTMLElement).textContent = '▷'; });
      btn.classList.add('on');
      (btn.querySelector('.dir-folder-icon') as HTMLElement).textContent = '▣';

      let visible = 0;
      rows.forEach(row => {
        const show = slugSet.has(row.dataset.slug ?? '');
        row.style.display = show ? '' : 'none';
        if (show) { visible++; }
        const link = row.querySelector<HTMLAnchorElement>('.file-row-link');
        const base = row.dataset.baseHref ?? (link ? link.href.split('?')[0] : '');
        if (link) link.href = base + '?list=' + encodeURIComponent(curatedCtx) + '&ref=stories';
      });

      if (addrCurrent) addrCurrent.textContent = label;
      if (addrCount)   addrCount.textContent   = `${visible} 件`;
      if (dirPath)     dirPath.textContent      = `/ ${label}`;
      if (fileCount)   fileCount.textContent    = String(visible);
      if (noRes)       noRes.style.display      = visible === 0 ? 'block' : 'none';
    }

    document.querySelectorAll<HTMLButtonElement>('.dir-curated').forEach(btn => {
      btn.addEventListener('click', () => selectCurated(btn));
    });
    document.querySelector<HTMLButtonElement>('#dirPaid')?.addEventListener('click', (e) => {
      selectCurated(e.currentTarget as HTMLButtonElement);
    });

    dirAll.addEventListener('click', () => selectCat('全部', '全部卷宗', 'ALL'));
    catBtns.forEach(btn => {
      btn.addEventListener('click', () =>
        selectCat(btn.dataset.cat ?? '全部', btn.dataset.label ?? '', btn.dataset.code ?? '')
      );
    });

    const urlParams  = new URLSearchParams(location.search);
    const urlCat     = urlParams.get('cat') ?? '全部';
    const urlCurated = urlParams.get('curated');
    if (urlCurated) {
      const curatedBtn = document.querySelector<HTMLButtonElement>(`[data-curated-id="${urlCurated}"]`);
      if (curatedBtn) selectCurated(curatedBtn);
    } else if (urlCat !== '全部') {
      const savedBtn = document.querySelector<HTMLButtonElement>(`.dir-cat[data-cat="${urlCat}"]`);
      if (savedBtn) selectCat(urlCat, savedBtn.dataset.label ?? '', savedBtn.dataset.code ?? '');
    }
  }

  // ─── Progress bars from localStorage ─────────────────────
  function applyLocalProgress() {
    document.querySelectorAll<HTMLElement>('.file-prog-bar[data-slug]').forEach(bar => {
      const pct = parseInt(localStorage.getItem('hz-progress:' + bar.dataset.slug) || '0', 10);
      bar.style.width = pct > 0 ? pct + '%' : '0';

      // Bookmark dot on file-num
      if (localStorage.getItem('hz-bookmark:' + bar.dataset.slug) === '1') {
        const row = bar.closest('.file-row');
        const numEl = row?.querySelector('.file-num');
        if (numEl && !numEl.querySelector('.bm-dot')) {
          const dot = document.createElement('span');
          dot.className = 'bm-dot';
          dot.textContent = ' ☑';
          numEl.appendChild(dot);
        }
      }
    });
  }

  function init() {
    initExplorer();
    applyLocalProgress();
  }

  document.addEventListener('astro:after-swap', init);
  init();
</script>

<style>
  /* ─── Touch: prevent double-tap zoom on buttons ──── */
  button { touch-action: manipulation; }

  /* ─── Header ─────────────────────────────────────── */
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: 52px;
    display: flex;
    align-items: center;
    padding: 0 16px;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    gap: 12px;
  }
  .logo-back {
    display: flex;
    align-items: center;
    color: var(--text-muted);
    transition: color 0.2s;
    flex-shrink: 0;
  }
  .logo-back:hover { color: var(--accent); }
  .logo-back svg { width: 18px; height: 18px; }
  a.logo-text-btn {
    font-family: 'Noto Serif TC', serif;
    font-weight: 900;
    font-size: 1rem;
    color: var(--text);
    text-decoration: none;
    letter-spacing: 0.1em;
    flex-shrink: 0;
  }
  a.logo-text-btn em { color: var(--accent); font-style: normal; }
  .header-mid {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hdr-badge {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.25em;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 3px 10px;
  }

  /* ─── Explorer Address Bar ───────────────────────── */
  .explorer-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 24px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.72rem;
    gap: 16px;
  }
  .addr-bar { display: flex; align-items: center; overflow: hidden; }
  .addr-proto { color: var(--accent); font-weight: bold; }
  .addr-sep   { color: var(--text-muted); }
  .addr-root  { color: var(--text-dim); }
  .addr-current { color: var(--text); font-weight: bold; }
  .addr-cursor {
    color: var(--accent);
    animation: blink 1.1s step-end infinite;
    margin-left: 1px;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
  .addr-meta {
    font-size: 0.62rem;
    color: var(--text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ─── Directory Navigator ────────────────────────── */
  .dir-nav {
    padding: 16px 24px 12px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
  }
  .dir-row-all { display: flex; }
  .dir-row-cats { display: flex; flex-wrap: wrap; gap: 8px; }

  .dir-all {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    padding: 8px 16px;
    cursor: pointer;
    transition: all 0.18s;
  }
  .dir-all:hover, .dir-all.on {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-dim);
  }
  .dir-cat {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: none;
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    padding: 7px 14px;
    cursor: pointer;
    transition: all 0.18s;
  }
  .dir-cat:hover { border-color: var(--text-dim); color: var(--text); }
  .dir-cat.on { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }
  .dir-folder-icon { font-size: 0.65rem; opacity: 0.7; }
  .dir-slash { color: var(--accent); opacity: 0.6; }
  .dir-count {
    font-size: 0.6rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 1px 5px;
    letter-spacing: 0;
  }
  .dir-all.on .dir-count, .dir-cat.on .dir-count { border-color: var(--accent); color: var(--accent); }

  /* ─── Directory Divider ──────────────────────────── */
  .dir-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 24px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.62rem;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
  }
  .dir-divider-path { color: var(--accent); white-space: nowrap; }
  .dir-divider-line { flex: 1; height: 1px; background: var(--border); }
  .dir-file-count { white-space: nowrap; }

  /* ─── Main ───────────────────────────────────────── */
  main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 0 80px;
  }

  /* ─── Column Header ──────────────────────────────── */
  .list-header {
    display: flex;
    align-items: center;
    padding: 6px 0;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.58rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    user-select: none;
  }
  .lh-icon  { width: 28px; flex-shrink: 0; }
  .lh-num   { width: 80px; flex-shrink: 0; padding-left: 2px; }
  .lh-title { flex: 1; min-width: 0; }
  .lh-tags  { width: 160px; flex-shrink: 0; display: flex; gap: 4px; }
  .lh-time  { width: 48px; flex-shrink: 0; text-align: right; }
  .lh-date  { width: 72px; flex-shrink: 0; text-align: right; padding-right: 8px; }
  .lh-arrow { width: 32px; flex-shrink: 0; }

  /* ─── File List ──────────────────────────────────── */
  .file-list { display: flex; flex-direction: column; }

  .file-row {
    position: relative;
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--border);
    transition: background 0.12s;
    overflow: hidden;
  }
  .file-row:hover { background: var(--surface); }
  /* ─── Row Link ───────────────────────────────────── */
  .file-row-link {
    display: flex;
    align-items: center;
    flex: 1;
    gap: 0;
    padding: 11px 0;
    text-decoration: none;
    color: inherit;
    min-width: 0;
  }
  .file-icon {
    width: 28px;
    font-size: 0.8rem;
    color: var(--text-muted);
    flex-shrink: 0;
    text-align: center;
  }
  .file-num {
    width: 80px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.63rem;
    color: var(--accent);
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }
  .bm-dot { color: var(--accent); font-size: 0.65rem; }
  .file-title {
    font-family: 'Noto Serif TC', serif;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text);
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    padding-right: 16px;
  }
  .file-row:hover .file-title { color: var(--accent); }
  .file-tags {
    width: 160px;
    flex-shrink: 0;
    display: flex;
    gap: 4px;
    overflow: hidden;
  }
  .file-tag {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.55rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 2px 5px;
    letter-spacing: 0.03em;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .file-time {
    width: 48px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.6rem;
    color: var(--text-muted);
    flex-shrink: 0;
    text-align: right;
  }
  .file-date {
    width: 72px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.6rem;
    color: var(--text-muted);
    flex-shrink: 0;
    text-align: right;
    padding-right: 8px;
  }
  .file-arrow {
    width: 32px;
    font-size: 1rem;
    color: var(--text-dim);
    flex-shrink: 0;
    text-align: center;
    transition: transform 0.15s, color 0.15s;
  }
  .file-row:hover .file-arrow { color: var(--accent); transform: translateX(2px); }

  /* ─── Progress bar (bottom line) ────────────────── */
  .file-prog-wrap {
    position: absolute;
    bottom: 0;
    left: 40px;
    right: 0;
    height: 2px;
    pointer-events: none;
  }
  .file-prog-bar {
