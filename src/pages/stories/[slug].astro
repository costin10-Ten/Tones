---
import Layout from '../../layouts/Layout.astro';
import ThemeSwitcher from '../../components/ThemeSwitcher.astro';
import { PaymentGateway } from '../../components/PaymentGateway';
import { ErrorBoundary } from '../../components/ErrorBoundary';
import { getCollection, getEntry } from 'astro:content';
import { supabase } from '../../lib/supabase';

export const prerender = false;

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/stories');

const entry = await getEntry('stories', slug);
if (!entry || !entry.data.published) {
  return Astro.redirect('/stories');
}

const { Content } = await entry.render();

// ─── Server-side auth check ──────────────────────────────────
const userId = Astro.locals.auth?.()?.userId ?? null;

const level = entry.data.level;
const isRestricted = level === 'restricted';
const isTopSecret  = level === 'top-secret';
const isPaid       = level === 'paid';

const signInUrl = `/sign-in?redirect_url=${encodeURIComponent(Astro.url.pathname)}`;

// Paid content: check if user has unlocked this story in user_unlocks table
let isUnlocked = false;
if (isPaid && userId) {
  const { data } = await supabase
    .from('user_unlocks')
    .select('story_slug')
    .eq('user_id', userId)
    .eq('story_slug', slug)
    .single();
  isUnlocked = !!data;
}

// Server-side liked state — avoids localStorage mismatch for logged-in users
let isLiked = false;
if (userId) {
  const { data: _tokenRow } = await supabase
    .from('user_tokens')
    .select('story_slug')
    .eq('user_id', userId)
    .eq('story_slug', slug)
    .maybeSingle();
  isLiked = !!_tokenRow;
}

// showAccessGate: not logged in AND story requires auth (restricted, top-secret, or paid)
const showAccessGate = !userId && (isRestricted || isTopSecret || isPaid);
// showPaywall: logged in but paid story not yet unlocked
const showPaywall = isPaid && !!userId && !isUnlocked;

// Adjacent stories for prev/next navigation
const allStories = await getCollection('stories', ({ data }) => data.published);
const sorted = allStories.sort((a, b) => {
  const aDate = a.data.uploadDate || a.data.date;
  const bDate = b.data.uploadDate || b.data.date;
  return bDate.localeCompare(aDate);
});
const currentIndex = sorted.findIndex(s => s.slug === slug);
const prevStory = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
const nextStory = currentIndex > 0 ? sorted[currentIndex - 1] : null;
// All stories data for client-side list navigation
const allStoriesData = sorted.map(s => ({ slug: s.slug, tags: s.data.tags, title: s.data.title }));
import curatedData from '../../data/curated-lists.json';
const _publishedSlugsSet = new Set(sorted.map(s => s.slug));
const curatedListsData = [
  { id: 'starter',  slugs: curatedData.starter.slugs.filter(s => s && _publishedSlugsSet.has(s)) },
  { id: 'thriller', slugs: curatedData.thriller.slugs.filter(s => s && _publishedSlugsSet.has(s)) },
  { id: 'ecology',  slugs: curatedData.ecology.slugs.filter(s => s && _publishedSlugsSet.has(s)) },
  { id: 'emotion',  slugs: curatedData.emotion.slugs.filter(s => s && _publishedSlugsSet.has(s)) },
];

// ─── Series navigation ───────────────────────────────────────
const seriesName = entry.data.series;
const seriesStories = seriesName
  ? allStories
      .filter(s => s.data.series === seriesName)
      .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0))
  : [];

// ─── Related stories (same tags, exclude self, up to 3) ──────
const tagSet = new Set(entry.data.tags);
const relatedStories = allStories
  .filter(s => s.slug !== slug && s.data.tags.some(t => tagSet.has(t)))
  .sort((a, b) => {
    const aMatch = a.data.tags.filter(t => tagSet.has(t)).length;
    const bMatch = b.data.tags.filter(t => tagSet.has(t)).length;
    return bMatch - aMatch || b.data.date.localeCompare(a.data.date);
  })
  .slice(0, 3);

const ogImageUrl = new URL(`/og/${slug}.png`, Astro.url).href;

const levelLabel: Record<string, string> = {
  'public': '公開', 'restricted': '限制', 'top-secret': '極密', 'paid': '付費',
};

const storyId = `story:${slug}`;

// ─── Edge caching for public stories ─────────────────────────
// Public stories render the same HTML for all users (comment form auth is
// handled client-side), so we can let Vercel's edge cache the response.
const isPublic = level === 'public';
if (isPublic) {
  Astro.response.headers.set(
    'Cache-Control',
    'public, s-maxage=3600, stale-while-revalidate=86400',
  );
}
---

<Layout
  title={`${entry.data.title} — 弦音異象`}
  description={entry.data.excerpt}
  ogImage={ogImageUrl}
  ogType="article"
  articleMeta={{ author: entry.data.author, tags: entry.data.tags }}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Article",
        "headline": entry.data.title,
        "description": entry.data.excerpt,
        "author": { "@type": "Person", "name": entry.data.author },
        "datePublished": entry.data.date,
        "image": { "@type": "ImageObject", "url": ogImageUrl, "width": 1200, "height": 630 },
        "url": Astro.url.origin + Astro.url.pathname,
        "publisher": {
          "@type": "Organization",
          "name": "弦音異象",
          "@id": `${Astro.url.origin}/#organization`,
          "url": Astro.url.origin
        },
        "keywords": entry.data.tags.join(', '),
        "inLanguage": "zh-TW",
        "isPartOf": { "@id": `${Astro.url.origin}/#website` }
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "弦音異象", "item": Astro.url.origin + "/" },
          { "@type": "ListItem", "position": 2, "name": "卷宗總覽", "item": Astro.url.origin + "/stories" },
          { "@type": "ListItem", "position": 3, "name": entry.data.title, "item": Astro.url.origin + Astro.url.pathname }
        ]
      }
    ]
  })} slot="head" />
  <!-- ─── Reader Header ─── -->
  <header id="rdrHeader">
    <button id="agBack" class="ctrl-btn back-btn" aria-label="返回" title="返回列表">
      <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 4L6 10l6 6"/>
      </svg>
    </button>
    <a href="/" class="rdr-logo">弦音<em>異象</em></a>
    <div class="rdr-ttl">{entry.data.title}</div>
    <ThemeSwitcher />
    <button id="widthToggle" class="ctrl-btn" title="切換滿版/窄版">
      ⊡<span class="ctrl-lbl" id="widthLbl">窄版</span>
    </button>
  </header>

  <!-- ─── Floating Help Button ─── -->
  <button id="helpBtn" class="help-fab" title="閱讀器使用說明" aria-label="閱讀器說明">?</button>

  <!-- ─── Reader Tutorial Overlay ─── -->
  <div id="readerTutorial" class="tutorial-overlay" role="dialog" aria-label="閱讀器使用說明">
    <div class="tut-backdrop"></div>
    <div class="tut-content">
      <!-- Top-left hints -->
      <div class="tut-hint tut-back">
        <div class="tut-arrow tut-arrow-tr">↖</div>
        <div class="tut-label">返回列表</div>
      </div>
      <div class="tut-hint tut-width">
        <div class="tut-label">滿版 / 窄版切換</div>
        <div class="tut-arrow">↗</div>
      </div>
      <div class="tut-hint tut-help-ref">
        <div class="tut-label">點此重看說明</div>
        <div class="tut-arrow tut-arrow-sm">↑</div>
      </div>
      <!-- Side hints -->
      <div class="tut-hint tut-prev">
        <div class="tut-arrow">←</div>
        <div class="tut-label">上一篇</div>
      </div>
      <div class="tut-hint tut-next">
        <div class="tut-label">下一篇</div>
        <div class="tut-arrow">→</div>
      </div>
      <!-- Bottom hints -->
      <div class="tut-hint tut-fontsz">
        <div class="tut-arrow tut-arrow-down">↘</div>
        <div class="tut-label">字體大小</div>
      </div>
      <div class="tut-hint tut-fonttype">
        <div class="tut-label">明/黑體切換</div>
        <div class="tut-arrow tut-arrow-down">↙</div>
      </div>
      <!-- Center dismiss -->
      <div class="tut-center">
        <div class="tut-title">閱讀器說明</div>
        <div class="tut-desc">在滿版模式下<br>往下滑→按鈕全隱藏<br>往上滑兩行→按鈕半透明出現</div>
        <button id="tutorialClose" class="tut-close-btn">[ 了解了，開始閱讀 ]</button>
      </div>
    </div>
  </div>

  <!-- ─── Reading Progress Bar ─── -->
  <div id="progress" aria-hidden="true"></div>

  <!-- ─── Article Body ─── -->
  <main style="padding-top: 56px; min-height: 100vh; background: var(--bg);">
    <div class="art-wrap" id="artWrap">

      <!-- Tags -->
      <div class="art-tags">
        {entry.data.tags.map(tag => (
          <span class="tag">{tag}</span>
        ))}
        <span class={`tag ${level === 'top-secret' || level === 'paid' ? 'w' : ''}`}>
          {levelLabel[level]}
        </span>
      </div>

      <!-- Title -->
      <h1>{entry.data.title}</h1>

      <!-- Series navigation banner -->
      {seriesStories.length > 1 && (
        <div class="series-nav-box">
          <div class="series-nav-label">▸ 系列：{seriesName}</div>
          <div class="series-nav-list">
            {seriesStories.map((s, i) => (
              <a
                href={`/stories/${s.slug}`}
                class={`series-nav-item${s.slug === slug ? ' current' : ''}`}
              >
                <span class="snav-order">{i + 1}</span>
                <span class="snav-title">{s.data.title}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Byline + action buttons -->
      <div class="art-byline">
        <div class="byl-item">案件編號 <em>{entry.data.fileNum}</em></div>
        <div class="byl-item">案發時間 <em>{entry.data.date}</em></div>
        <div class="byl-item">預估閱讀 <em>{entry.data.readTime}</em></div>
        <div class="byl-item">目擊次數 <em><span id="art-views">0</span></em></div>
        <div class="byl-item">累積金幣 <em><span id="art-tokens">0</span></em></div>
        <div class="byl-actions">
          <button class="byl-btn" id="bookmarkBtn2" title="書籤">☐ 書籤</button>
        </div>
      </div>

      <!-- Content (gated by auth level) -->
      {showAccessGate ? (
        <div class="art-body">
          <div class="access-gate">
            <div class="ag-badge">
              {isTopSecret ? '⚠ 極機密文件' : isPaid ? '⚠ 付費限定' : '⚠ 限制閱覽'}
            </div>
            {entry.data.excerpt && (
              <p class="ag-excerpt">{entry.data.excerpt}</p>
            )}
            <div class="ag-divider" />
            <div class="ag-msg">
              此卷宗需要 <strong>身份驗證</strong> 才能存取。<br />
              請登入或建立帳號以取得閱覽授權。
            </div>
            <div class="ag-actions">
              <a href={signInUrl} class="ag-btn ag-btn-primary">[ 登入 / 建立帳號 ]</a>
              <a href="/stories" class="ag-btn ag-btn-ghost">&lt; 返回卷宗列表</a>
            </div>
          </div>
        </div>
      ) : showPaywall ? (
        <div class="art-body">
          <PaymentGateway
            client:load
            storyTitle={entry.data.title}
            storySlug={slug}
            previewContent={entry.data.excerpt}
          />
        </div>
      ) : (
        <div class="art-body" id="artBody">
          <Content />
        </div>
      )}

      <!-- Share Row -->
      <div class="share-row">
        <button class="share-btn" id="shareBtn">↑ 分享</button>
        <button class="share-btn" id="copyBtn">⎘ 複製連結</button>
        <span id="copyFeedback" class="copy-feedback"></span>
      </div>

      <!-- Bottom Nav -->
      <nav class="art-nav" aria-label="文章導覽">
        <a id="navPrev"
           href={prevStory ? `/stories/${prevStory.slug}` : undefined}
           class="nav-pp nav-pp-prev"
           style={prevStory ? '' : 'opacity:.25;pointer-events:none'}>
          <span class="nav-arrow">←</span>
          <span class="nav-title" id="navPrevTitle">{prevStory?.data.title ?? ''}</span>
        </a>
        <div class="token-wrap">
          <button class="token-btn" id="tokenBtn" title="給顆金幣">
            <span id="tokenIcon">⎔</span>
            <span id="tokenCnt">0</span>
            <span class="token-label">給顆金幣</span>
          </button>
          <div class="token-anon-hint" id="tokenAnonHint" style="display:none">
            <a href="/sign-up" class="token-anon-link">加入弦音</a>才能給金幣
          </div>
        </div>
        <a id="navNext"
           href={nextStory ? `/stories/${nextStory.slug}` : undefined}
           class="nav-pp nav-pp-next"
           style={nextStory ? '' : 'opacity:.25;pointer-events:none'}>
          <span class="nav-title" id="navNextTitle">{nextStory?.data.title ?? ''}</span>
          <span class="nav-arrow">→</span>
        </a>
      </nav>

      <!-- Related Stories -->
      {relatedStories.length > 0 && (
        <div class="related-section">
          <div class="related-hd">相關卷宗</div>
          <div class="related-list">
            {relatedStories.map(s => (
              <a href={`/stories/${s.slug}`} class="related-item">
                <span class="rel-num">{s.data.fileNum}</span>
                <span class="rel-title">{s.data.title}</span>
                <span class="rel-tags">{s.data.tags.slice(0, 2).join(' · ')}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Comments -->
      <!--
        For public stories (edge-cached): both form and prompt are rendered;
        client-side auth check reveals the correct one.
        For SSR stories: server knows userId, so only one branch is rendered.
      -->
      <div class="comments-section" id="commentsSection" data-slug={slug} data-authed={userId ? '1' : '0'} data-public={isPublic ? '1' : '0'}>
        <div class="comments-hd">[ 目擊者留言 ]</div>
        <div id="commentsList" class="comments-list">
          <div class="comments-loading">載入中…</div>
        </div>
        {isPublic ? (
          <>
            {/* Public stories: render both; JS picks the visible one after auth check */}
            <form id="commentForm" class="comment-form" style="display:none">
              <input type="text" id="commentName" class="comment-input" placeholder="代號（選填，預設匿名觀測者）" maxlength="30" />
              <textarea id="commentContent" class="comment-textarea" placeholder="留下你的觀察紀錄… （上限 500 字）" maxlength="500" rows="3"></textarea>
              <div class="comment-actions">
                <span id="commentCharCount" class="comment-char">0 / 500</span>
                <button type="submit" id="commentSubmit" class="comment-submit">提交觀察報告</button>
              </div>
              <div id="commentMsg" class="comment-msg"></div>
            </form>
            <div id="commentLoginPrompt" class="comment-login-prompt">
              <a href={signInUrl} class="comment-login-btn">[ 登入後留言 ]</a>
            </div>
          </>
        ) : userId ? (
          <form id="commentForm" class="comment-form">
            <input type="text" id="commentName" class="comment-input" placeholder="代號（選填，預設匿名觀測者）" maxlength="30" />
            <textarea id="commentContent" class="comment-textarea" placeholder="留下你的觀察紀錄… （上限 500 字）" maxlength="500" rows="3"></textarea>
            <div class="comment-actions">
              <span id="commentCharCount" class="comment-char">0 / 500</span>
              <button type="submit" id="commentSubmit" class="comment-submit">提交觀察報告</button>
            </div>
            <div id="commentMsg" class="comment-msg"></div>
          </form>
        ) : (
          <div id="commentLoginPrompt" class="comment-login-prompt">
            <a href={signInUrl} class="comment-login-btn">[ 登入後留言 ]</a>
          </div>
        )}
      </div>

    </div>
  </main>

  <footer>
    <div class="ft-logo">弦音<em>異象</em></div>
    <div class="ft-txt">ANOMALY ARCHIVES · CLASSIFIED<br>一切皆為虛構，除非你相信。</div>
  </footer>

  <!-- ─── Font Size FAB (bottom right) ─── -->
  <div class="font-sz-fab" id="fontSzFab">
    <div class="fsz-pill">
      <button class="fsz-btn big" id="fontUp">+A</button>
      <div class="fsz-lbl" id="fontLabel">1.0×</div>
      <button class="fsz-btn sml" id="fontDown">-A</button>
    </div>
  </div>

  <!-- ─── Font Type FAB (bottom left) ─── -->
  <div class="font-type-fab" id="fontTypeFab">
    <div class="ft-pill">
      <button class="ft-opt on" id="ftSerif">
        <span class="ft-opt-serif">明</span>
      </button>
      <button class="ft-opt" id="ftSans">
        <span class="ft-opt-sans">黑</span>
      </button>
    </div>
  </div>

  <!-- ─── Side Nav Buttons ─── -->
  <a class="side-nav side-nav-prev" id="btnPrev"
     href={prevStory ? `/stories/${prevStory.slug}` : undefined}
     style={prevStory ? '' : 'opacity:0;pointer-events:none'}
     aria-label="上一卷宗">‹</a>
  <a class="side-nav side-nav-next" id="btnNext"
     href={nextStory ? `/stories/${nextStory.slug}` : undefined}
     style={nextStory ? '' : 'opacity:0;pointer-events:none'}
     aria-label="下一卷宗">›</a>
  <!-- Nav data for client-side list navigation (not a script — browser ignores non-JS types) -->
  <div id="hz-nav-data" style="display:none" data-d={JSON.stringify({ all: allStoriesData, curated: curatedListsData, slug })}></div>
</Layout>

<script define:vars={{ storyId, currentSlug: slug, storyTitle: entry.data.title, serverIsLiked: isLiked, isLoggedIn: !!userId }} nonce={Astro.locals.nonce || undefined}>
  // ─── Back button ──
  var _agBack = document.getElementById('agBack');
  if (_agBack) {
    _agBack.onclick = function() {
      var params = new URLSearchParams(location.search);
      var ref = params.get('ref') || '';
      var listParam = params.get('list') || 'all';
      if (ref === 'home')   { window.location.href = '/';       return; }
      if (ref === 'member') { window.location.href = '/member'; return; }
      if (ref === 'tags')   { window.location.href = '/tags';   return; }
      if (listParam.startsWith('cat:')) {
        window.location.href = '/stories?cat=' + encodeURIComponent(listParam.slice(4));
        return;
      }
      if (listParam.startsWith('curated:')) {
        window.location.href = '/stories?curated=' + encodeURIComponent(listParam.slice(8));
        return;
      }
      window.location.href = '/stories';
    };
  }
</script>

<!-- Reader controls — bundled script (wide mode, tutorial, font) so they survive ViewTransitions + CSP 'self' -->
<script>
  var _rcCtrl = null;
  function _initReaderControls() {
    if (_rcCtrl) _rcCtrl.abort();
    _rcCtrl = typeof AbortController !== 'undefined' ? new AbortController() : null;
    var sig = _rcCtrl ? _rcCtrl.signal : undefined;
    var sigOpts = sig ? { signal: sig } : {};

    function sGet(k) { try { return localStorage.getItem(k); } catch(e) { return null; } }
    function sSet(k, v) { try { localStorage.setItem(k, v); } catch(e) {} }

    // ─── Wide / Narrow toggle ─────────────────────────────────
    var wide = sGet('hz-wide') === '1';
    var wideLastY = window.scrollY;
    var wideUpAccum = 0;
    var WIDE_SHOW_PX = 48;

    function setWideUiState(state) {
      document.body.classList.toggle('ui-fade-out', state === 'out');
      document.body.classList.toggle('ui-fade-in', state === 'in');
    }

    function applyWide() {
      var artWrap = document.getElementById('artWrap');
      var widthBtn = document.getElementById('widthToggle');
      var widthLbl = document.getElementById('widthLbl');
      if (artWrap) artWrap.classList.toggle('wide', wide);
      document.body.classList.toggle('wide', wide);
      if (widthLbl) widthLbl.textContent = wide ? '滿版' : '窄版';
      if (widthBtn) {
        widthBtn.firstChild.nodeValue = wide ? '⊞' : '⊡';
        widthBtn.classList.toggle('on', wide);
      }
      if (!wide) {
        setWideUiState('');
      } else {
        wideLastY = window.scrollY;
        wideUpAccum = 0;
        setWideUiState('in');
      }
    }
    applyWide();

    var widthBtn = document.getElementById('widthToggle');
    if (widthBtn) widthBtn.addEventListener('click', function() {
      wide = !wide;
      sSet('hz-wide', wide ? '1' : '0');
      applyWide();
    }, sigOpts);

    window.addEventListener('scroll', function() {
      if (!wide) return;
      var cy = window.scrollY;
      var diff = cy - wideLastY;
      if (diff > 2) { wideUpAccum = 0; setWideUiState('out'); }
      else if (diff < -2) { wideUpAccum += Math.abs(diff); if (wideUpAccum >= WIDE_SHOW_PX) setWideUiState('in'); }
      wideLastY = cy;
    }, sig ? { passive: true, signal: sig } : { passive: true });

    // ─── Reader Tutorial ──────────────────────────────────────
    var tutorialKey = 'hz-reader-tutorial-seen';
    var tutEl = document.getElementById('readerTutorial');

    function showTutorial() { if (tutEl) tutEl.style.display = 'block'; }
    function hideTutorial() { if (tutEl) tutEl.style.display = 'none'; sSet(tutorialKey, '1'); }

    var tutClose = document.getElementById('tutorialClose');
    var helpBtn = document.getElementById('helpBtn');
    if (tutClose) tutClose.addEventListener('click', hideTutorial, sigOpts);
    if (tutEl) tutEl.addEventListener('click', function(e) {
      if (e.target === tutEl || (e.target && e.target.classList && e.target.classList.contains('tut-backdrop'))) hideTutorial();
    }, sigOpts);
    if (helpBtn) helpBtn.addEventListener('click', showTutorial, sigOpts);
    if (!sGet(tutorialKey)) setTimeout(showTutorial, 600);

    // ─── Font size ────────────────────────────────────────────
    var fontSz = parseFloat(sGet('hz-font-sz') || '1.0');
    var fontType = sGet('hz-font-type') || 'serif';

    function applyFont() {
      var body = document.getElementById('artBody');
      if (!body) return;
      body.style.fontSize = fontSz + 'rem';
      body.style.fontFamily = fontType === 'serif' ? "'Noto Serif TC', serif" : "'Noto Sans TC', sans-serif";
      var lh = (fontSz >= 1.0 ? Math.max(2.0, 2.18 - (fontSz - 1.0) * 0.356) : 2.18).toFixed(2);
      body.style.lineHeight = lh;
      var lbl = document.getElementById('fontLabel');
      if (lbl) lbl.textContent = fontSz.toFixed(1) + '×';
    }

    function setFontType(type) {
      fontType = type;
      sSet('hz-font-type', type);
      applyFont();
      var s = document.getElementById('ftSerif');
      var n = document.getElementById('ftSans');
      if (s) s.classList.toggle('on', type === 'serif');
      if (n) n.classList.toggle('on', type === 'sans');
    }
    setFontType(fontType);

    var fontUp = document.getElementById('fontUp');
    var fontDown = document.getElementById('fontDown');
    var fontLabel = document.getElementById('fontLabel');
    var ftSerif = document.getElementById('ftSerif');
    var ftSans = document.getElementById('ftSans');
    if (fontUp) fontUp.addEventListener('click', function() { fontSz = Math.min(1.45, +(fontSz + 0.1).toFixed(1)); sSet('hz-font-sz', String(fontSz)); applyFont(); }, sigOpts);
    if (fontDown) fontDown.addEventListener('click', function() { fontSz = Math.max(0.78, +(fontSz - 0.1).toFixed(1)); sSet('hz-font-sz', String(fontSz)); applyFont(); }, sigOpts);
    if (fontLabel) fontLabel.addEventListener('click', function() { fontSz = 1.0; sSet('hz-font-sz', '1.0'); applyFont(); }, sigOpts);
    if (ftSerif) ftSerif.addEventListener('click', function() { setFontType('serif'); }, sigOpts);
    if (ftSans) ftSans.addEventListener('click', function() { setFontType('sans'); }, sigOpts);
  }
  document.addEventListener('astro:page-load', _initReaderControls);
  _initReaderControls();
</script>

<!-- Prev/next nav — bundled script, reads data from #hz-nav-data div (works via ViewTransitions + CSP 'self') -->
<script>
  function _resolveNavPool(listParam, all, curated) {
    if (!listParam || listParam === 'all') return all;
    if (listParam.startsWith('cat:')) {
      var tag = listParam.slice(4);
      var f = all.filter(function(s) { return s.tags.includes(tag); });
      return f.length > 0 ? f : all;
    }
    if (listParam.startsWith('curated:')) {
      var id = listParam.slice(8);
      var cl = curated.find(function(l) { return l.id === id; });
      if (cl) {
        var p = cl.slugs.map(function(sl) { return all.find(function(s) { return s.slug === sl; }); }).filter(Boolean);
        if (p.length > 0) return p;
      }
      return all;
    }
    if (listParam.startsWith('user:')) {
      var uid = listParam.slice(5);
      try {
        var saved = sessionStorage.getItem('hz-nav-ctx-' + uid);
        if (saved) {
          var slugs = JSON.parse(saved);
          var p2 = slugs.map(function(sl) { return all.find(function(s) { return s.slug === sl; }); }).filter(Boolean);
          if (p2.length > 0) return p2;
        }
      } catch(_) {}
    }
    return all;
  }

  function _initNavLinks() {
    var el = document.getElementById('hz-nav-data');
    if (!el) return;
    var navData; try { navData = JSON.parse(el.getAttribute('data-d') || '{}'); } catch(_) { return; }
    var all = navData.all || [];
    var curated = navData.curated || [];
    var currentSlug = navData.slug || '';

    var params = new URLSearchParams(location.search);
    var listParam = params.get('list') || 'all';
    var ref = params.get('ref') || '';
    var pool = _resolveNavPool(listParam, all, curated);
    var idx = pool.findIndex(function(s) { return s.slug === currentSlug; });
    if (idx === -1) { pool = all; listParam = 'all'; idx = pool.findIndex(function(s) { return s.slug === currentSlug; }); }

    var suffix = '?list=' + encodeURIComponent(listParam);
    if (ref) suffix += '&ref=' + encodeURIComponent(ref);
    var prevSlug = idx < pool.length - 1 ? pool[idx + 1].slug : null;
    var nextSlug = idx > 0 ? pool[idx - 1].slug : null;

    function title(sl) { var s = all.find(function(x) { return x.slug === sl; }); return s ? s.title : ''; }

    var btnPrev = document.getElementById('btnPrev');
    var btnNext = document.getElementById('btnNext');
    if (btnPrev) {
      if (prevSlug) { btnPrev.setAttribute('href', '/stories/' + prevSlug + suffix); btnPrev.style.opacity = ''; btnPrev.style.pointerEvents = ''; }
      else { btnPrev.removeAttribute('href'); btnPrev.style.opacity = '0'; btnPrev.style.pointerEvents = 'none'; }
    }
    if (btnNext) {
      if (nextSlug) { btnNext.setAttribute('href', '/stories/' + nextSlug + suffix); btnNext.style.opacity = ''; btnNext.style.pointerEvents = ''; }
      else { btnNext.removeAttribute('href'); btnNext.style.opacity = '0'; btnNext.style.pointerEvents = 'none'; }
    }
    var navPrev = document.getElementById('navPrev');
    var navNext = document.getElementById('navNext');
    var navPrevTitle = document.getElementById('navPrevTitle');
    var navNextTitle = document.getElementById('navNextTitle');
    if (navPrev) {
      if (prevSlug) { navPrev.setAttribute('href', '/stories/' + prevSlug + suffix); navPrev.style.opacity = ''; navPrev.style.pointerEvents = ''; if (navPrevTitle) navPrevTitle.textContent = title(prevSlug); }
      else { navPrev.removeAttribute('href'); navPrev.style.opacity = '0.25'; navPrev.style.pointerEvents = 'none'; if (navPrevTitle) navPrevTitle.textContent = ''; }
    }
    if (navNext) {
      if (nextSlug) { navNext.setAttribute('href', '/stories/' + nextSlug + suffix); navNext.style.opacity = ''; navNext.style.pointerEvents = ''; if (navNextTitle) navNextTitle.textContent = title(nextSlug); }
      else { navNext.removeAttribute('href'); navNext.style.opacity = '0.25'; navNext.style.pointerEvents = 'none'; if (navNextTitle) navNextTitle.textContent = ''; }
    }
  }
  document.addEventListener('astro:page-load', _initNavLinks);
  _initNavLinks();
</script>

<script define:vars={{ storyId, currentSlug: slug, storyTitle: entry.data.title, isSignedIn: userId !== null }} nonce={Astro.locals.nonce || undefined}>
  // ─── ViewTransitions cleanup ──────────────────────────────
  // define:vars scripts re-run on every page swap — clean up window listeners
  var _pageCtrl = (typeof AbortController !== 'undefined') ? new AbortController() : null;
  var _pageSig = _pageCtrl ? _pageCtrl.signal : undefined;
  document.addEventListener('astro:before-swap', function() {
    if (_pageCtrl) _pageCtrl.abort();
  }, { once: true });

  function fmtN(n) { return n >= 1000 ? (n / 1000).toFixed(1) + 'K' : String(n); }

  // ─── Supabase stats ───────────────────────────────────────
  // liked state stays in localStorage (per-device fallback for non-login users)
  function sGet(k) { try { return localStorage.getItem(k); } catch(e) { return null; } }
  function sSet(k, v) { try { localStorage.setItem(k, v); } catch(e) {} }

  // Use server-authoritative liked state for logged-in users; localStorage for anonymous
  let liked = isLoggedIn ? serverIsLiked : (sGet('hz-liked:' + currentSlug) === '1');
  // Keep localStorage in sync
  sSet('hz-liked:' + currentSlug, liked ? '1' : '0');
  let globalTokens = 0;

  // Track last visited story and list context for homepage smart resume
  sSet('hz-last-story', currentSlug);
  const _lp = new URLSearchParams(location.search);
  sSet('hz-last-list', _lp.get('list') || 'all');

  // Fetch current stats from Supabase
  fetch('/api/stats/' + currentSlug)
    .then(r => r.json())
    .then(data => {
      globalTokens = data.tokens ?? 0;
      const viewsEl = document.getElementById('art-views');
      const artTokens = document.getElementById('art-tokens');
      const cnt = document.getElementById('tokenCnt');
      if (viewsEl) viewsEl.textContent = fmtN(data.views ?? 0);
      if (artTokens) artTokens.textContent = fmtN(globalTokens);
      if (cnt) cnt.textContent = fmtN(globalTokens);
    })
    .catch(() => {});

  // Increment view count — skip if already counted this session
  const _viewKey = 'viewed:' + currentSlug;
  if (!sessionStorage.getItem(_viewKey)) {
    sessionStorage.setItem(_viewKey, '1');
    fetch('/api/stats/view', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug: currentSlug }),
    }).catch(() => {});
  }

  // ─── Token / Coin button ──────────────────────────────────
  function updateTokenUI() {
    const btn = document.getElementById('tokenBtn');
    const icon = document.getElementById('tokenIcon');
    const cnt = document.getElementById('tokenCnt');
    const label = btn?.querySelector('.token-label');
    const artTokens = document.getElementById('art-tokens');
    if (icon) icon.textContent = liked ? '◈' : '⎔';
    if (cnt) cnt.textContent = fmtN(globalTokens);
    if (label) label.textContent = liked ? '收回金幣' : '給顆金幣';
    if (artTokens) artTokens.textContent = fmtN(globalTokens);
    btn?.classList.toggle('on', liked);
  }
  updateTokenUI();

  // Show sign-in hint for non-members; hide when signed in
  const tokenAnonHint = document.getElementById('tokenAnonHint');
  if (tokenAnonHint) tokenAnonHint.style.display = isSignedIn ? 'none' : 'block';

  document.getElementById('tokenBtn')?.addEventListener('click', () => {
    // Non-members: flash the sign-in hint and bail out
    if (!isSignedIn) {
      if (tokenAnonHint) {
        tokenAnonHint.style.animation = 'none';
        tokenAnonHint.offsetHeight; // reflow
        tokenAnonHint.style.animation = 'tokenHintPulse 0.4s ease';
      }
      return;
    }

    const action = liked ? 'remove' : 'add';
    const prevLiked = liked;
    const prevTokens = globalTokens;
    liked = !liked;
    globalTokens = Math.max(0, globalTokens + (liked ? 1 : -1));
    sSet('hz-liked:' + currentSlug, liked ? '1' : '0');
    updateTokenUI();

    fetch('/api/stats/token', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug: currentSlug, action }),
    })
      .then(r => {
        // 401 = auth required; rollback optimistic update
        if (r.status === 401) {
          liked = prevLiked;
          globalTokens = prevTokens;
          sSet('hz-liked:' + currentSlug, liked ? '1' : '0');
          updateTokenUI();
          const btn = document.getElementById('tokenBtn');
          const lbl = btn?.querySelector('.token-label');
          if (lbl) {
            const orig = lbl.textContent;
            lbl.textContent = '請先登入';
            setTimeout(() => { lbl.textContent = orig; }, 2000);
          }
          return null;
        }
        return r.json();
      })
      .then(data => {
        if (data && data.tokens !== undefined) {
          globalTokens = data.tokens;
          updateTokenUI();
        }
      })
      .catch(() => {}); // keep optimistic update on network error
  });

  // ─── Reading progress bar + save ──────────────────────────
  let progressSaveTimer = null;
  let lastSavedPct = parseInt(sGet('hz-progress:' + currentSlug) || '0', 10);

  // Retroactively mark as read for users who already reached 90% before this feature
  if (lastSavedPct >= 90 && sGet('hz-read:' + currentSlug) !== '1') {
    sSet('hz-read:' + currentSlug, '1');
  }

  function saveProgress(pct) {
    sSet('hz-progress:' + currentSlug, String(pct));
    // Fire-and-forget for logged-in users; 401 for anonymous is silently ignored
    fetch('/api/progress', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug: currentSlug, pct }),
    }).catch(() => {});
  }

  window.addEventListener('scroll', () => {
    // Progress tracking only (wide-mode UI fade is handled in the bundled reader-controls script)
    const docH = document.documentElement.scrollHeight - window.innerHeight;
    const pct = docH > 0 ? Math.round(window.scrollY / docH * 100) : 0;

    // Mark as read when reaching 90% — localStorage flag + DB record for members
    if (pct >= 90 && sGet('hz-read:' + currentSlug) !== '1') {
      sSet('hz-read:' + currentSlug, '1');
      // Persist to DB for logged-in users (member stats readSlugs)
      fetch('/api/progress', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug: currentSlug, pct: 100 }),
      }).catch(() => {});
    }

    if (Math.abs(pct - lastSavedPct) >= 5) {
      clearTimeout(progressSaveTimer);
      progressSaveTimer = setTimeout(() => { saveProgress(pct); lastSavedPct = pct; }, 5000);
    }
  }, { passive: true, signal: _pageSig });

  // ─── Bookmark ──────────────────────────────────────────────
  let bookmarked = sGet('hz-bookmark:' + currentSlug) === '1';

  function updateBookmarkUI() {
    const btn2 = document.getElementById('bookmarkBtn2');
    if (btn2) { btn2.textContent = bookmarked ? '☑ 已書籤' : '☐ 書籤'; btn2.classList.toggle('on', bookmarked); }
  }
  updateBookmarkUI();

  function toggleBookmark() {
    bookmarked = !bookmarked;
    sSet('hz-bookmark:' + currentSlug, bookmarked ? '1' : '0');
    updateBookmarkUI();
    fetch('/api/bookmark', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug: currentSlug, action: bookmarked ? 'add' : 'remove' }),
    }).catch(() => {});
  }
  document.getElementById('bookmarkBtn2')?.addEventListener('click', toggleBookmark);

  // ─── Share ─────────────────────────────────────────────────
  function copyLink(feedbackId = 'copyFeedback') {
    navigator.clipboard?.writeText(location.href).then(() => {
      const fb = document.getElementById(feedbackId);
      if (fb) { fb.textContent = '已複製！'; setTimeout(() => { fb.textContent = ''; }, 2000); }
    }).catch(() => {});
  }

  async function doShare() {
    if (navigator.share) {
      try { await navigator.share({ title: storyTitle, text: storyTitle, url: location.href }); return; }
      catch (_) {}
    }
    copyLink('copyFeedback');
  }

  document.getElementById('shareBtn')?.addEventListener('click', doShare);
  document.getElementById('copyBtn')?.addEventListener('click', () => copyLink('copyFeedback'));

  // ─── Comments ─────────────────────────────────────────────
  (function() {
    var section = document.getElementById('commentsSection');
    if (!section) return;
    var slug = section.dataset.slug;
    var isPublicStory = section.dataset.public === '1';
    var list = document.getElementById('commentsList');

    // ── Pagination state ──
    var currentPage = 1;
    var hasMore = false;
    var loadMoreBtn = null;

    function fmtDate(iso) {
      var d = new Date(iso);
      return d.getFullYear() + '.' +
        String(d.getMonth() + 1).padStart(2, '0') + '.' +
        String(d.getDate()).padStart(2, '0');
    }

    function escHtml(s) {
      return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    function buildCommentEl(c) {
      return '<div class="comment-item">' +
        '<div class="comment-meta"><span class="comment-name">' + escHtml(c.display_name) + '</span>' +
        '<span class="comment-date">' + fmtDate(c.created_at) + '</span></div>' +
        '<div class="comment-body">' + escHtml(c.content) + '</div>' +
        '</div>';
    }

    function setLoadMoreBtn(show) {
      if (!list) return;
      if (loadMoreBtn) loadMoreBtn.remove();
      loadMoreBtn = null;
      if (!show) return;
      loadMoreBtn = document.createElement('button');
      loadMoreBtn.className = 'comment-load-more';
      loadMoreBtn.textContent = '載入更多留言';
      loadMoreBtn.addEventListener('click', function() { loadPage(currentPage + 1, true); });
      list.after(loadMoreBtn);
    }

    function renderComments(comments, append) {
      if (!list) return;
      if (!append) {
        if (!comments.length) {
          list.innerHTML = '<div class="comment-empty">尚無觀測紀錄。成為第一位目擊者。</div>';
          return;
        }
        list.innerHTML = comments.map(buildCommentEl).join('');
      } else {
        var frag = document.createDocumentFragment();
        comments.forEach(function(c) {
          var el = document.createElement('div');
          el.innerHTML = buildCommentEl(c);
          frag.appendChild(el.firstChild);
        });
        list.appendChild(frag);
      }
    }

    var commentsLoaded = false;
    function loadPage(page, append) {
      if (loadMoreBtn) loadMoreBtn.disabled = true;
      fetch('/api/comments?slug=' + slug + '&page=' + page)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var comments = Array.isArray(data.comments) ? data.comments : [];
          hasMore = !!data.hasMore;
          currentPage = data.page || page;
          renderComments(comments, !!append);
          setLoadMoreBtn(hasMore);
        })
        .catch(function() {
          if (!append && list) list.innerHTML = '';
          setLoadMoreBtn(false);
        });
    }

    function loadComments() {
      if (commentsLoaded) return;
      commentsLoaded = true;
      loadPage(1, false);
    }

    if ('IntersectionObserver' in window) {
      var obs = new IntersectionObserver(function(entries) {
        if (entries[0].isIntersecting) { loadComments(); obs.disconnect(); }
      }, { rootMargin: '200px' });
      obs.observe(section);
    } else {
      loadComments();
    }

    // ── Client-side auth check for public (edge-cached) stories ──
    // Use window.Clerk.user directly instead of an API call — faster, no
    // dependency on server-side JWT validity, same polling pattern as index.astro.
    if (isPublicStory) {
      var _authChecks = 0;
      function _checkClerkUser() {
        var c = window.Clerk;
        if (c && c.loaded && c.user !== undefined) {
          if (c.user) {
            var f = document.getElementById('commentForm');
            var p = document.getElementById('commentLoginPrompt');
            if (f) f.style.display = '';
            if (p) p.style.display = 'none';
            section.dataset.authed = '1';
          }
          return;
        }
        if (++_authChecks < 40) setTimeout(_checkClerkUser, 100);
      }
      _checkClerkUser();
    }

    var form = document.getElementById('commentForm');
    var textarea = document.getElementById('commentContent');
    var charCount = document.getElementById('commentCharCount');
    var msg = document.getElementById('commentMsg');

    textarea?.addEventListener('input', function() {
      var len = textarea.value.length;
      if (charCount) charCount.textContent = len + ' / 500';
    });

    form?.addEventListener('submit', function(e) {
      e.preventDefault();
      var content = textarea?.value.trim() ?? '';
      if (!content) return;
      var nameEl = document.getElementById('commentName');
      var displayName = nameEl?.value.trim() || '';
      var submitBtn = document.getElementById('commentSubmit');
      if (submitBtn) submitBtn.disabled = true;

      fetch('/api/comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug: slug, content: content, displayName: displayName }),
      })
        .then(function(r) { return r.ok ? r.json() : Promise.reject(r.status); })
        .then(function(comment) {
          if (textarea) textarea.value = '';
          if (charCount) charCount.textContent = '0 / 500';
          if (nameEl) nameEl.value = '';
          if (msg) { msg.textContent = '觀察報告已提交。'; msg.className = 'comment-msg ok'; }
          var empty = list?.querySelector('.comment-empty');
          if (empty) empty.remove();
          var el = document.createElement('div');
          el.className = 'comment-item new';
          el.innerHTML = '<div class="comment-meta"><span class="comment-name">' +
            escHtml(comment.display_name) + '</span><span class="comment-date">剛剛</span></div>' +
            '<div class="comment-body">' + escHtml(comment.content) + '</div>';
          list?.prepend(el);
          setTimeout(function() { el.classList.remove('new'); }, 1500);
          setTimeout(function() { if (msg) msg.textContent = ''; }, 3000);
        })
        .catch(function(err) {
          if (msg) { msg.textContent = err === 401 ? '請先登入再留言。' : '提交失敗，請稍後再試。'; msg.className = 'comment-msg err'; }
        })
        .finally(function() { if (submitBtn) submitBtn.disabled = false; });
    });
  })();

</script>

