    padding: 4px 10px;
    cursor: pointer;
    transition: all .2s;
    white-space: nowrap;
  }
  .byl-btn:hover, .byl-btn.on { border-color: var(--accent); color: var(--accent); }
  .copy-feedback2 {
    font-family: 'Share Tech Mono', monospace;
    font-size: .65rem;
    color: var(--accent);
  }

  .art-body {
    font-family: 'Noto Serif TC', serif;
    font-size: 1rem;
    line-height: 2.08;
    color: var(--text-dim);
    transition: font-size .2s, line-height .2s;
  }
  .art-body :global(p)          { margin-bottom: 1.5rem; }
  .art-body :global(h2)         { font-size: 1.2rem; font-weight: 900; color: var(--text); border-left: 3px solid var(--accent); padding-left: 12px; margin: 2.5rem 0 1rem; }
  .art-body :global(h3)         { font-size: 1rem; font-weight: 700; color: var(--text); margin: 2rem 0 .75rem; }
  .art-body :global(blockquote) { border-left: 2px solid var(--accent); padding: 12px 16px; background: var(--accent-dim); margin: 1.5rem 0; }
  .art-body :global(blockquote p) { margin: 0; color: var(--text); font-style: italic; }
  .art-body :global(hr)         { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }
  .art-body :global(strong)     { color: var(--text); font-weight: 700; text-decoration: underline; text-decoration-color: var(--accent); text-underline-offset: 3px; }
  .art-body :global(em)         { color: var(--warm); font-style: italic; }
  .art-body :global(a)          { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  .art-body :global(img)        {
    display: block;
    width: 100%;
    max-width: 700px;
    margin: 2rem auto;
    border: 1px solid var(--border);
    filter: saturate(0.85) brightness(0.9);
    opacity: 0.92;
  }
  .art-body :global(img:hover)  { opacity: 1; filter: saturate(1) brightness(1); transition: all 0.3s; }
  .art-body :global(figure)     { margin: 2.5rem 0; }
  .art-body :global(figcaption) {
    font-family: 'Share Tech Mono', monospace;
    font-size: .62rem;
    color: var(--text-muted);
    text-align: center;
    letter-spacing: .08em;
    margin-top: .5rem;
  }

  /* ─── Footer ─────────────────────────────────────────────── */
  footer { text-align: center; padding: 48px 24px; border-top: 1px solid var(--border); }
  .ft-logo { font-family: 'Noto Serif TC', serif; font-size: 1.2rem; font-weight: 900; color: var(--text); letter-spacing: .1em; margin-bottom: 10px; }
  .ft-logo em { color: var(--accent); font-style: normal; }
  .ft-txt { font-family: 'Share Tech Mono', monospace; font-size: .65rem; color: var(--text-muted); letter-spacing: .1em; line-height: 1.8; }

  /* ─── Font FAB ──────────────────────────────────────────── */
  .font-sz-fab {
    position: fixed;
    bottom: 80px;
    right: 16px;
    z-index: 560;
    opacity: 0.5;
    transition: opacity 0.3s;
  }
  .font-sz-fab:hover { opacity: 1; }

  .fsz-pill {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: var(--surface);
    border: 1px solid var(--border);
    box-shadow: 0 4px 15px rgba(0,0,0,.6);
  }
  .fsz-btn {
    width: 40px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--text-dim);
    cursor: pointer;
    font-family: 'Share Tech Mono', monospace;
    touch-action: manipulation; /* prevent double-tap zoom */
  }
  .fsz-btn.big { font-size: .9rem; font-weight: 700; }
  .fsz-btn.sml { font-size: .7rem; }
  .fsz-btn:hover { color: var(--text); background: var(--bg2); }

  .fsz-lbl {
    font-family: 'Share Tech Mono', monospace;
    font-size: .6rem;
    color: var(--text-muted);
    padding: 6px 0;
    cursor: pointer;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    width: 100%;
    text-align: center;
    letter-spacing: .1em;
  }

  /* ─── Font Type FAB ─────────────────────────────────────── */
  .font-type-fab {
    position: fixed;
    bottom: 80px;
    left: 16px;
    z-index: 560;
    opacity: 0.5;
    transition: opacity 0.3s;
  }
  .font-type-fab:hover { opacity: 1; }

  .ft-pill {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    box-shadow: 0 4px 15px rgba(0,0,0,.6);
  }
  .ft-opt {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px 14px;
    background: none;
    border: none;
    cursor: pointer;
    font-size: .8rem;
    color: var(--text-dim);
    transition: all .2s;
    touch-action: manipulation; /* prevent double-tap zoom */
  }
  .ft-opt + .ft-opt { border-top: 1px solid var(--border); }
  .ft-opt:hover, .ft-opt.on { color: var(--text); background: var(--bg2); }
  .ft-opt-serif { font-family: 'Noto Serif TC', serif; font-weight: 900; }
  .ft-opt-sans  { font-family: 'Noto Sans TC', sans-serif; font-weight: 700; }

  /* ─── Share Row ──────────────────────────────────────────── */
  .share-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 48px;
    padding-top: 20px;
    border-top: 1px dashed var(--border);
    flex-wrap: wrap;
  }
  .share-btn {
    background: none;
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-family: 'Share Tech Mono', monospace;
    font-size: .7rem;
    letter-spacing: .1em;
    padding: 7px 14px;
    cursor: pointer;
    transition: all .2s;
  }
  .share-btn:hover { border-color: var(--text); color: var(--text); }
  .copy-feedback {
    font-family: 'Share Tech Mono', monospace;
    font-size: .65rem;
    color: var(--accent);
    letter-spacing: .1em;
  }

  /* ─── Art Nav (bottom) ───────────────────────────────────── */
  .art-nav {
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    gap: 12px;
    margin-top: 60px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }
  .nav-pp {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Share Tech Mono', monospace;
    font-size: .7rem;
    letter-spacing: .06em;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-dim);
    padding: 12px 16px;
    cursor: pointer;
    transition: all .2s;
    text-decoration: none;
    flex: 1;
    min-width: 0;
  }
  .nav-pp-prev { justify-content: flex-start; }
  .nav-pp-next { justify-content: flex-end; }
  .nav-arrow { flex-shrink: 0; font-size: .85rem; }
  .nav-title {
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }
  .nav-pp:hover {
    border-color: var(--text);
    color: var(--bg);
    background: var(--text);
  }

  /* ─── Side Nav Buttons ───────────────────────────────────── */
  .side-nav {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 240px;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-size: 1.1rem;
    line-height: 1;
    text-decoration: none;
    transition: background .2s, color .2s, border-color .2s, opacity .3s;
    user-select: none;
  }
  .side-nav-prev {
    left: 0;
    border-left: none;
    border-radius: 0 3px 3px 0;
  }
  .side-nav-next {
    right: 0;
    border-right: none;
    border-radius: 3px 0 0 3px;
  }
  .side-nav:hover {
    background: var(--text);
    color: var(--bg);
    border-color: var(--text);
  }
  :global(body.wide) .side-nav {
    opacity: 0;
  }
  .token-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: 1px solid var(--accent);
    padding: 10px 20px;
    cursor: pointer;
    font-family: 'Share Tech Mono', monospace;
    font-size: .75rem;
    color: var(--accent);
    transition: all .2s;
    letter-spacing: .1em;
    flex: 0 0 auto;
  }
  .token-label { font-size: .65rem; letter-spacing: .08em; }
  .token-btn.on { background: var(--accent); color: var(--bg); }
  .token-btn:hover { background: var(--accent); color: var(--bg); }
  .token-wrap { display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .token-anon-hint {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.6rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  .token-anon-link { color: var(--accent); text-decoration: underline; }
  @keyframes tokenHintPulse {
    0%   { color: var(--text-muted); }
    50%  { color: var(--accent); }
    100% { color: var(--text-muted); }
  }


/* ─── Reader layout adjustments ────────────────────────── */
  .art-wrap {
    max-width: 680px;
    margin: 0 auto;
    padding: 50px 32px 100px;
    background: var(--bg);
    min-height: 100%;
    transition: max-width .25s ease, padding .25s ease;
  }
  .art-wrap.wide {
    max-width: 100%;
    padding-left: 5px;
    padding-right: 5px;
  }

  @media (max-width: 680px) {
    .art-wrap { padding: 32px 28px 100px; }
    .token-btn { padding: 8px 12px; font-size: .65rem; }
    .font-sz-fab { bottom: 72px; }
    .font-type-fab { bottom: 72px; }
    .ctrl-btn { padding: 6px 8px; }
  }

  /* ─── Wide mode UI transparency (FABs + side-nav only, header stays visible) ── */
  :global(body.wide) .font-sz-fab,
  :global(body.wide) .font-type-fab {
    transition: opacity 0.4s ease;
  }
  :global(body.wide.ui-fade-out) .font-sz-fab,
  :global(body.wide.ui-fade-out) .font-type-fab {
    opacity: 0;
    pointer-events: none;
  }
  :global(body.wide.ui-fade-in) .font-sz-fab,
  :global(body.wide.ui-fade-in) .font-type-fab { opacity: 0.55; }
  :global(body.wide.ui-fade-in) .side-nav { opacity: 0.4; }
  :global(body.wide) .font-sz-fab:hover,
  :global(body.wide) .font-type-fab:hover { opacity: 1 !important; pointer-events: all !important; }
  :global(body.wide) .side-nav:hover { opacity: 0.9 !important; }

  /* ─── Tutorial Overlay ───────────────────────────────────── */
  .tutorial-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9000;
    pointer-events: all;
  }
  .tut-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
  }
  .tut-content {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .tut-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    pointer-events: all;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }
  .tut-title {
    font-family: 'Share Tech Mono', monospace;
    font-size: .65rem;
    letter-spacing: .25em;
    color: var(--accent);
    text-transform: uppercase;
  }
  .tut-desc {
    font-family: 'Share Tech Mono', monospace;
    font-size: .7rem;
    color: var(--text-muted);
    line-height: 1.9;
    letter-spacing: .06em;
  }
  .tut-close-btn {
    font-family: 'Share Tech Mono', monospace;
    font-size: .78rem;
    letter-spacing: .1em;
    color: var(--accent);
    background: none;
    border: 1px solid var(--accent);
    padding: 10px 24px;
    cursor: pointer;
    transition: all .2s;
  }
  .tut-close-btn:hover { background: var(--accent); color: var(--bg); }
  .tut-hint {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 6px;
    pointer-events: none;
  }
  .tut-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: .68rem;
    color: rgba(255,255,255,0.75);
    letter-spacing: .06em;
    white-space: nowrap;
  }
  .tut-arrow {
    font-size: 1.2rem;
    color: var(--accent);
    line-height: 1;
  }
  .tut-arrow-sm { font-size: .9rem; }
  /* Hint positions */
  .tut-back     { top: 68px; left: 20px; flex-direction: column; align-items: flex-start; }
  .tut-width    { top: 68px; right: 130px; flex-direction: column; align-items: flex-end; }
  .tut-help-ref { top: 112px; right: 10px; flex-direction: column; align-items: center; }
  .tut-prev     { top: 50%; left: 30px; transform: translateY(-50%); flex-direction: column; align-items: flex-start; gap: 4px; }
  .tut-next     { top: 50%; right: 30px; transform: translateY(-50%); flex-direction: column; align-items: flex-end; gap: 4px; }
  .tut-fontsz   { bottom: 130px; right: 20px; flex-direction: column; align-items: flex-end; }
  .tut-fonttype { bottom: 130px; left: 20px; flex-direction: column; align-items: flex-start; }
  @media (max-width: 480px) {
    .tut-width { right: 100px; }
    .tut-prev { left: 8px; }
    .tut-next { right: 8px; }
    .tut-label { font-size: .6rem; }
  }

  /* ─── Access Gate ───────────────────────────────────────── */
  .access-gate {
    padding: 48px 0 32px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }
  .ag-badge {
    font-family: 'Share Tech Mono', monospace;
    font-size: .6rem;
    letter-spacing: .25em;
    color: var(--bg);
    background: var(--danger);
    padding: 4px 16px;
    display: inline-block;
  }
  .ag-excerpt {
    max-width: 480px;
    font-family: 'Share Tech Mono', monospace;
    font-size: .78rem;
    color: var(--text-dim);
    line-height: 1.8;
    letter-spacing: .04em;
  }
  .ag-divider {
    width: 60px;
    height: 1px;
    background: var(--accent);
    opacity: .4;
  }
  .ag-msg {
    font-family: 'Share Tech Mono', monospace;
    font-size: .75rem;
    color: var(--text-muted);
    line-height: 1.9;
    letter-spacing: .04em;
  }
  .ag-msg strong {
    color: var(--accent);
    font-weight: bold;
    text-decoration: none;
  }
  .ag-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    padding-top: 8px;
  }
  .ag-btn {
    font-family: 'Share Tech Mono', monospace;
    font-size: .75rem;
    letter-spacing: .12em;
    padding: 12px 24px;
    cursor: pointer;
    text-decoration: none;
    transition: all .2s;
    display: inline-flex;
    align-items: center;
  }
  .ag-btn-primary {
    background: var(--accent);
    color: var(--bg);
    border: 1px solid var(--accent);
    font-weight: bold;
  }
  .ag-btn-primary:hover { opacity: .85; }
  .ag-btn-ghost {
    background: none;
    color: var(--text-dim);
    border: 1px solid var(--border);
  }
  .ag-btn-ghost:hover { border-color: var(--text); color: var(--text); }
  @media (max-width: 500px) {
    .ag-actions { flex-direction: column; align-items: stretch; }
    .ag-btn { justify-content: center; }
  }

  /* ─── Series Nav ────────────────────────────────────────── */
  .series-nav-box {
    margin: 1.2rem 0 1.6rem;
    border: 1px solid var(--border);
    background: var(--surface);
    padding: 14px 18px;
  }
  .series-nav-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: .68rem;
    letter-spacing: .15em;
    color: var(--accent);
    margin-bottom: 10px;
    text-transform: uppercase;
  }
  .series-nav-list { display: flex; flex-direction: column; gap: 4px; }
  .series-nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 6px 10px;
    text-decoration: none;
    border: 1px solid transparent;
    transition: all .18s;
  }
  .series-nav-item:hover { border-color: var(--border); background: var(--bg2); }
  .series-nav-item.current {
    border-color: var(--accent);
    background: rgba(var(--accent-rgb, 180,0,0), .06);
    pointer-events: none;
  }
  .snav-order {
    font-family: 'Share Tech Mono', monospace;
    font-size: .6rem;
    color: var(--text-muted);
    min-width: 18px;
  }
  .series-nav-item.current .snav-order { color: var(--accent); }
  .snav-title {
    font-family: 'Noto Serif TC', serif;
    font-size: .82rem;
    color: var(--text-dim);
  }
  .series-nav-item.current .snav-title { color: var(--text); font-weight: 700; }

  /* ─── Related Stories ───────────────────────────────────── */
  .related-section { margin: 2rem 0; }
  .related-hd {
    font-family: 'Share Tech Mono', monospace;
    font-size: .72rem;
    letter-spacing: .2em;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
    padding-bottom: 8px;
    margin-bottom: 12px;
    text-transform: uppercase;
  }
  .related-hd::before { content: '[ '; color: var(--accent); }
  .related-hd::after  { content: ' ]'; color: var(--accent); }
  .related-list { display: flex; flex-direction: column; gap: 4px; }
  .related-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid transparent;
    text-decoration: none;
    transition: all .18s;
  }
  .related-item:hover { border-left-color: var(--accent); background: var(--bg2); }
  .rel-num {
    font-family: 'Share Tech Mono', monospace;
    font-size: .6rem;
    color: var(--text-muted);
    white-space: nowrap;
  }
  .rel-title {
    font-family: 'Noto Serif TC', serif;
    font-size: .85rem;
    font-weight: 700;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .related-item:hover .rel-title { color: var(--accent); }
  .rel-tags {
    font-family: 'Share Tech Mono', monospace;
    font-size: .6rem;
    color: var(--text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ─── Comments ──────────────────────────────────────────── */
  .comments-section { margin: 2rem 0 1rem; }
  .comments-hd {
    font-family: 'Share Tech Mono', monospace;
    font-size: .72rem;
    letter-spacing: .2em;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
    padding-bottom: 8px;
    margin-bottom: 14px;
    text-transform: uppercase;
  }
  .comments-loading {
    font-family: 'Share Tech Mono', monospace;
    font-size: .7rem;
    color: var(--text-muted);
    padding: 8px 0;
  }
  .comment-empty {
    font-family: 'Share Tech Mono', monospace;
    font-size: .72rem;
    color: var(--text-muted);
    padding: 10px 0;
    font-style: italic;
  }
  .comment-item {
    padding: 12px 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--border);
    margin-bottom: 6px;
    transition: border-left-color .3s;
  }
  .comment-item.new { border-left-color: var(--accent); }
  .comment-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 6px;
  }
  .comment-name {
    font-family: 'Share Tech Mono', monospace;
    font-size: .68rem;
    color: var(--accent);
    letter-spacing: .05em;
  }
  .comment-date {
    font-family: 'Share Tech Mono', monospace;
    font-size: .6rem;
    color: var(--text-muted);
  }
  .comment-body {
    font-family: 'Noto Serif TC', serif;
    font-size: .85rem;
    color: var(--text-dim);
    line-height: 1.7;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .comment-form { margin-top: 16px; display: flex; flex-direction: column; gap: 8px; }
  .comment-input, .comment-textarea {
    background: var(--bg2);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: 'Noto Serif TC', serif;
    font-size: .85rem;
    padding: 10px 14px;
    width: 100%;
    box-sizing: border-box;
    outline: none;
    transition: border-color .18s;
    resize: vertical;
  }
  .comment-input:focus, .comment-textarea:focus { border-color: var(--accent); }
  .comment-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
  }
  .comment-char {
    font-family: 'Share Tech Mono', monospace;
    font-size: .62rem;
    color: var(--text-muted);
  }
  .comment-submit {
    font-family: 'Share Tech Mono', monospace;
    font-size: .72rem;
    letter-spacing: .1em;
    padding: 9px 18px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-dim);
    cursor: pointer;
    transition: all .18s;
    text-transform: uppercase;
  }
  .comment-submit:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); }
  .comment-submit:disabled { opacity: .5; cursor: not-allowed; }
  .comment-msg { font-family: 'Share Tech Mono', monospace; font-size: .68rem; }
  .comment-load-more {
    display: block;
    width: 100%;
    margin-top: 12px;
    padding: 9px;
    font-family: 'Share Tech Mono', monospace;
