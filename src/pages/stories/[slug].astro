---
import Layout from '../../layouts/Layout.astro';
import ThemeSwitcher from '../../components/ThemeSwitcher.astro';
import { PaymentGateway } from '../../components/PaymentGateway';
import { ErrorBoundary } from '../../components/ErrorBoundary';
import { getCollection, getEntry } from 'astro:content';
import { supabase } from '../../lib/supabase';

export const prerender = false;

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/stories');

const entry = await getEntry('stories', slug);
if (!entry || !entry.data.published) {
  return Astro.redirect('/stories');
}

const { Content } = await entry.render();

// ─── Server-side auth check ──────────────────────────────────
const userId = Astro.locals.auth?.()?.userId ?? null;

const level = entry.data.level;
const isRestricted = level === 'restricted';
const isTopSecret  = level === 'top-secret';
const isPaid       = level === 'paid';

const signInUrl = `/sign-in?redirect_url=${encodeURIComponent(Astro.url.pathname)}`;

// Paid content: check if user has unlocked this story in user_unlocks table
let isUnlocked = false;
if (isPaid && userId) {
  const { data } = await supabase
    .from('user_unlocks')
    .select('story_slug')
    .eq('user_id', userId)
    .eq('story_slug', slug)
    .single();
  isUnlocked = !!data;
}

// showAccessGate: not logged in AND story requires auth (restricted, top-secret, or paid)
const showAccessGate = !userId && (isRestricted || isTopSecret || isPaid);
// showPaywall: logged in but paid story not yet unlocked
const showPaywall = isPaid && !!userId && !isUnlocked;

// Adjacent stories for prev/next navigation
const allStories = await getCollection('stories', ({ data }) => data.published);
const sorted = allStories.sort((a, b) => b.data.date.localeCompare(a.data.date));
const currentIndex = sorted.findIndex(s => s.slug === slug);
const prevStory = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
const nextStory = currentIndex > 0 ? sorted[currentIndex - 1] : null;
// All stories data for client-side list navigation
const allStoriesData = sorted.map(s => ({ slug: s.slug, tags: s.data.tags, title: s.data.title }));
const curatedListsData = [
  { id: 'starter',  slugs: sorted.filter(s => s.data.level === 'public').slice(0, 5).map(s => s.slug) },
  { id: 'thriller', slugs: sorted.filter(s => s.data.tags.some((t: string) => ['記憶科技','AI社會'].includes(t))).slice(0, 6).map(s => s.slug) },
];

// ─── Series navigation ───────────────────────────────────────
const seriesName = entry.data.series;
const seriesStories = seriesName
  ? allStories
      .filter(s => s.data.series === seriesName)
      .sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0))
  : [];

// ─── Related stories (same tags, exclude self, up to 3) ──────
const tagSet = new Set(entry.data.tags);
const relatedStories = allStories
  .filter(s => s.slug !== slug && s.data.tags.some(t => tagSet.has(t)))
  .sort((a, b) => {
    const aMatch = a.data.tags.filter(t => tagSet.has(t)).length;
    const bMatch = b.data.tags.filter(t => tagSet.has(t)).length;
    return bMatch - aMatch || b.data.date.localeCompare(a.data.date);
  })
  .slice(0, 3);

const ogImageUrl = new URL(`/og/${slug}.png`, Astro.url).href;

const levelLabel: Record<string, string> = {
  'public': '公開', 'restricted': '限制', 'top-secret': '極密', 'paid': '付費',
};

const storyId = `story:${slug}`;
---

<Layout
  title={`${entry.data.title} — 弦音異象`}
  description={entry.data.excerpt}
  ogImage={ogImageUrl}
  ogType="article"
  articleMeta={{ author: entry.data.author, tags: entry.data.tags }}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": entry.data.title,
    "description": entry.data.excerpt,
    "author": { "@type": "Person", "name": entry.data.author },
    "datePublished": entry.data.date,
    "image": ogImageUrl,
    "url": Astro.url.origin + Astro.url.pathname,
    "publisher": {
      "@type": "Organization",
      "name": "弦音異象",
      "url": Astro.url.origin
    },
    "keywords": entry.data.tags.join(', '),
    "inLanguage": "zh-TW"
  })} slot="head" />
  <!-- ─── Reader Header ─── -->
  <header>
    <button id="agBack" class="ctrl-btn back-btn" aria-label="返回" title="返回列表">
      <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 4L6 10l6 6"/>
      </svg>
    </button>
    <a href="/" class="rdr-logo">弦音<em>異象</em></a>
    <div class="rdr-ttl">{entry.data.title}</div>
    <ThemeSwitcher />
    <button id="widthToggle" class="ctrl-btn" title="切換滿版/窄版">
      ⊡<span class="ctrl-lbl" id="widthLbl">窄版</span>
    </button>
  </header>

  <!-- ─── Reading Progress Bar ─── -->
  <div id="progress" aria-hidden="true"></div>

  <!-- ─── Article Body ─── -->
  <main style="padding-top: 56px; min-height: 100vh; background: var(--bg);">
    <div class="art-wrap" id="artWrap">

      <!-- Tags -->
      <div class="art-tags">
        {entry.data.tags.map(tag => (
          <span class="tag">{tag}</span>
        ))}
        <span class={`tag ${level === 'top-secret' || level === 'paid' ? 'w' : ''}`}>
          {levelLabel[level]}
        </span>
      </div>

      <!-- Title -->
      <h1>{entry.data.title}</h1>

      <!-- Series navigation banner -->
      {seriesStories.length > 1 && (
        <div class="series-nav-box">
          <div class="series-nav-label">▸ 系列：{seriesName}</div>
          <div class="series-nav-list">
            {seriesStories.map((s, i) => (
              <a
                href={`/stories/${s.slug}`}
                class={`series-nav-item${s.slug === slug ? ' current' : ''}`}
              >
                <span class="snav-order">{i + 1}</span>
                <span class="snav-title">{s.data.title}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Byline + action buttons -->
      <div class="art-byline">
        <div class="byl-item">案件編號 <em>{entry.data.fileNum}</em></div>
        <div class="byl-item">案發時間 <em>{entry.data.date}</em></div>
        <div class="byl-item">預估閱讀 <em>{entry.data.readTime}</em></div>
        <div class="byl-item">目擊次數 <em><span id="art-views">0</span></em></div>
        <div class="byl-item">累積金幣 <em><span id="art-tokens">0</span></em></div>
        <div class="byl-actions">
          <button class="byl-btn" id="bookmarkBtn2" title="書籤">☐ 書籤</button>
        </div>
      </div>

      <!-- Content (gated by auth level) -->
      {showAccessGate ? (
        <div class="art-body">
          <div class="access-gate">
            <div class="ag-badge">
              {isTopSecret ? '⚠ 極機密文件' : isPaid ? '⚠ 付費限定' : '⚠ 限制閱覽'}
            </div>
            {entry.data.excerpt && (
              <p class="ag-excerpt">{entry.data.excerpt}</p>
            )}
            <div class="ag-divider" />
            <div class="ag-msg">
              此卷宗需要 <strong>身份驗證</strong> 才能存取。<br />
              請登入或建立帳號以取得閱覽授權。
            </div>
            <div class="ag-actions">
              <a href={signInUrl} class="ag-btn ag-btn-primary">[ 登入 / 建立帳號 ]</a>
              <a href="/stories" class="ag-btn ag-btn-ghost">&lt; 返回卷宗列表</a>
            </div>
          </div>
        </div>
      ) : showPaywall ? (
        <div class="art-body">
          <PaymentGateway
            client:load
            storyTitle={entry.data.title}
            storySlug={slug}
            previewContent={entry.data.excerpt}
          />
        </div>
      ) : (
        <div class="art-body" id="artBody">
          <Content />
        </div>
      )}

      <!-- Share Row -->
      <div class="share-row">
        <button class="share-btn" id="shareBtn">↑ 分享</button>
        <button class="share-btn" id="copyBtn">⎘ 複製連結</button>
        <span id="copyFeedback" class="copy-feedback"></span>
      </div>

      <!-- Bottom Nav -->
      <nav class="art-nav" aria-label="文章導覽">
        <a id="navPrev"
           href={prevStory ? `/stories/${prevStory.slug}` : undefined}
           class="nav-pp nav-pp-prev"
           style={prevStory ? '' : 'opacity:.25;pointer-events:none'}>
          <span class="nav-arrow">←</span>
          <span class="nav-title" id="navPrevTitle">{prevStory?.data.title ?? ''}</span>
        </a>
        <button class="token-btn" id="tokenBtn" title="給顆金幣">
          <span id="tokenIcon">⎔</span>
          <span id="tokenCnt">0</span>
          <span class="token-label">給顆金幣</span>
        </button>
        <a id="navNext"
           href={nextStory ? `/stories/${nextStory.slug}` : undefined}
           class="nav-pp nav-pp-next"
           style={nextStory ? '' : 'opacity:.25;pointer-events:none'}>
          <span class="nav-title" id="navNextTitle">{nextStory?.data.title ?? ''}</span>
          <span class="nav-arrow">→</span>
        </a>
      </nav>

      <!-- Related Stories -->
      {relatedStories.length > 0 && (
        <div class="related-section">
          <div class="related-hd">相關卷宗</div>
          <div class="related-list">
            {relatedStories.map(s => (
              <a href={`/stories/${s.slug}`} class="related-item">
                <span class="rel-num">{s.data.fileNum}</span>
                <span class="rel-title">{s.data.title}</span>
                <span class="rel-tags">{s.data.tags.slice(0, 2).join(' · ')}</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Comments -->
      <div class="comments-section" id="commentsSection" data-slug={slug} data-authed={userId ? '1' : '0'}>
        <div class="comments-hd">[ 目擊者留言 ]</div>
        <div id="commentsList" class="comments-list">
          <div class="comments-loading">載入中…</div>
        </div>
        {userId ? (
          <form id="commentForm" class="comment-form">
            <input type="text" id="commentName" class="comment-input" placeholder="代號（選填，預設匿名觀測者）" maxlength="30" />
            <textarea id="commentContent" class="comment-textarea" placeholder="留下你的觀察紀錄… （上限 500 字）" maxlength="500" rows="3"></textarea>
            <div class="comment-actions">
              <span id="commentCharCount" class="comment-char">0 / 500</span>
              <button type="submit" id="commentSubmit" class="comment-submit">提交觀察報告</button>
            </div>
            <div id="commentMsg" class="comment-msg"></div>
          </form>
        ) : (
          <div class="comment-login-prompt">
            <a href={signInUrl} class="comment-login-btn">[ 登入後留言 ]</a>
          </div>
        )}
      </div>

    </div>
  </main>

  <footer>
    <div class="ft-logo">弦音<em>異象</em></div>
    <div class="ft-txt">ANOMALY ARCHIVES · CLASSIFIED<br>一切皆為虛構，除非你相信。</div>
  </footer>

  <!-- ─── Font Size FAB (bottom right) ─── -->
  <div class="font-sz-fab" id="fontSzFab">
    <div class="fsz-pill">
      <button class="fsz-btn big" id="fontUp">+A</button>
      <div class="fsz-lbl" id="fontLabel">1.0×</div>
      <button class="fsz-btn sml" id="fontDown">-A</button>
    </div>
  </div>

  <!-- ─── Font Type FAB (bottom left) ─── -->
  <div class="font-type-fab" id="fontTypeFab">
    <div class="ft-pill">
      <button class="ft-opt on" id="ftSerif">
        <span class="ft-opt-serif">明</span>
      </button>
      <button class="ft-opt" id="ftSans">
        <span class="ft-opt-sans">黑</span>
      </button>
    </div>
  </div>

  <!-- ─── Side Nav Buttons ─── -->
  <a class="side-nav side-nav-prev" id="btnPrev"
     href={prevStory ? `/stories/${prevStory.slug}` : undefined}
     style={prevStory ? '' : 'opacity:0;pointer-events:none'}
     aria-label="上一卷宗">‹</a>
  <a class="side-nav side-nav-next" id="btnNext"
     href={nextStory ? `/stories/${nextStory.slug}` : undefined}
     style={nextStory ? '' : 'opacity:0;pointer-events:none'}
     aria-label="下一卷宗">›</a>
</Layout>

<script define:vars={{ storyId, currentSlug: slug, allStoriesData, curatedListsData, storyTitle: entry.data.title }}>
  // ─── Back button (use .onclick so each page-swap replaces the handler) ──
  var _agBack = document.getElementById('agBack');
  if (_agBack) {
    _agBack.onclick = function() {
      var params = new URLSearchParams(location.search);
      var ref = params.get('ref') || '';
      var listParam = params.get('list') || 'all';
      if (ref === 'home')   { window.location.href = '/';       return; }
      if (ref === 'member') { window.location.href = '/member'; return; }
      if (ref === 'tags')   { window.location.href = '/tags';   return; }
      if (listParam.startsWith('cat:')) {
        window.location.href = '/stories?cat=' + encodeURIComponent(listParam.slice(4));
        return;
      }
      if (listParam.startsWith('curated:')) {
        window.location.href = '/stories?curated=' + encodeURIComponent(listParam.slice(8));
        return;
      }
      window.location.href = '/stories';
    };
  }

  // ─── View counter ─────────────────────────────────────────
  function sGet(k) { try { return localStorage.getItem(k); } catch(e) { return null; } }
  function sSet(k, v) { try { localStorage.setItem(k, v); } catch(e) {} }

  // ─── List-context-aware prev/next ────────────────────────
  function resolvePool() {
    var params = new URLSearchParams(location.search);
    var listParam = params.get('list') || 'all';
    if (listParam === 'all') return allStoriesData;
    if (listParam.startsWith('cat:')) {
      var tag = listParam.slice(4);
      var filtered = allStoriesData.filter(function(s) { return s.tags.includes(tag); });
      return filtered.length > 0 ? filtered : allStoriesData;
    }
    if (listParam.startsWith('curated:')) {
      var id = listParam.slice(8);
      var curated = curatedListsData.find(function(l) { return l.id === id; });
      if (curated) {
        var pool = curated.slugs
          .map(function(sl) { return allStoriesData.find(function(s) { return s.slug === sl; }); })
          .filter(Boolean);
        if (pool.length > 0) return pool;
      }
      return allStoriesData;
    }
    if (listParam.startsWith('user:')) {
      var uid = listParam.slice(5);
      try {
        var saved = sessionStorage.getItem('hz-nav-ctx-' + uid);
        if (saved) {
          var slugs = JSON.parse(saved);
          var pool = slugs
            .map(function(sl) { return allStoriesData.find(function(s) { return s.slug === sl; }); })
            .filter(Boolean);
          if (pool.length > 0) return pool;
        }
      } catch(_) {}
    }
    return allStoriesData;
  }

  function getAdjacent() {
    var params = new URLSearchParams(location.search);
    var listParam = params.get('list') || 'all';
    var ref = params.get('ref') || '';
    var pool = resolvePool();
    var idx = pool.findIndex(function(s) { return s.slug === currentSlug; });
    if (idx === -1) { pool = allStoriesData; listParam = 'all'; idx = pool.findIndex(function(s) { return s.slug === currentSlug; }); }
    var suffix = '?list=' + encodeURIComponent(listParam);
    if (ref) suffix += '&ref=' + encodeURIComponent(ref);
    return {
      suffix: suffix,
      prevSlug: idx < pool.length - 1 ? pool[idx + 1].slug : null,
      nextSlug: idx > 0 ? pool[idx - 1].slug : null,
    };
  }

  function getStoryTitle(sl) {
    var s = allStoriesData.find(function(s) { return s.slug === sl; });
    return s ? s.title : '';
  }

  function updateNavLinks() {
    var adj = getAdjacent();
    // ── Side buttons ──
    var btnPrev = document.getElementById('btnPrev');
    var btnNext = document.getElementById('btnNext');
    if (btnPrev) {
      if (adj.prevSlug) { btnPrev.setAttribute('href', '/stories/' + adj.prevSlug + adj.suffix); btnPrev.style.opacity = ''; btnPrev.style.pointerEvents = ''; }
      else { btnPrev.removeAttribute('href'); btnPrev.style.opacity = '0'; btnPrev.style.pointerEvents = 'none'; }
    }
    if (btnNext) {
      if (adj.nextSlug) { btnNext.setAttribute('href', '/stories/' + adj.nextSlug + adj.suffix); btnNext.style.opacity = ''; btnNext.style.pointerEvents = ''; }
      else { btnNext.removeAttribute('href'); btnNext.style.opacity = '0'; btnNext.style.pointerEvents = 'none'; }
    }
    // ── Bottom nav ──
    var navPrev = document.getElementById('navPrev');
    var navNext = document.getElementById('navNext');
    var navPrevTitle = document.getElementById('navPrevTitle');
    var navNextTitle = document.getElementById('navNextTitle');
    if (navPrev) {
      if (adj.prevSlug) { navPrev.setAttribute('href', '/stories/' + adj.prevSlug + adj.suffix); navPrev.style.opacity = ''; navPrev.style.pointerEvents = ''; if (navPrevTitle) navPrevTitle.textContent = getStoryTitle(adj.prevSlug); }
      else { navPrev.removeAttribute('href'); navPrev.style.opacity = '0.25'; navPrev.style.pointerEvents = 'none'; if (navPrevTitle) navPrevTitle.textContent = ''; }
    }
    if (navNext) {
      if (adj.nextSlug) { navNext.setAttribute('href', '/stories/' + adj.nextSlug + adj.suffix); navNext.style.opacity = ''; navNext.style.pointerEvents = ''; if (navNextTitle) navNextTitle.textContent = getStoryTitle(adj.nextSlug); }
      else { navNext.removeAttribute('href'); navNext.style.opacity = '0.25'; navNext.style.pointerEvents = 'none'; if (navNextTitle) navNextTitle.textContent = ''; }
    }
  }
  updateNavLinks();

  function fmtN(n) { return n >= 1000 ? (n / 1000).toFixed(1) + 'K' : String(n); }

  // ─── Supabase stats ───────────────────────────────────────
  // liked state stays in localStorage (per-device fallback for non-login users)
  function sGet(k) { try { return localStorage.getItem(k); } catch(e) { return null; } }
  function sSet(k, v) { try { localStorage.setItem(k, v); } catch(e) {} }

  let liked = sGet('hz-liked:' + currentSlug) === '1';
  let globalTokens = 0;

  // Track last visited story for homepage CTA
  sSet('hz-last-story', currentSlug);

  // Fetch current stats from Supabase
  fetch('/api/stats/' + currentSlug)
    .then(r => r.json())
    .then(data => {
      globalTokens = data.tokens ?? 0;
      const viewsEl = document.getElementById('art-views');
      const artTokens = document.getElementById('art-tokens');
      const cnt = document.getElementById('tokenCnt');
      if (viewsEl) viewsEl.textContent = fmtN(data.views ?? 0);
      if (artTokens) artTokens.textContent = fmtN(globalTokens);
      if (cnt) cnt.textContent = fmtN(globalTokens);
    })
    .catch(() => {});

  // Increment view count — skip if already counted this session
  const _viewKey = 'viewed:' + currentSlug;
  if (!sessionStorage.getItem(_viewKey)) {
    sessionStorage.setItem(_viewKey, '1');
    fetch('/api/stats/view', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug: currentSlug }),
    }).catch(() => {});
  }

  // ─── Token / Coin button ──────────────────────────────────
  function updateTokenUI() {
    const btn = document.getElementById('tokenBtn');
    const icon = document.getElementById('tokenIcon');
    const cnt = document.getElementById('tokenCnt');
    const label = btn?.querySelector('.token-label');
    const artTokens = document.getElementById('art-tokens');
    if (icon) icon.textContent = liked ? '◈' : '⎔';
    if (cnt) cnt.textContent = fmtN(globalTokens);
    if (label) label.textContent = liked ? '收回金幣' : '給顆金幣';
    if (artTokens) artTokens.textContent = fmtN(globalTokens);
    btn?.classList.toggle('on', liked);
  }
  updateTokenUI();

  document.getElementById('tokenBtn')?.addEventListener('click', () => {
    const action = liked ? 'remove' : 'add';
    liked = !liked;
    globalTokens = Math.max(0, globalTokens + (liked ? 1 : -1));
    sSet('hz-liked:' + currentSlug, liked ? '1' : '0');
    updateTokenUI();

    fetch('/api/stats/token', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug: currentSlug, action }),
    })
      .then(r => r.json())
      .then(data => {
        if (data.tokens !== undefined) {
          globalTokens = data.tokens;
          updateTokenUI();
        }
      })
      .catch(() => {}); // keep optimistic update on error
  });

  // ─── Reading progress bar + save ──────────────────────────
  let progressSaveTimer = null;
  let lastSavedPct = parseInt(sGet('hz-progress:' + currentSlug) || '0', 10);

  // Clue discovery: triggered once per story per session when ≥60% read
  const clueDiscoverKey = 'hz-clues-discovered:' + currentSlug;
  let clueDiscovered = sGet(clueDiscoverKey) === '1';

  function showClueToast(count: number) {
    const toast = document.createElement('div');
    toast.className = 'clue-toast';
    toast.innerHTML = `🔍 發現 <strong>${count}</strong> 條線索 — <a href="/investigate">前往調查室</a>`;
    document.body.appendChild(toast);
    requestAnimationFrame(() => toast.classList.add('visible'));
    setTimeout(() => {
      toast.classList.remove('visible');
      setTimeout(() => toast.remove(), 400);
    }, 5000);
  }

  function discoverClues() {
    if (clueDiscovered) return;
    clueDiscovered = true; // prevent parallel calls
    fetch('/api/clues/discover', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug: currentSlug }),
    })
      .then(r => r.ok ? r.json() : Promise.reject(r.status))
      .then(data => {
        sSet(clueDiscoverKey, '1'); // only persist on success
        if (data?.discovered > 0) showClueToast(data.discovered);
      })
      .catch((err) => {
        clueDiscovered = false; // allow retry on next page load
        console.warn('[Tones] clue discover failed:', err);
      });
  }

  function saveProgress(pct) {
    sSet('hz-progress:' + currentSlug, String(pct));
    // Fire-and-forget for logged-in users; 401 for anonymous is silently ignored
    fetch('/api/progress', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug: currentSlug, pct }),
    }).catch(() => {});
  }

  // If already read past 60% in a previous session, discover immediately
  if (lastSavedPct >= 60) discoverClues();

  window.addEventListener('scroll', () => {
    const docH = document.documentElement.scrollHeight - window.innerHeight;
    const pct = docH > 0 ? Math.round(window.scrollY / docH * 100) : 0;

    // Update visual progress bar
    const progressEl = document.getElementById('progress');
    if (progressEl) progressEl.style.width = pct + '%';

    // Trigger clue discovery immediately at 60% (no debounce)
    if (pct >= 60) discoverClues();

    if (Math.abs(pct - lastSavedPct) >= 5) {
      clearTimeout(progressSaveTimer);
      progressSaveTimer = setTimeout(() => { saveProgress(pct); lastSavedPct = pct; }, 5000);
    }
  }, { passive: true });

  // ─── Bookmark ──────────────────────────────────────────────
  let bookmarked = sGet('hz-bookmark:' + currentSlug) === '1';

  function updateBookmarkUI() {
    const btn2 = document.getElementById('bookmarkBtn2');
    if (btn2) { btn2.textContent = bookmarked ? '☑ 已書籤' : '☐ 書籤'; btn2.classList.toggle('on', bookmarked); }
  }
  updateBookmarkUI();

  function toggleBookmark() {
    bookmarked = !bookmarked;
    sSet('hz-bookmark:' + currentSlug, bookmarked ? '1' : '0');
    updateBookmarkUI();
    fetch('/api/bookmark', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug: currentSlug, action: bookmarked ? 'add' : 'remove' }),
    }).catch(() => {});
  }
  document.getElementById('bookmarkBtn2')?.addEventListener('click', toggleBookmark);

  // ─── Share ─────────────────────────────────────────────────
  function copyLink(feedbackId = 'copyFeedback') {
    navigator.clipboard?.writeText(location.href).then(() => {
      const fb = document.getElementById(feedbackId);
      if (fb) { fb.textContent = '已複製！'; setTimeout(() => { fb.textContent = ''; }, 2000); }
    }).catch(() => {});
  }

  async function doShare() {
    if (navigator.share) {
      try { await navigator.share({ title: storyTitle, text: storyTitle, url: location.href }); return; }
      catch (_) {}
    }
    copyLink('copyFeedback');
  }

  document.getElementById('shareBtn')?.addEventListener('click', doShare);
  document.getElementById('copyBtn')?.addEventListener('click', () => copyLink('copyFeedback'));

  // ─── Wide / Narrow toggle ─────────────────────────────────
  const artWrap = document.getElementById('artWrap');
  const widthBtn = document.getElementById('widthToggle');
  const widthLbl = document.getElementById('widthLbl');
  let wide = sGet('hz-wide') === '1';

  function applyWide() {
    artWrap?.classList.toggle('wide', wide);
    document.body.classList.toggle('wide', wide);
    if (widthLbl) widthLbl.textContent = wide ? '滿版' : '窄版';
    if (widthBtn) {
      widthBtn.firstChild.nodeValue = wide ? '⊞' : '⊡';
      widthBtn.classList.toggle('on', wide);
    }
  }
  applyWide();

  widthBtn?.addEventListener('click', () => {
    wide = !wide;
    sSet('hz-wide', wide ? '1' : '0');
    applyWide();
  });

  // ─── Font size ────────────────────────────────────────────
  let fontSz = parseFloat(sGet('hz-font-sz') || '1.0');
  let fontType = sGet('hz-font-type') || 'serif';

  function applyFont() {
    const body = document.getElementById('artBody');
    if (!body) return;
    body.style.fontSize = fontSz + 'rem';
    body.style.fontFamily = fontType === 'serif'
      ? "'Noto Serif TC', serif"
      : "'Noto Sans TC', sans-serif";
    const lh = (fontSz >= 1.0 ? Math.max(2.0, 2.18 - (fontSz - 1.0) * 0.356) : 2.18).toFixed(2);
    body.style.lineHeight = lh;
    const lbl = document.getElementById('fontLabel');
    if (lbl) lbl.textContent = fontSz.toFixed(1) + '×';
  }
  applyFont();

  document.getElementById('fontUp')?.addEventListener('click', () => {
    fontSz = Math.min(1.45, +(fontSz + 0.1).toFixed(1));
    sSet('hz-font-sz', String(fontSz));
    applyFont();
  });
  document.getElementById('fontDown')?.addEventListener('click', () => {
    fontSz = Math.max(0.78, +(fontSz - 0.1).toFixed(1));
    sSet('hz-font-sz', String(fontSz));
    applyFont();
  });
  document.getElementById('fontLabel')?.addEventListener('click', () => {
    fontSz = 1.0;
    sSet('hz-font-sz', '1.0');
    applyFont();
  });

  // ─── Font type toggle ────────────────────────────────────
  function setFontType(type) {
    fontType = type;
    sSet('hz-font-type', type);
    applyFont();
    document.getElementById('ftSerif')?.classList.toggle('on', type === 'serif');
    document.getElementById('ftSans')?.classList.toggle('on', type === 'sans');
  }
  // restore saved font type
  setFontType(fontType);

  document.getElementById('ftSerif')?.addEventListener('click', () => setFontType('serif'));
  document.getElementById('ftSans')?.addEventListener('click', () => setFontType('sans'));

  // ─── Comments ─────────────────────────────────────────────
  (function() {
    var section = document.getElementById('commentsSection');
    if (!section) return;
    var slug = section.dataset.slug;
    var authed = section.dataset.authed === '1';
    var list = document.getElementById('commentsList');

    function fmtDate(iso) {
      var d = new Date(iso);
      return d.getFullYear() + '.' +
        String(d.getMonth() + 1).padStart(2, '0') + '.' +
        String(d.getDate()).padStart(2, '0');
    }

    function renderComments(comments) {
      if (!list) return;
      if (!comments.length) {
        list.innerHTML = '<div class="comment-empty">尚無觀測紀錄。成為第一位目擊者。</div>';
        return;
      }
      list.innerHTML = comments.map(function(c) {
        return '<div class="comment-item">' +
          '<div class="comment-meta"><span class="comment-name">' + escHtml(c.display_name) + '</span>' +
          '<span class="comment-date">' + fmtDate(c.created_at) + '</span></div>' +
          '<div class="comment-body">' + escHtml(c.content) + '</div>' +
          '</div>';
      }).join('');
    }

    function escHtml(s) {
      return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    // Lazy-load comments when section scrolls into view
    var commentsLoaded = false;
    function loadComments() {
      if (commentsLoaded) return;
      commentsLoaded = true;
      fetch('/api/comments?slug=' + slug)
        .then(function(r) { return r.json(); })
        .then(function(data) { renderComments(Array.isArray(data) ? data : []); })
        .catch(function() { if (list) list.innerHTML = ''; });
    }

    if ('IntersectionObserver' in window) {
      var obs = new IntersectionObserver(function(entries) {
        if (entries[0].isIntersecting) { loadComments(); obs.disconnect(); }
      }, { rootMargin: '200px' });
      obs.observe(section);
    } else {
      loadComments();
    }

    var form = document.getElementById('commentForm');
    var textarea = document.getElementById('commentContent');
    var charCount = document.getElementById('commentCharCount');
    var msg = document.getElementById('commentMsg');

    textarea?.addEventListener('input', function() {
      var len = textarea.value.length;
      if (charCount) charCount.textContent = len + ' / 500';
    });

    form?.addEventListener('submit', function(e) {
      e.preventDefault();
      var content = textarea?.value.trim() ?? '';
      if (!content) return;
      var nameEl = document.getElementById('commentName');
      var displayName = nameEl?.value.trim() || '';
      var submitBtn = document.getElementById('commentSubmit');
      if (submitBtn) submitBtn.disabled = true;

      fetch('/api/comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug: slug, content: content, displayName: displayName }),
      })
        .then(function(r) { return r.ok ? r.json() : Promise.reject(r.status); })
        .then(function(comment) {
          if (textarea) textarea.value = '';
          if (charCount) charCount.textContent = '0 / 500';
          if (nameEl) nameEl.value = '';
          if (msg) { msg.textContent = '觀察報告已提交。'; msg.className = 'comment-msg ok'; }
          // Prepend new comment to list
          var existing = list?.querySelectorAll('.comment-item').length ?? 0;
          var empty = list?.querySelector('.comment-empty');
          if (empty) empty.remove();
          var el = document.createElement('div');
          el.className = 'comment-item new';
          el.innerHTML = '<div class="comment-meta"><span class="comment-name">' +
            escHtml(comment.display_name) + '</span><span class="comment-date">剛剛</span></div>' +
            '<div class="comment-body">' + escHtml(comment.content) + '</div>';
          list?.prepend(el);
          setTimeout(function() { el.classList.remove('new'); }, 1500);
          setTimeout(function() { if (msg) msg.textContent = ''; }, 3000);
        })
        .catch(function(err) {
          if (msg) { msg.textContent = err === 401 ? '請先登入再留言。' : '提交失敗，請稍後再試。'; msg.className = 'comment-msg err'; }
        })
        .finally(function() { if (submitBtn) submitBtn.disabled = false; });
    });
  })();

</script>

