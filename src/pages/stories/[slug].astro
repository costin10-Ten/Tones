---
import Layout from '../../layouts/Layout.astro';
import ThemeSwitcher from '../../components/ThemeSwitcher.astro';
import { PaymentGateway } from '../../components/PaymentGateway';
import { ErrorBoundary } from '../../components/ErrorBoundary';
import { getCollection, getEntry } from 'astro:content';

export const prerender = false;

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/stories');

const entry = await getEntry('stories', slug);
if (!entry || !entry.data.published) {
  return Astro.redirect('/stories');
}

const { Content } = await entry.render();

// ─── Server-side auth check ──────────────────────────────────
const userId = Astro.locals.auth?.()?.userId ?? null;

const level = entry.data.level;
const isRestricted = level === 'restricted';
const isTopSecret  = level === 'top-secret';
const isPaid       = level === 'paid';

// Access gate: unauthenticated users see an in-page gate (no redirect, no content leak)
const showAccessGate = (isRestricted || isTopSecret) && !userId;
const signInUrl = `/sign-in?redirect_url=${encodeURIComponent(Astro.url.pathname)}`;

// Paid content: authenticated but not subscribed → show PaymentGateway
const isSubscribed = false; // TODO: check DB/Stripe subscription
const showPaywall = isPaid && (!userId || !isSubscribed);

// Adjacent stories for prev/next navigation
const allStories = await getCollection('stories', ({ data }) => data.published);
const sorted = allStories.sort((a, b) => b.data.date.localeCompare(a.data.date));
const currentIndex = sorted.findIndex(s => s.slug === slug);
const prevStory = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
const nextStory = currentIndex > 0 ? sorted[currentIndex - 1] : null;
// All stories data for client-side category-aware swipe navigation
const allStoriesData = sorted.map(s => ({ slug: s.slug, tags: s.data.tags }));

const levelLabel: Record<string, string> = {
  'public': '公開', 'restricted': '限制', 'top-secret': '極密', 'paid': '付費',
};

const storyId = `story:${slug}`;
---

<Layout
  title={`${entry.data.title} — 弦音異象`}
  description={entry.data.excerpt}
>
  <!-- ─── Reader Header ─── -->
  <header>
    <a href="/" class="rdr-logo">弦音<em>異象</em></a>
    <div class="rdr-ttl">{entry.data.title}</div>
    <ThemeSwitcher />
    <button id="widthToggle" class="ctrl-btn" title="切換滿版/窄版">
      ⊡<span class="ctrl-lbl" id="widthLbl">窄版</span>
    </button>
  </header>

  <!-- ─── Reading Progress Bar ─── -->
  <div id="progress" aria-hidden="true"></div>

  <!-- ─── Article Body ─── -->
  <main style="padding-top: 56px; min-height: 100vh; background: var(--bg);">
    <div class="art-wrap" id="artWrap">

      <!-- Tags -->
      <div class="art-tags">
        {entry.data.tags.map(tag => (
          <span class="tag">{tag}</span>
        ))}
        <span class={`tag ${level === 'top-secret' || level === 'paid' ? 'w' : ''}`}>
          {levelLabel[level]}
        </span>
      </div>

      <!-- Title -->
      <h1>{entry.data.title}</h1>

      <!-- Byline -->
      <div class="art-byline">
        <div class="byl-item">案件編號 <em>{entry.data.fileNum}</em></div>
        <div class="byl-item">案發時間 <em>{entry.data.date}</em></div>
        <div class="byl-item">預估閱讀 <em>{entry.data.readTime}</em></div>
        <div class="byl-item">目擊次數 <em><span id="art-views">0</span></em></div>
      </div>

      <!-- Content, Access Gate, or Paywall -->
      {showAccessGate ? (
        <!-- ─── Access Gate ─── -->
        <div class="access-gate">
          <div class="ag-badge">{isTopSecret ? 'TOP SECRET' : 'RESTRICTED'} · ACCESS DENIED</div>
          <div class="ag-excerpt">{entry.data.excerpt}</div>
          <div class="ag-divider"></div>
          <p class="ag-msg">
            此卷宗屬於<strong>{isTopSecret ? '極密' : '限制'}</strong>級別。<br/>
            需要觀測者身份驗證後方可存取。
          </p>
          <div class="ag-actions">
            <a href={signInUrl} class="ag-btn ag-btn-primary">[ 登入以解鎖 ]</a>
            <button class="ag-btn ag-btn-ghost" id="agBack">[ 返回上一頁 ]</button>
            <a href="/" class="ag-btn ag-btn-ghost">[ 返回首頁 ]</a>
          </div>
        </div>
      ) : showPaywall ? (
        <ErrorBoundary client:load>
          <PaymentGateway
            client:load
            storyTitle={entry.data.title}
            storySlug={slug}
            previewContent={entry.data.excerpt}
          />
        </ErrorBoundary>
      ) : (
        <div class="art-body" id="artBody">
          <Content />
        </div>
      )}

      <!-- Prev / Next Navigation (hrefs updated client-side for category-aware swipe) -->
      <nav class="art-nav" aria-label="文章導覽">
        <a href={prevStory ? `/stories/${prevStory.slug}` : undefined}
           class="nav-pp" id="btnPrev"
           style={prevStory ? '' : 'opacity:.25;pointer-events:none'}>
          ← 上一卷宗
        </a>

        <!-- Token / Coin button -->
        <button class="token-btn" id="tokenBtn" title="沒收金幣">
          <span id="tokenIcon">⎔</span><span id="tokenCnt">0</span>
        </button>

        <a href={nextStory ? `/stories/${nextStory.slug}` : undefined}
           class="nav-pp" id="btnNext"
           style={nextStory ? '' : 'opacity:.25;pointer-events:none'}>
          下一卷宗 →
        </a>
      </nav>
    </div>
  </main>

  <footer>
    <div class="ft-logo">弦音<em>異象</em></div>
    <div class="ft-txt">ANOMALY ARCHIVES · CLASSIFIED<br>一切皆為虛構，除非你相信。</div>
  </footer>

  <!-- ─── Font Size FAB (bottom right) ─── -->
  <div class="font-sz-fab" id="fontSzFab">
    <div class="fsz-pill">
      <button class="fsz-btn big" id="fontUp">+A</button>
      <div class="fsz-lbl" id="fontLabel">1.0×</div>
      <button class="fsz-btn sml" id="fontDown">-A</button>
    </div>
  </div>

  <!-- ─── Font Type FAB (bottom left) ─── -->
  <div class="font-type-fab" id="fontTypeFab">
    <div class="ft-pill">
      <button class="ft-opt on" id="ftSerif">
        <span class="ft-opt-serif">明</span>
      </button>
      <button class="ft-opt" id="ftSans">
        <span class="ft-opt-sans">黑</span>
      </button>
    </div>
  </div>

  <!-- ─── Swipe Hint ─── -->
  <div class="swipe-hint" id="swipeHint">← 滑動切換卷宗 →</div>
</Layout>

<script is:inline>
  document.getElementById('agBack')?.addEventListener('click', function() {
    if (history.length > 1) { history.back(); }
    else { window.location.href = '/'; }
  });
</script>

<script define:vars={{ storyId, currentSlug: slug, allStoriesData }}>
  // ─── View counter ─────────────────────────────────────────
  function sGet(k) { try { return localStorage.getItem(k); } catch(e) { return null; } }
  function sSet(k, v) { try { localStorage.setItem(k, v); } catch(e) {} }

  // ─── Category-aware prev/next ─────────────────────────────
  function getAdjacent() {
    var cat = sGet('hz-cat') || '全部';
    var pool = cat !== '全部'
      ? allStoriesData.filter(function(s) { return s.tags.includes(cat); })
      : allStoriesData;
    var idx = pool.findIndex(function(s) { return s.slug === currentSlug; });
    if (idx === -1) {
      // current story not in filtered pool (e.g. category changed) → use all
      pool = allStoriesData;
      idx = pool.findIndex(function(s) { return s.slug === currentSlug; });
    }
    return {
      prevSlug: idx < pool.length - 1 ? pool[idx + 1].slug : null,
      nextSlug: idx > 0 ? pool[idx - 1].slug : null,
    };
  }

  function updateNavLinks() {
    var adj = getAdjacent();
    var btnPrev = document.getElementById('btnPrev');
    var btnNext = document.getElementById('btnNext');
    if (btnPrev) {
      if (adj.prevSlug) {
        btnPrev.setAttribute('href', '/stories/' + adj.prevSlug);
        btnPrev.style.opacity = ''; btnPrev.style.pointerEvents = '';
      } else {
        btnPrev.removeAttribute('href');
        btnPrev.style.opacity = '0.25'; btnPrev.style.pointerEvents = 'none';
      }
    }
    if (btnNext) {
      if (adj.nextSlug) {
        btnNext.setAttribute('href', '/stories/' + adj.nextSlug);
        btnNext.style.opacity = ''; btnNext.style.pointerEvents = '';
      } else {
        btnNext.removeAttribute('href');
        btnNext.style.opacity = '0.25'; btnNext.style.pointerEvents = 'none';
      }
    }
  }
  updateNavLinks();

  function loadStoryStats(id) {
    const raw = sGet(id);
    if (raw) { try { return JSON.parse(raw); } catch(e) {} }
    return { views: 0, tokens: 0, liked: false };
  }
  function saveStoryStats(id, stats) { sSet(id, JSON.stringify(stats)); }
  function fmtN(n) { return n >= 1000 ? (n / 1000).toFixed(1) + 'K' : String(n); }

  const stats = loadStoryStats(storyId);
  stats.views++;
  saveStoryStats(storyId, stats);
  // Track last visited story for homepage CTA
  sSet('hz-last-story', currentSlug);

  const viewsEl = document.getElementById('art-views');
  if (viewsEl) viewsEl.textContent = fmtN(stats.views);

  // ─── Token / Coin button ──────────────────────────────────
  function updateTokenUI() {
    const btn = document.getElementById('tokenBtn');
    const icon = document.getElementById('tokenIcon');
    const cnt = document.getElementById('tokenCnt');
    if (icon) icon.textContent = stats.liked ? '◈' : '⎔';
    if (cnt) cnt.textContent = fmtN(stats.tokens);
    btn?.classList.toggle('on', !!stats.liked);
  }
  updateTokenUI();

  document.getElementById('tokenBtn')?.addEventListener('click', () => {
    stats.liked = !stats.liked;
    stats.tokens = Math.max(0, stats.tokens + (stats.liked ? 1 : -1));
    saveStoryStats(storyId, stats);
    updateTokenUI();
  });

  // ─── Reading progress bar ─────────────────────────────────
  const progressBar = document.getElementById('progress');
  window.addEventListener('scroll', () => {
    if (!progressBar) return;
    const docH = document.documentElement.scrollHeight - window.innerHeight;
    progressBar.style.width = docH > 0 ? (window.scrollY / docH * 100) + '%' : '0%';
  }, { passive: true });

  // ─── Wide / Narrow toggle ─────────────────────────────────
  const artWrap = document.getElementById('artWrap');
  const widthBtn = document.getElementById('widthToggle');
  const widthLbl = document.getElementById('widthLbl');
  let wide = false;

  widthBtn?.addEventListener('click', () => {
    wide = !wide;
    artWrap?.classList.toggle('wide', wide);
    if (widthLbl) widthLbl.textContent = wide ? '滿版' : '窄版';
    if (widthBtn) {
      widthBtn.firstChild.nodeValue = wide ? '⊞' : '⊡';
      widthBtn.classList.toggle('on', wide);
    }
  });

  // ─── Font size ────────────────────────────────────────────
  let fontSz = parseFloat(sGet('hz-font-sz') || '1.0');
  let fontType = sGet('hz-font-type') || 'serif';

  function applyFont() {
    const body = document.getElementById('artBody');
    if (!body) return;
    body.style.fontSize = fontSz + 'rem';
    body.style.fontFamily = fontType === 'serif'
      ? "'Noto Serif TC', serif"
      : "'Noto Sans TC', sans-serif";
    const lh = (fontSz >= 1.0 ? Math.max(1.94, 2.1 - (fontSz - 1.0) * 0.356) : 2.1).toFixed(2);
    body.style.lineHeight = lh;
    const lbl = document.getElementById('fontLabel');
    if (lbl) lbl.textContent = fontSz.toFixed(1) + '×';
  }
  applyFont();

  document.getElementById('fontUp')?.addEventListener('click', () => {
    fontSz = Math.min(1.45, +(fontSz + 0.1).toFixed(1));
    sSet('hz-font-sz', String(fontSz));
    applyFont();
  });
  document.getElementById('fontDown')?.addEventListener('click', () => {
    fontSz = Math.max(0.78, +(fontSz - 0.1).toFixed(1));
    sSet('hz-font-sz', String(fontSz));
    applyFont();
  });
  document.getElementById('fontLabel')?.addEventListener('click', () => {
    fontSz = 1.0;
    sSet('hz-font-sz', '1.0');
    applyFont();
  });

  // ─── Font type toggle ────────────────────────────────────
  function setFontType(type) {
    fontType = type;
    sSet('hz-font-type', type);
    applyFont();
    document.getElementById('ftSerif')?.classList.toggle('on', type === 'serif');
    document.getElementById('ftSans')?.classList.toggle('on', type === 'sans');
  }
  // restore saved font type
  setFontType(fontType);

  document.getElementById('ftSerif')?.addEventListener('click', () => setFontType('serif'));
  document.getElementById('ftSans')?.addEventListener('click', () => setFontType('sans'));

  // ─── Swipe gesture (prev / next, category-aware) ─────────
  // Use AbortController so listeners are removed when leaving the page via ViewTransitions
  var _swipeCtrl = new AbortController();
  var swipeSig = _swipeCtrl.signal;
  document.addEventListener('astro:before-swap', function() { _swipeCtrl.abort(); }, { once: true });

  var touchStartX = null;
  var touchStartY = null;
  var touchStartTime = 0;

  document.addEventListener('touchstart', function(e) {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
    touchStartTime = Date.now();
  }, { passive: true, signal: swipeSig });

  document.addEventListener('touchend', function(e) {
    if (touchStartX === null) return;
    var dx = e.changedTouches[0].clientX - touchStartX;
    var dy = Math.abs(e.changedTouches[0].clientY - touchStartY);
    var dt = Date.now() - touchStartTime;

    if (dt < 500 && Math.abs(dx) > 60 && Math.abs(dx) > dy * 1.5) {
      var hint = document.getElementById('swipeHint');
      if (hint) { hint.classList.add('show'); setTimeout(function() { hint.classList.remove('show'); }, 1800); }

      var adj = getAdjacent();
      if (dx < 0 && adj.nextSlug) {
        window.location.href = '/stories/' + adj.nextSlug;
      } else if (dx > 0 && adj.prevSlug) {
        window.location.href = '/stories/' + adj.prevSlug;
      }
    }
    touchStartX = null;
  }, { passive: true, signal: swipeSig });
</script>

<style>
  /* ─── Header ─────────────────────────────────────────────── */
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: 56px;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 0 16px;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }
  .rdr-logo {
    font-family: 'Noto Serif TC', serif;
    font-weight: 900;
    font-size: 1rem;
    color: var(--text);
    text-decoration: none;
    letter-spacing: 0.08em;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .rdr-logo em { color: var(--accent); font-style: normal; }
  .rdr-logo:hover { color: var(--text); }
  .rdr-ttl {
    flex: 1;
    font-family: 'Noto Serif TC', serif;
    font-size: .85rem;
    font-weight: 700;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-align: center;
    letter-spacing: .04em;
  }
  .ctrl-btn {
    background: none;
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-family: 'Share Tech Mono', monospace;
    font-size: .7rem;
    padding: 5px 10px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 5px;
    white-space: nowrap;
    flex-shrink: 0;
    transition: all .2s;
    touch-action: manipulation; /* prevent double-tap zoom */
  }
  .ctrl-btn:hover, .ctrl-btn.on { border-color: var(--accent); color: var(--accent); }
  .ctrl-lbl { font-size: .65rem; letter-spacing: .1em; }

  /* ─── Article ────────────────────────────────────────────── */
  .art-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }
  .tag {
    font-family: 'Share Tech Mono', monospace;
    font-size: .62rem;
    letter-spacing: .1em;
    padding: 3px 8px;
    background: var(--accent-dim);
    color: var(--accent);
    border: 1px solid var(--border);
  }
  .tag.w { background: rgba(217,4,41,.25); border-color: var(--accent); }

  h1 {
    font-family: 'Noto Serif TC', serif;
    font-size: clamp(1.5rem, 5vw, 2.4rem);
    font-weight: 900;
    line-height: 1.25;
    color: var(--text);
    letter-spacing: .04em;
    margin-bottom: 20px;
  }
  .art-byline {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 40px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
  }
  .byl-item {
    font-family: 'Share Tech Mono', monospace;
    font-size: .65rem;
    color: var(--text-muted);
    letter-spacing: .08em;
  }
  .byl-item em { color: var(--accent); font-style: normal; margin-left: 4px; }

  .art-body {
    font-family: 'Noto Serif TC', serif;
    font-size: 1rem;
    line-height: 2;
    color: var(--text-dim);
    transition: font-size .2s, line-height .2s;
  }
  .art-body :global(p)          { margin-bottom: 1.5rem; }
  .art-body :global(h2)         { font-size: 1.2rem; font-weight: 900; color: var(--text); border-left: 3px solid var(--accent); padding-left: 12px; margin: 2.5rem 0 1rem; }
  .art-body :global(h3)         { font-size: 1rem; font-weight: 700; color: var(--text); margin: 2rem 0 .75rem; }
  .art-body :global(blockquote) { border-left: 2px solid var(--accent); padding: 12px 16px; background: var(--accent-dim); margin: 1.5rem 0; }
  .art-body :global(blockquote p) { margin: 0; color: var(--text); font-style: italic; }
  .art-body :global(hr)         { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }
  .art-body :global(strong)     { color: var(--text); font-weight: 700; text-decoration: underline; text-decoration-color: var(--accent); text-underline-offset: 3px; }
  .art-body :global(em)         { color: var(--warm); font-style: italic; }
  .art-body :global(a)          { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  .art-body :global(img)        {
    display: block;
    width: 100%;
    max-width: 700px;
    margin: 2rem auto;
    border: 1px solid var(--border);
    filter: saturate(0.85) brightness(0.9);
    opacity: 0.92;
  }
  .art-body :global(img:hover)  { opacity: 1; filter: saturate(1) brightness(1); transition: all 0.3s; }
  .art-body :global(figure)     { margin: 2.5rem 0; }
  .art-body :global(figcaption) {
    font-family: 'Share Tech Mono', monospace;
    font-size: .62rem;
    color: var(--text-muted);
    text-align: center;
    letter-spacing: .08em;
    margin-top: .5rem;
  }

  /* ─── Footer ─────────────────────────────────────────────── */
  footer { text-align: center; padding: 48px 24px; border-top: 1px solid var(--border); }
  .ft-logo { font-family: 'Noto Serif TC', serif; font-size: 1.2rem; font-weight: 900; color: var(--text); letter-spacing: .1em; margin-bottom: 10px; }
  .ft-logo em { color: var(--accent); font-style: normal; }
  .ft-txt { font-family: 'Share Tech Mono', monospace; font-size: .65rem; color: var(--text-muted); letter-spacing: .1em; line-height: 1.8; }

  /* ─── Font FAB ──────────────────────────────────────────── */
  .font-sz-fab {
    position: fixed;
    bottom: 80px;
    right: 16px;
    z-index: 560;
    opacity: 0.5;
    transition: opacity 0.3s;
  }
  .font-sz-fab:hover { opacity: 1; }

  .fsz-pill {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: var(--surface);
    border: 1px solid var(--border);
    box-shadow: 0 4px 15px rgba(0,0,0,.6);
  }
  .fsz-btn {
    width: 40px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--text-dim);
    cursor: pointer;
    font-family: 'Share Tech Mono', monospace;
    touch-action: manipulation; /* prevent double-tap zoom */
  }
  .fsz-btn.big { font-size: .9rem; font-weight: 700; }
  .fsz-btn.sml { font-size: .7rem; }
  .fsz-btn:hover { color: var(--text); background: var(--bg2); }

  .fsz-lbl {
    font-family: 'Share Tech Mono', monospace;
    font-size: .6rem;
    color: var(--text-muted);
    padding: 6px 0;
    cursor: pointer;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    width: 100%;
    text-align: center;
    letter-spacing: .1em;
  }

  /* ─── Font Type FAB ─────────────────────────────────────── */
  .font-type-fab {
    position: fixed;
    bottom: 80px;
    left: 16px;
    z-index: 560;
    opacity: 0.5;
    transition: opacity 0.3s;
  }
  .font-type-fab:hover { opacity: 1; }

  .ft-pill {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    box-shadow: 0 4px 15px rgba(0,0,0,.6);
  }
  .ft-opt {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px 14px;
    background: none;
    border: none;
    cursor: pointer;
    font-size: .8rem;
    color: var(--text-dim);
    transition: all .2s;
    touch-action: manipulation; /* prevent double-tap zoom */
  }
  .ft-opt + .ft-opt { border-top: 1px solid var(--border); }
  .ft-opt:hover, .ft-opt.on { color: var(--text); background: var(--bg2); }
  .ft-opt-serif { font-family: 'Noto Serif TC', serif; font-weight: 900; }
  .ft-opt-sans  { font-family: 'Noto Sans TC', sans-serif; font-weight: 700; }

  /* ─── Art Nav (bottom) ──────────────────────────────────── */
  .art-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 60px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    flex-wrap: nowrap;
  }
  .nav-pp {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Share Tech Mono', monospace;
    font-size: .7rem;
    letter-spacing: .1em;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-dim);
    padding: 10px 16px;
    cursor: pointer;
    transition: all .2s;
    white-space: nowrap;
    text-transform: uppercase;
    text-decoration: none;
    flex: 1;
    justify-content: center;
