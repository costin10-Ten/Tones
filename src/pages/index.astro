---
import Layout from '../layouts/Layout.astro';
import StoryCard from '../components/StoryCard.astro';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';
import { SignedIn, SignedOut, UserButton, SignInButton } from '@clerk/astro/components';
import { getCollection } from 'astro:content';

const allStories = await getCollection('stories', ({ data }) => data.published);
const stories = allStories.sort((a, b) => b.data.date.localeCompare(a.data.date));

const categories = ['全部', '記憶科技', '地下城市', 'AI社會', '生態復育', '情感科技', '🔍 彩蛋'];
---

<Layout>
  <!-- ─── Header ─── -->
  <header>
    <button class="logo-icon" id="leftSidebarBtn" aria-label="開啟導覽側欄">
      <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg"
        stroke="var(--text)" stroke-width="1.4" stroke-linejoin="round" stroke-linecap="round">
        <polygon points="14,2.5 20,6.5 20,13.5 14,17.5 8,13.5 8,6.5" fill="none"/>
        <polygon points="14,10.5 17.5,12.5 17.5,17 14,19 10.5,17 10.5,12.5" fill="none"/>
        <line x1="14" y1="2.5" x2="14" y2="10.5"/>
        <line x1="20" y1="6.5" x2="17.5" y2="12.5"/>
        <line x1="20" y1="13.5" x2="17.5" y2="17"/>
        <line x1="14" y1="17.5" x2="14" y2="19"/>
        <line x1="8" y1="13.5" x2="10.5" y2="17"/>
        <line x1="8" y1="6.5" x2="10.5" y2="12.5"/>
        <line x1="14" y1="19" x2="14" y2="25.5"/>
        <line x1="17.5" y1="17" x2="20.5" y2="21.5"/>
        <line x1="10.5" y1="17" x2="7.5" y2="21.5"/>
        <line x1="14" y1="25.5" x2="20.5" y2="21.5"/>
        <line x1="14" y1="25.5" x2="7.5" y2="21.5"/>
      </svg>
    </button>

    <a href="/" class="logo-text-btn">弦音<em>異象</em></a>

    <nav class="top-nav">
      <a class="nav-a" data-cat="記憶科技" href="#world">精神汙染</a>
      <a class="nav-a" data-cat="地下城市" href="#world">深淵建築</a>
      <a class="nav-a" data-cat="AI社會" href="#world">人工意識</a>
      <a class="nav-a" data-cat="生態復育" href="#world">異變生態</a>
    </nav>

    <ThemeSwitcher />

    <SignedOut>
      <a href="/sign-in" class="nav-a" style="border-color:var(--accent);color:var(--accent)">登入</a>
    </SignedOut>
    <SignedIn>
      <a href="/member" class="nav-a" style="white-space:nowrap">觀測者檔案</a>
      <UserButton afterSignOutUrl="/" />
    </SignedIn>

    <button class="burger" id="rightSidebarBtn" aria-label="開啟通訊側欄">
      <span></span><span></span><span></span>
    </button>
  </header>

  <!-- ─── Sidebar Overlay ─── -->
  <div class="sidebar-overlay" id="sbOverlay"></div>

  <!-- ─── Left Sidebar ─── -->
  <div class="sidebar left" id="leftSidebar" role="dialog" aria-label="檔案庫導覽">
    <div class="sb-drag" id="leftSidebarClose"></div>
    <div class="sb-head">
      <span class="sb-logo-text">檔案庫<em>導覽</em></span>
      <button class="sb-close" id="leftSidebarCloseBtn">[X]</button>
    </div>
    <div class="sb-body">
      <div class="sb-section">主目錄</div>
      <a href="#stories" class="sb-link">> 最新文章</a>
      <a href="#world" class="sb-link">> 犯罪類別篩選</a>
      <a href="/about" class="sb-link">> 關於作者</a>
      <a href="/history" class="sb-link">> 網站發展史</a>
      <SignedIn>
        <a href="/member" class="sb-link sb-link-bold">> 觀測者檔案</a>
      </SignedIn>
      <SignedOut>
        <a href="/sign-in" class="sb-link sb-link-bold" style="color:var(--accent)">> 登入系統</a>
        <a href="/sign-up" class="sb-link">> 申請觀測者身份</a>
      </SignedOut>

      <div class="sb-section" style="margin-top:32px">系統數據</div>
      <div class="sb-stat-box">
        <span class="sb-stat-lbl">已歸檔案件</span>
        <span class="sb-stat-val">{stories.length}</span>
      </div>
      <div class="sb-stat-box">
        <span class="sb-stat-lbl">最新更新</span>
        <span class="sb-stat-val" style="font-size:.8rem">{stories[0]?.data.date ?? '—'}</span>
      </div>
      <div class="sb-stat-box">
        <span class="sb-stat-lbl">累積瀏覽次數</span>
        <span class="sb-stat-val" id="sbTotalViews">—</span>
      </div>
      <div class="sb-stat-box">
        <span class="sb-stat-lbl">累積金幣</span>
        <span class="sb-stat-val" id="sbTotalTokens">—</span>
      </div>

      <div class="sb-section" style="margin-top:32px">閱讀模式</div>
      <button class="sb-plain-btn" id="sbPlainBtn" style="touch-action:manipulation">
        <span id="sbPlainIcon">≡</span>
        <span id="sbPlainLbl">純文字模式</span>
        <span id="sbPlainStatus" class="sb-plain-status">關</span>
      </button>

      <div class="sb-section" style="margin-top:32px">視覺覆寫濾鏡</div>
      <div class="sb-theme-grid">
        {[
          ['dark','闇夜'], ['clinical','臨床'], ['biohazard','生化'], ['fog','迷霧'],
          ['dossier','卷宗'], ['abyss','窒息'], ['cctv','監視'], ['noir','漆黑'],
        ].map(([name, label]) => (
          <button class="sb-theme-btn" data-sb={name}>
            <div class={`sb-dot ${name}`}></div>
            <div class="sb-theme-name">{label}</div>
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- ─── Right Sidebar ─── -->
  <div class="sidebar right" id="rightSidebar" role="dialog" aria-label="通訊頻道">
    <div class="sb-drag" id="rightSidebarClose"></div>
    <div class="sb-head">
      <span class="sb-logo-text">通訊<em>頻道</em></span>
      <button class="sb-close" id="rightSidebarCloseBtn">[X]</button>
    </div>
    <div class="sb-body">
      <div class="sb-section">作者通訊頻道</div>
      <div class="msg-box">
        <p style="font-size:0.75rem;color:var(--text-dim);margin-bottom:12px;">
          // 如果你發現了系統漏洞，或者想對作者說些什麼，請在這裡留言。訊號可能會被攔截，但我會看到的。
        </p>
        <textarea id="authorMsg" class="msg-textarea" rows="4" placeholder="請輸入加密訊息..."></textarea>
        <button class="msg-btn" id="sendMsgBtn">[ 發送訊號 ]</button>
        <div id="msgStatus" class="msg-status"></div>
      </div>

      <div class="sb-section" style="margin-top:20px">近期攔截訊息</div>
      <div class="rsb-list">
        {stories.slice(0, 5).map(story => (
          <a href={`/stories/${story.slug}`} class="rsb-item">
            <div class="rsb-title">{story.data.title}</div>
            <div class="rsb-tags">{story.data.tags.join(', ')}</div>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- ─── Hero ─── -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-grid"></div>
    <div class="hero-content">
      <div class="hero-tag">CONFIDENTIAL · CASE FILE 2045</div>
      <h1 class="hero-title">
        每個通勤的早晨<br>
        <span class="line2">直視深淵的邊緣</span>
        <span class="line3">心理驚悚 · 推理短篇 · 車廂文學</span>
      </h1>
      <p class="hero-desc">
        五分鐘，一個細思極恐的故事，一塊拼湊瘋狂的碎片。<br>
        當你滑到網頁最底端時——你將發現真正的怪物，<span class="redacted">就站在你身後</span>。
      </p>
      <div class="hero-actions">
        <button class="btn-primary" id="unlockBtn" data-href={`/stories/${stories[0]?.slug ?? ''}`}>[ 解鎖第一份卷宗 ]</button>
        <button class="btn-ghost" id="contactBtn">[ 聯繫作者 ]</button>
      </div>
    </div>
    <div class="hero-stats">
      <div class="stat"><span class="stat-num">{stories.length}</span><div class="stat-label">已歸檔案件</div></div>
      <div class="stat"><span class="stat-num">∞</span><div class="stat-label">目擊者數量</div></div>
      <div class="stat"><span class="stat-num">0</span><div class="stat-label">沒收證物</div></div>
      <div class="stat"><span class="stat-num">∞</span><div class="stat-label">未解之謎</div></div>
    </div>
  </section>

  <!-- ─── Main Content ─── -->
  <main>
    <section class="section" id="stories">
      <div class="sec-hd">
        <div class="sec-title">高危險級檔案</div>
        <a href="/stories" class="see-all">[ 展開全部 ]</a>
      </div>

      <!-- Category Filter (client island) -->
      <div class="tags-row" id="filterRow">
        {categories.map((cat, i) => (
          <button class={`tag-btn${i === 0 ? ' on' : ''}`} data-cat={cat}>
            {cat === '全部' ? '全部' :
             cat === '記憶科技' ? '精神汙染' :
             cat === '地下城市' ? '深淵建築' :
             cat === 'AI社會' ? '人工意識' :
             cat === '生態復育' ? '異變生態' :
             cat === '情感科技' ? '情緒操縱' :
             cat === '🔍 彩蛋' ? '[ 最高機密 ]' : cat}
          </button>
        ))}
      </div>

      <div class="cards-grid" id="storiesGrid">
        {stories.map(story => (
          <StoryCard
            title={story.data.title}
            fileNum={story.data.fileNum}
            date={story.data.date}
            readTime={story.data.readTime}
            tags={story.data.tags}
            level={story.data.level}
            excerpt={story.data.excerpt}
            vis={story.data.vis}
            icon={story.data.icon}
            slug={story.slug}
          />
        ))}
      </div>

      <div id="noResults" style="display:none;text-align:center;padding:40px 0;">
        <p style="color:var(--danger);font-size:.85rem;font-family:'Share Tech Mono',monospace;">
          [ 查無符合權限的檔案 ]
        </p>
      </div>
    </section>

    <hr class="divider" />

    <section class="section" id="world">
      <div class="sec-hd"><div class="sec-title">異常類別索引</div></div>
      <p style="font-size:.8rem;color:var(--text-muted);font-family:'Share Tech Mono',monospace;letter-spacing:.05em;margin-top:16px;">
        // 警告：交叉比對上述案件可能導致嚴重的認知失調。請謹慎閱讀。
      </p>
    </section>
  </main>

  <!-- ─── Unlock Modal ─── -->
  <div class="modal-overlay" id="unlockModal" role="dialog" aria-modal="true" aria-label="開始閱讀">
    <div class="modal-box">
      <div class="modal-tag">ACCESS CONTROL</div>
      <div class="modal-title">進入異象檔案庫</div>
      <p class="modal-desc">
        登入後可解鎖限制級卷宗，追蹤閱讀紀錄，<br>
        並在所有設備間同步金幣。
      </p>
      <div class="modal-actions">
        <a href="/sign-in" class="modal-btn-primary">[ 登入 / 註冊 ]</a>
        <button class="modal-btn-ghost" id="skipLoginBtn">不登入，直接開始閱讀</button>
      </div>
      <button class="modal-close" id="closeModalBtn" aria-label="關閉">[X]</button>
    </div>
  </div>

  <!-- ─── Footer ─── -->
  <footer>
    <div class="ft-logo">弦音<em>異象</em></div>
    <div class="ft-txt">
      ANOMALY ARCHIVES · CLASSIFIED<br>
      一切皆為虛構，除非你相信。
    </div>
  </footer>
</Layout>

<script>
  function fmtN(n: number) { return n >= 1000 ? (n / 1000).toFixed(1) + 'K' : String(n); }
  function sGet(k: string) { try { return localStorage.getItem(k); } catch(e) { return null; } }
  function sSet(k: string, v: string) { try { localStorage.setItem(k, v); } catch(e) {} }

  // AbortController used to clean up all listeners when initHomepage re-runs
  let _hpCleanup: AbortController | null = null;

  function initHomepage() {
    // Abort previous listeners so re-runs don't stack up
    if (_hpCleanup) _hpCleanup.abort();
    _hpCleanup = new AbortController();
    const sig = _hpCleanup.signal;

    // ─── Sidebar open/close ─────────────────────────────────
    const overlay = document.getElementById('sbOverlay');
    const leftSb  = document.getElementById('leftSidebar');
    const rightSb = document.getElementById('rightSidebar');
    if (!overlay || !leftSb || !rightSb) return;

    function openLeft()  { leftSb!.classList.add('open');  overlay!.classList.add('open'); document.body.style.overflow = 'hidden'; }
    function openRight() { rightSb!.classList.add('open'); overlay!.classList.add('open'); document.body.style.overflow = 'hidden'; }
    function closeAll()  {
      leftSb!.classList.remove('open'); rightSb!.classList.remove('open');
      overlay!.classList.remove('open'); document.body.style.overflow = '';
    }

    document.getElementById('leftSidebarBtn')?.addEventListener('click', openLeft, { signal: sig });
    document.getElementById('rightSidebarBtn')?.addEventListener('click', openRight, { signal: sig });
    document.getElementById('contactBtn')?.addEventListener('click', openRight, { signal: sig });
    document.getElementById('leftSidebarCloseBtn')?.addEventListener('click', closeAll, { signal: sig });
    document.getElementById('rightSidebarCloseBtn')?.addEventListener('click', closeAll, { signal: sig });
    overlay.addEventListener('click', closeAll, { signal: sig });
    document.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Escape') closeAll(); }, { signal: sig });

    // ─── Swipe to dismiss sidebars ──────────────────────────
    let sbTouchX = 0;
    function addSwipeDismiss(el: HTMLElement, dir: 'left' | 'right') {
      el.addEventListener('touchstart', (e: TouchEvent) => { sbTouchX = e.touches[0].clientX; }, { passive: true, signal: sig } as AddEventListenerOptions);
      el.addEventListener('touchend', (e: TouchEvent) => {
        const dx = e.changedTouches[0].clientX - sbTouchX;
        if (dir === 'left'  && dx < -50) closeAll();
        if (dir === 'right' && dx >  50) closeAll();
      }, { passive: true, signal: sig } as AddEventListenerOptions);
    }
    addSwipeDismiss(leftSb as HTMLElement,  'left');
    addSwipeDismiss(rightSb as HTMLElement, 'right');

    // ─── Sidebar stats from localStorage ───────────────────
    {
      let totalViews = 0, totalTokens = 0;
      try {
        for (let i = 0; i < localStorage.length; i++) {
          const k = localStorage.key(i);
          if (!k?.startsWith('story:')) continue;
          const d = JSON.parse(localStorage.getItem(k) || '{}');
          totalViews  += d.views  || 0;
          totalTokens += d.tokens || 0;
        }
      } catch(_) {}
      const vEl = document.getElementById('sbTotalViews');
      const tEl = document.getElementById('sbTotalTokens');
      if (vEl) vEl.textContent = fmtN(totalViews);
      if (tEl) tEl.textContent = fmtN(totalTokens);
    }

    // ─── Pure text mode toggle ──────────────────────────────
    const plainBtn    = document.getElementById('sbPlainBtn');
    const plainStatus = document.getElementById('sbPlainStatus');
    let plainMode = sGet('hz-plain') === '1';

    function updatePlainBtn() {
      if (!plainStatus) return;
      plainStatus.textContent = plainMode ? '開' : '關';
      plainBtn?.classList.toggle('on', plainMode);
    }
    updatePlainBtn();

    plainBtn?.addEventListener('click', () => {
      plainMode = !plainMode;
      sSet('hz-plain', plainMode ? '1' : '0');
      updatePlainBtn();
    }, { signal: sig });

    // ─── Sidebar theme buttons ──────────────────────────────
    document.querySelectorAll<HTMLButtonElement>('.sb-theme-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const t = btn.dataset.sb ?? 'dark';
        document.documentElement.setAttribute('data-theme', t);
        sSet('hz-theme', t);
        document.querySelectorAll('.sb-theme-btn').forEach(b => b.classList.toggle('on', b === btn));
      }, { signal: sig });
    });
    {
      const saved = sGet('hz-theme') ?? 'dark';
      document.querySelector(`.sb-theme-btn[data-sb="${saved}"]`)?.classList.add('on');
    }

    // ─── Unlock modal ───────────────────────────────────────
    const unlockModal = document.getElementById('unlockModal');
    const unlockBtn   = document.getElementById('unlockBtn') as HTMLButtonElement | null;
    const storyHref   = unlockBtn?.dataset.href ?? '/stories';

    function openModal()  { unlockModal?.classList.add('open'); document.body.style.overflow = 'hidden'; }
    function closeModal() { unlockModal?.classList.remove('open'); document.body.style.overflow = ''; }

    unlockBtn?.addEventListener('click', openModal, { signal: sig });
    document.getElementById('closeModalBtn')?.addEventListener('click', closeModal, { signal: sig });
    document.getElementById('skipLoginBtn')?.addEventListener('click', () => {
      closeModal();
      if (plainMode && storyHref.match(/^\/stories\/[^/]+$/)) {
        window.location.href = storyHref + '/plain';
      } else {
        window.location.href = storyHref;
      }
    }, { signal: sig });
    unlockModal?.addEventListener('click', (e) => { if (e.target === unlockModal) closeModal(); }, { signal: sig });

    // ─── Category filter ────────────────────────────────────
    // Tag data is stored on cards so filtering works after re-init
    document.querySelectorAll<HTMLElement>('.story-card').forEach(card => {
      if (!card.dataset.tags) {
        card.dataset.tags = Array.from(card.querySelectorAll('.tag')).map(t => t.textContent?.trim() ?? '').join(',');
      }
    });

    function applyFilter(cat: string) {
      sSet('hz-cat', cat);
      document.querySelectorAll<HTMLElement>('.tag-btn').forEach(b => b.classList.toggle('on', b.dataset.cat === cat));
      let visible = 0;
      document.querySelectorAll<HTMLElement>('.story-card').forEach(card => {
        const tags = card.dataset.tags?.split(',') ?? [];
        const show = cat === '全部' || tags.includes(cat);
        card.style.display = show ? 'block' : 'none';
        if (show) visible++;
      });
      const noRes = document.getElementById('noResults');
      if (noRes) noRes.style.display = visible === 0 ? 'block' : 'none';
    }

    document.querySelectorAll<HTMLButtonElement>('.tag-btn').forEach(btn => {
      btn.addEventListener('click', () => applyFilter(btn.dataset.cat ?? '全部'), { signal: sig });
    });

    // Restore saved category selection
    {
      const savedCat = sGet('hz-cat') ?? '全部';
      if (savedCat !== '全部') applyFilter(savedCat);
    }

    // ─── Message send (mock) ────────────────────────────────
    document.getElementById('sendMsgBtn')?.addEventListener('click', () => {
      const ta = document.getElementById('authorMsg') as HTMLTextAreaElement | null;
      const st = document.getElementById('msgStatus');
      if (!ta || !st) return;
      if (!ta.value.trim()) {
        st.style.color = 'var(--danger)';
        st.textContent = '[ 錯誤：無法發送空訊號 ]';
      } else {
        st.style.color = 'var(--accent)';
        st.textContent = '[ 訊號已加密傳送。觀測者會收到的。 ]';
        ta.value = '';
      }
      st.style.display = 'block';
      setTimeout(() => { if (st) st.style.display = 'none'; }, 4000);
    }, { signal: sig });
  }

  initHomepage();
  document.addEventListener('astro:after-swap', initHomepage);
</script>

<style>
  /* ─── Header ─────────────────────────────────────── */
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 16px;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    gap: 10px;
  }
  button.logo-icon {
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  button.logo-icon svg { width: 28px; height: 28px; }
  button.logo-icon:hover svg { stroke: var(--accent); }
  a.logo-text-btn {
    font-family: 'Noto Serif TC', serif;
    font-weight: 900;
    font-size: 1.1rem;
    color: var(--text);
    text-decoration: none;
    letter-spacing: 0.1em;
    flex-shrink: 0;
  }
  a.logo-text-btn em { color: var(--accent); font-style: normal; }
  .top-nav {
    display: flex;
    gap: 2px;
    flex: 1;
    justify-content: center;
  }
  .nav-a {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--text-dim);
    text-decoration: none;
    padding: 5px 8px;
    border: 1px solid transparent;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .nav-a:hover { border-color: var(--border); color: var(--text); }
  .burger {
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    flex-shrink: 0;
  }
  .burger span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--text);
    transition: all 0.2s;
  }
  .burger:hover span { background: var(--accent); }

  /* ─── Sidebar Overlay ─────────────────────────────── */
  .sidebar-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.75);
    z-index: 200;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }
  .sidebar-overlay.open { opacity: 1; pointer-events: all; }

  /* ─── Sidebars ─────────────────────────────────────── */
  .sidebar {
    position: fixed;
    top: 0;
    bottom: 0;
    width: 300px;
    max-width: 85vw;
    z-index: 300;
    background: var(--bg);
    overflow-y: auto;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
  }
  .sidebar.left  { left: 0;  transform: translateX(-100%); border-right: 1px solid var(--accent); }
