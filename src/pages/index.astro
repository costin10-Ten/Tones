---
import Layout from '../layouts/Layout.astro';
import StoryCard from '../components/StoryCard.astro';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';
import { SignedIn, SignedOut, UserButton, SignInButton } from '@clerk/astro/components';
import { getCollection } from 'astro:content';

const allStories = await getCollection('stories', ({ data }) => data.published);
const stories = allStories.sort((a, b) => b.data.date.localeCompare(a.data.date));

const categories = ['全部', '記憶科技', '地下城市', 'AI社會', '生態復育', '情感科技', '🔍 彩蛋'];

// For stats: compute inaccessible story count (restricted/top-secret/paid)
const inaccessibleCount = stories.filter(s =>
  s.data.level === 'restricted' || s.data.level === 'top-secret' || s.data.level === 'paid'
).length;
const totalStories = stories.length;

// Minimal story map for client-side resume card
const storiesMapJson = JSON.stringify(
  Object.fromEntries(allStories.map(s => [s.slug, { fileNum: s.data.fileNum, title: s.data.title }]))
);

// Site-curated lists for sidebar
const curatedLists = [
  { id: 'starter',  label: '入門推薦', icon: '◈', slugs: stories.filter(s => s.data.level === 'public').slice(0, 5).map(s => s.slug) },
  { id: 'thriller', label: '深度驚悚', icon: '⊕', slugs: stories.filter(s => s.data.tags.some(t => ['記憶科技','AI社會'].includes(t))).slice(0, 6).map(s => s.slug) },
];
const paidStories = stories.filter(s => s.data.level === 'paid');
---

<Layout>
  <!-- ─── Header ─── -->
  <header>
    <button class="logo-icon" id="leftSidebarBtn" aria-label="開啟導覽側欄">
      <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg"
        stroke="var(--text)" stroke-width="1.4" stroke-linejoin="round" stroke-linecap="round">
        <polygon points="14,2.5 20,6.5 20,13.5 14,17.5 8,13.5 8,6.5" fill="none"/>
        <polygon points="14,10.5 17.5,12.5 17.5,17 14,19 10.5,17 10.5,12.5" fill="none"/>
        <line x1="14" y1="2.5" x2="14" y2="10.5"/>
        <line x1="20" y1="6.5" x2="17.5" y2="12.5"/>
        <line x1="20" y1="13.5" x2="17.5" y2="17"/>
        <line x1="14" y1="17.5" x2="14" y2="19"/>
        <line x1="8" y1="13.5" x2="10.5" y2="17"/>
        <line x1="8" y1="6.5" x2="10.5" y2="12.5"/>
        <line x1="14" y1="19" x2="14" y2="25.5"/>
        <line x1="17.5" y1="17" x2="20.5" y2="21.5"/>
        <line x1="10.5" y1="17" x2="7.5" y2="21.5"/>
        <line x1="14" y1="25.5" x2="20.5" y2="21.5"/>
        <line x1="14" y1="25.5" x2="7.5" y2="21.5"/>
      </svg>
    </button>

    <a href="/" class="logo-text-btn">弦音<em>異象</em></a>

    <nav class="top-nav">
      <a class="nav-a" data-cat="記憶科技" href="#world">精神汙染</a>
      <a class="nav-a" data-cat="地下城市" href="#world">深淵建築</a>
      <a class="nav-a" data-cat="AI社會" href="#world">人工意識</a>
      <a class="nav-a" data-cat="生態復育" href="#world">異變生態</a>
    </nav>

    <ThemeSwitcher />

    <SignedOut>
      <a href="/sign-in" class="nav-a" style="border-color:var(--accent);color:var(--accent)">登入</a>
    </SignedOut>
    <SignedIn>
      <a href="/member" class="nav-a" style="white-space:nowrap">會員資料</a>
      <UserButton afterSignOutUrl="/" />
    </SignedIn>

    <button class="burger" id="rightSidebarBtn" aria-label="開啟通訊側欄">
      <span></span><span></span><span></span>
    </button>
  </header>

  <!-- ─── Sidebar Overlay ─── -->
  <div class="sidebar-overlay" id="sbOverlay"></div>

  <!-- ─── Left Sidebar ─── -->
  <div class="sidebar left" id="leftSidebar" role="dialog" aria-label="檔案庫導覽">
    <div class="sb-drag" id="leftSidebarClose"></div>
    <div class="sb-head">
      <span class="sb-logo-text">檔案庫<em>導覽</em></span>
      <button class="sb-close" id="leftSidebarCloseBtn">[X]</button>
    </div>
    <div class="sb-body">
      <div class="sb-section">主目錄</div>
      <a href="#stories" class="sb-link">> 最新文章</a>
      <a href="#stories" class="sb-link">> 犯罪類別篩選</a>
      <a href="/about" class="sb-link">> 關於作者</a>
      <a href="/history" class="sb-link">> 網站發展史</a>
      <SignedIn>
        <a href="/member" class="sb-link sb-link-bold">> 會員資料</a>
      </SignedIn>
      <SignedOut>
        <a href="/sign-in" class="sb-link sb-link-bold" style="color:var(--accent)">> 登入系統</a>
        <a href="/sign-up" class="sb-link">> 申請觀測者身份</a>
      </SignedOut>

      <!-- ─── My Lists (logged-in, populated by JS) ─── -->
      <SignedIn>
        <div class="sb-section" style="margin-top:24px">我的清單</div>
        <div id="sbMyLists">
          <span class="sb-list-loading">載入中…</span>
        </div>
        <a href="/stories" class="sb-link sb-link-manage">> 管理所有清單</a>
      </SignedIn>

      <!-- ─── Site Curated Lists ─── -->
      <div class="sb-section" style="margin-top:24px">站內精選</div>
      {curatedLists.map(list => (
        <a href={`/stories?curated=${list.id}`} class="sb-link">
          > {list.icon} {list.label}
          <span class="sb-list-cnt">{list.slugs.length}</span>
        </a>
      ))}

      <!-- ─── Paid Zone ─── -->
      {paidStories.length > 0 && (
        <>
          <div class="sb-section" style="margin-top:24px">付費專區</div>
          <SignedIn>
            {paidStories.slice(0, 3).map(s => (
              <a href={`/stories/${s.slug}`} class="sb-link sb-link-paid">
                > ⎔ {s.data.title}
              </a>
            ))}
            {paidStories.length > 3 && (
              <a href="/stories" class="sb-link sb-link-manage">> 還有 {paidStories.length - 3} 篇…</a>
            )}
          </SignedIn>
          <SignedOut>
            <div class="sb-paid-note">登入後查看付費內容</div>
            <a href="/sign-in" class="sb-link" style="color:var(--accent)">> 登入解鎖 →</a>
          </SignedOut>
        </>
      )}

      <div class="sb-section" style="margin-top:32px">系統數據</div>
      <div class="sb-stat-box">
        <span class="sb-stat-lbl">已歸檔案件</span>
        <span class="sb-stat-val">{stories.length}</span>
      </div>
      <div class="sb-stat-box">
        <span class="sb-stat-lbl">最新更新</span>
        <span class="sb-stat-val" style="font-size:.8rem">{stories[0]?.data.date ?? '—'}</span>
      </div>
      <div class="sb-stat-box">
        <span class="sb-stat-lbl">累積瀏覽次數</span>
        <span class="sb-stat-val" id="sbTotalViews">—</span>
      </div>
      <div class="sb-stat-box">
        <span class="sb-stat-lbl">累積金幣</span>
        <span class="sb-stat-val" id="sbTotalTokens">—</span>
      </div>

      <div class="sb-section" style="margin-top:32px">閱讀模式</div>
      <button class="sb-plain-btn" id="sbPlainBtn" style="touch-action:manipulation">
        <span id="sbPlainIcon">≡</span>
        <span id="sbPlainLbl">純文字模式</span>
        <span id="sbPlainStatus" class="sb-plain-status">關</span>
      </button>

      <div class="sb-section" style="margin-top:32px">視覺覆寫濾鏡</div>
      <div class="sb-theme-grid">
        {[
          ['dark','闇夜'], ['clinical','臨床'], ['biohazard','生化'], ['fog','迷霧'],
          ['dossier','卷宗'], ['abyss','窒息'], ['cctv','監視'], ['noir','漆黑'],
        ].map(([name, label]) => (
          <button class="sb-theme-btn" data-sb={name}>
            <div class={`sb-dot ${name}`}></div>
            <div class="sb-theme-name">{label}</div>
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- ─── Right Sidebar ─── -->
  <div class="sidebar right" id="rightSidebar" role="dialog" aria-label="通訊頻道">
    <div class="sb-drag" id="rightSidebarClose"></div>
    <div class="sb-head">
      <span class="sb-logo-text">通訊<em>頻道</em></span>
      <button class="sb-close" id="rightSidebarCloseBtn">[X]</button>
    </div>
    <div class="sb-body">
      <div class="sb-section">作者通訊頻道</div>
      <div class="msg-box">
        <p style="font-size:0.75rem;color:var(--text-dim);margin-bottom:12px;">
          // 如果你發現了系統漏洞，或者想對作者說些什麼，請在這裡留言。訊號可能會被攔截，但我會看到的。
        </p>
        <textarea id="authorMsg" class="msg-textarea" rows="4" placeholder="請輸入加密訊息..."></textarea>
        <button class="msg-btn" id="sendMsgBtn">[ 發送訊號 ]</button>
        <div id="msgStatus" class="msg-status"></div>
      </div>

      <div class="sb-section" style="margin-top:20px">近期攔截訊息</div>
      <div class="rsb-list">
        {stories.slice(0, 5).map(story => (
          <a href={`/stories/${story.slug}`} class="rsb-item">
            <div class="rsb-title">{story.data.title}</div>
            <div class="rsb-tags">{story.data.tags.join(', ')}</div>
          </a>
        ))}
      </div>
      <a href="/stories" class="rsb-more">[ 更多文章 → ]</a>
    </div>
  </div>

  <!-- ─── Hero ─── -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-grid"></div>
    <div class="hero-content">
      <div class="hero-tag">CONFIDENTIAL · CASE FILE 2045</div>
      <h1 class="hero-title">
        每個通勤的早晨<br>
        <span class="line2">直視深淵的邊緣</span>
        <span class="line3">心理驚悚 · 推理短篇 · 車廂文學</span>
      </h1>
      <p class="hero-desc">
        五分鐘，一個細思極恐的故事，一塊拼湊瘋狂的碎片。<br>
        當你滑到網頁最底端時——你將發現真正的怪物，<strong>就站在你身後</strong>。
      </p>
      <div class="hero-actions">
        <SignedIn>
          <a href={`/stories/${stories[0]?.slug ?? ''}`} class="btn-primary" id="resumeBtn">[ 繼續閱讀 ]</a>
          <!-- Resume info strip (populated by JS) -->
          <div class="resume-strip" id="resumeStrip" style="display:none">
            <div class="rs-top">
              <span class="rs-filenum" id="rsFileNum"></span>
              <span class="rs-title" id="rsTitle"></span>
            </div>
            <div class="rs-prog-wrap">
              <div class="rs-prog-fill" id="rsProgFill"></div>
              <span class="rs-pct" id="rsPct"></span>
            </div>
            <span class="rs-list" id="rsList" style="display:none"></span>
          </div>
        </SignedIn>
        <SignedOut>
          <button class="btn-primary" id="unlockBtn" data-href={`/stories/${stories[0]?.slug ?? ''}`}>[ 解鎖第一份卷宗 ]</button>
        </SignedOut>
        <button class="btn-ghost" id="contactBtn">[ 聯繫作者 ]</button>
      </div>
    </div>
    <div class="hero-stats">
      <div class="stat"><span class="stat-num">{stories.length}</span><div class="stat-label">已歸檔案件</div></div>
      <div class="stat"><span class="stat-num" id="statViewers">∞</span><div class="stat-label">目擊者數量</div></div>
      <div class="stat"><span class="stat-num" id="statCoins">∞</span><div class="stat-label">金幣總量</div></div>
      <div class="stat"><span class="stat-num" id="statMysteries">∞</span><div class="stat-label">未解之謎</div></div>
    </div>
  </section>

  <!-- ─── Main Content ─── -->
  <main>
    <section class="section" id="stories">
      <div class="sec-hd">
        <div class="sec-title">高危險級檔案</div>
        <a href="/stories" class="see-all">[ 展開全部 ]</a>
      </div>

      <!-- Category Filter (client island) -->
      <div class="tags-row" id="filterRow">
        {categories.map((cat, i) => (
          <button class={`tag-btn${i === 0 ? ' on' : ''}`} data-cat={cat}>
            {cat === '全部' ? '全部' :
             cat === '記憶科技' ? '精神汙染' :
             cat === '地下城市' ? '深淵建築' :
             cat === 'AI社會' ? '人工意識' :
             cat === '生態復育' ? '異變生態' :
             cat === '情感科技' ? '情緒操縱' :
             cat === '🔍 彩蛋' ? '[ 最高機密 ]' : cat}
          </button>
        ))}
      </div>

      <div class="cards-grid" id="storiesGrid">
        {stories.map(story => (
          <StoryCard
            title={story.data.title}
            fileNum={story.data.fileNum}
            date={story.data.date}
            readTime={story.data.readTime}
            tags={story.data.tags}
            level={story.data.level}
            excerpt={story.data.excerpt}
            vis={story.data.vis}
            icon={story.data.icon}
            slug={story.slug}
            featured={story.data.featured}
          />
        ))}
      </div>

      <div id="noResults" style="display:none;text-align:center;padding:40px 0;">
        <p style="color:var(--danger);font-size:.85rem;font-family:'Share Tech Mono',monospace;">
          [ 查無符合權限的檔案 ]
        </p>
      </div>
    </section>

    <hr class="divider" />

    <section class="section" id="world">
      <div class="sec-hd">
        <div class="sec-title">異常類別索引</div>
        <span class="sec-badge" id="mmBadge">限會員</span>
      </div>
      <p class="mm-warning">
        // 警告：交叉比對上述案件可能導致嚴重的認知失調。節點間的連線代表尚未公開的關聯性。
      </p>

      <!-- Mind Map -->
      <div class="mindmap-wrap" id="mindmapWrap">
        <!-- Locked overlay for non-members -->
        <div class="mm-lock" id="mmLock">
          <div class="mm-lock-inner">
            <div class="mm-lock-icon">⊘</div>
            <div class="mm-lock-title">存取受限</div>
            <p class="mm-lock-desc">觀測者身份驗證後，可解鎖異象關聯圖，<br>發現隱藏在卷宗之間的真正聯繫。</p>
            <a href="/sign-in" class="mm-lock-btn">[ 登入以解鎖 ]</a>
          </div>
        </div>
        <!-- SVG canvas -->
        <svg class="mindmap-svg" id="mindmapSvg" viewBox="0 0 900 520" preserveAspectRatio="xMidYMid meet">
          <defs>
            <marker id="arrow" viewBox="0 0 8 8" refX="6" refY="3" markerWidth="5" markerHeight="5" orient="auto">
              <path d="M0,0 L0,6 L8,3 z" fill="var(--accent)" opacity="0.4"/>
            </marker>
            <filter id="glow">
              <feGaussianBlur stdDeviation="2.5" result="blur"/>
              <feComposite in="SourceGraphic" in2="blur" operator="over"/>
            </filter>
          </defs>
          <!-- Edges drawn by JS -->
          <g id="mmEdges"></g>
          <!-- Nodes drawn by JS -->
          <g id="mmNodes"></g>
        </svg>
        <!-- Tooltip -->
        <div class="mm-tooltip" id="mmTooltip"></div>
      </div>

      <!-- Legend -->
      <div class="mm-legend" id="mmLegend">
        <div class="mm-legend-item"><span class="mm-dot" style="background:#d90429"></span>記憶科技</div>
        <div class="mm-legend-item"><span class="mm-dot" style="background:#00b4d8"></span>地下城市</div>
        <div class="mm-legend-item"><span class="mm-dot" style="background:#15803d"></span>生態復育</div>
        <div class="mm-legend-item"><span class="mm-dot" style="background:#7c3aed"></span>AI社會</div>
        <div class="mm-legend-item"><span class="mm-dot" style="background:#ff5400"></span>情感科技</div>
        <div class="mm-legend-item"><span class="mm-dot" style="background:#ffea00"></span>🔍 彩蛋</div>
      </div>
    </section>
  </main>

  <!-- ─── Unlock Modal ─── -->
  <div class="modal-overlay" id="unlockModal" role="dialog" aria-modal="true" aria-label="開始閱讀">
    <div class="modal-box">
      <div class="modal-tag">ACCESS CONTROL</div>
      <div class="modal-title">進入異象檔案庫</div>
      <p class="modal-desc">
        登入後可解鎖限制級卷宗，追蹤閱讀紀錄，<br>
        並在所有設備間同步金幣。
      </p>
      <div class="modal-actions">
        <a href="/sign-in" class="modal-btn-primary">[ 登入 / 註冊 ]</a>
        <button class="modal-btn-ghost" id="skipLoginBtn">不登入，直接開始閱讀</button>
      </div>
      <button class="modal-close" id="closeModalBtn" aria-label="關閉">[X]</button>
    </div>
  </div>

  <!-- ─── Newsletter ─── -->
  <section class="newsletter-section">
    <div class="newsletter-inner">
      <div class="nl-label">訂閱異象通知</div>
      <p class="nl-desc">新案件解封時，第一時間通知你。</p>
      <form class="nl-form" id="nlForm">
        <input type="email" id="nlEmail" class="nl-input" placeholder="your@email.com" required />
        <button type="submit" class="nl-btn" id="nlBtn">訂閱</button>
      </form>
      <div id="nlMsg" class="nl-msg"></div>
    </div>
  </section>

  <!-- ─── Footer ─── -->
  <footer>
    <div class="ft-logo">弦音<em>異象</em></div>
    <div class="ft-txt">
      ANOMALY ARCHIVES · CLASSIFIED<br>
      一切皆為虛構，除非你相信。
    </div>
  </footer>

  <!-- Server-side variables for client script (avoids define:vars inline-script re-evaluation) -->
  <div id="hp-meta"
       data-logged-in="false"
       data-total={String(totalStories)}
       data-inaccessible={String(inaccessibleCount)}
       data-stories-map={storiesMapJson}
       hidden></div>
</Layout>

<script>
  function fmtN(n: number) { return n >= 1000 ? (n / 1000).toFixed(1) + 'K' : String(n); }
  function sGet(k: string) { try { return localStorage.getItem(k); } catch(e) { return null; } }
  function sSet(k: string, v: string) { try { localStorage.setItem(k, v); } catch(e) {} }

  // Read server-side values from DOM (updated by each SPA page swap)
  function getHpMeta() {
    const el = document.getElementById('hp-meta');
    return {
      isLoggedIn:       el?.dataset.loggedIn === 'true',
      totalStories:     parseInt(el?.dataset.total      ?? '0', 10),
      inaccessibleCount: parseInt(el?.dataset.inaccessible ?? '0', 10),
    };
  }

  // ─── Resume button + strip: update href & show progress ───
  {
    const lastStory = sGet('hz-last-story');
    const resumeBtn  = document.getElementById('resumeBtn') as HTMLAnchorElement | null;
    const strip      = document.getElementById('resumeStrip') as HTMLElement | null;
    const rsFileNum  = document.getElementById('rsFileNum');
    const rsTitle    = document.getElementById('rsTitle');
    const rsProgFill = document.getElementById('rsProgFill') as HTMLElement | null;
    const rsPct      = document.getElementById('rsPct');
    const rsList     = document.getElementById('rsList') as HTMLElement | null;

    if (resumeBtn && lastStory) {
      resumeBtn.href = '/stories/' + lastStory + '?ref=home';

      const meta = document.getElementById('hp-meta');
      let storiesMap: Record<string, { fileNum: string; title: string }> = {};
      try { storiesMap = JSON.parse(meta?.dataset.storiesMap ?? '{}'); } catch (_) {}

      const info = storiesMap[lastStory];
      const pct  = parseInt(sGet('hz-progress:' + lastStory) || '0', 10);

      if (info && strip) {
        if (rsFileNum) rsFileNum.textContent = info.fileNum;
        if (rsTitle)   rsTitle.textContent   = info.title;
        if (rsProgFill) rsProgFill.style.width = pct + '%';
        if (rsPct)     rsPct.textContent     = pct + '%';

        try {
          const readlist = JSON.parse(sGet('hz-readlist') ?? '[]') as string[];
          if (readlist.length > 0 && rsList) {
            rsList.textContent = `閱讀清單 ${readlist.length} 件`;
            rsList.style.display = '';
          }
        } catch (_) {}

        strip.style.display = 'flex';
      }
    }
  }

  // ─── Update hero stats (全員可見全站統計) ──────────────────
  function updateHeroStats() {
    const { isLoggedIn, totalStories, inaccessibleCount } = getHpMeta();

    // 全站統計（所有人都顯示）
    fetch('/api/stats/global')
      .then(r => r.ok ? r.json() : Promise.reject())
      .then(data => {
        const viewersEl = document.getElementById('statViewers');
        const coinsEl   = document.getElementById('statCoins');
        if (viewersEl) viewersEl.textContent = fmtN(data.totalViews ?? 0);
        if (coinsEl)   coinsEl.textContent   = fmtN(data.totalTokens ?? 0);

        // Apply per-story view counts to homepage cards
        const perStory: Record<string, number> = data.perStory ?? {};
        document.querySelectorAll<HTMLElement>('.story-card[href]').forEach(card => {
          const slug = (card.getAttribute('href') ?? '').replace('/stories/', '').split('?')[0];
          if (!slug || perStory[slug] === undefined) return;
          const viewEl = card.querySelector<HTMLElement>('[title="瀏覽數"]');
          if (viewEl) viewEl.textContent = '👁 ' + fmtN(perStory[slug]);
        });
      })
      .catch(() => {});

  }
  updateHeroStats();

  // AbortController as module-level variable — safe now that this is a proper module
  // (modules run once per session; astro:after-swap calls initHomepage on each navigation)
  let _hpCleanup: AbortController | null = null;

  function initHomepage() {
    if (_hpCleanup) _hpCleanup.abort();
    _hpCleanup = new AbortController();
    const sig = _hpCleanup.signal;

    // ─── Sidebar open/close ─────────────────────────────────
    const overlay = document.getElementById('sbOverlay');
    const leftSb  = document.getElementById('leftSidebar');
    const rightSb = document.getElementById('rightSidebar');
    if (!overlay || !leftSb || !rightSb) return;

    function openLeft()  { leftSb!.classList.add('open');  overlay!.classList.add('open'); document.body.style.overflow = 'hidden'; }
    function openRight() { rightSb!.classList.add('open'); overlay!.classList.add('open'); document.body.style.overflow = 'hidden'; }
    function closeAll()  {
      leftSb!.classList.remove('open'); rightSb!.classList.remove('open');
      overlay!.classList.remove('open'); document.body.style.overflow = '';
    }

    document.getElementById('leftSidebarBtn')?.addEventListener('click', openLeft, { signal: sig });
    document.getElementById('rightSidebarBtn')?.addEventListener('click', openRight, { signal: sig });
    document.getElementById('contactBtn')?.addEventListener('click', openRight, { signal: sig });
    document.getElementById('leftSidebarCloseBtn')?.addEventListener('click', closeAll, { signal: sig });
    document.getElementById('rightSidebarCloseBtn')?.addEventListener('click', closeAll, { signal: sig });
    overlay.addEventListener('click', closeAll, { signal: sig });
    document.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Escape') closeAll(); }, { signal: sig });

    // ─── Swipe to dismiss sidebars ──────────────────────────
    let sbTouchX = 0;
    function addSwipeDismiss(el: HTMLElement, dir: 'left' | 'right') {
      el.addEventListener('touchstart', (e: TouchEvent) => { sbTouchX = e.touches[0].clientX; }, { passive: true, signal: sig } as AddEventListenerOptions);
      el.addEventListener('touchend', (e: TouchEvent) => {
        const dx = e.changedTouches[0].clientX - sbTouchX;
        if (dir === 'left'  && dx < -50) closeAll();
        if (dir === 'right' && dx >  50) closeAll();
      }, { passive: true, signal: sig } as AddEventListenerOptions);
    }
    addSwipeDismiss(leftSb as HTMLElement,  'left');
    addSwipeDismiss(rightSb as HTMLElement, 'right');

    // ─── Sidebar stats from localStorage ───────────────────
    {
      const { isLoggedIn } = getHpMeta();
      let totalViews = 0, totalTokens = 0;
      try {
        for (let i = 0; i < localStorage.length; i++) {
          const k = localStorage.key(i);
          if (!k?.startsWith('story:')) continue;
          const d = JSON.parse(localStorage.getItem(k) || '{}');
          totalViews  += d.views  || 0;
          totalTokens += d.tokens || 0;
        }
      } catch(_) {}
      const vEl = document.getElementById('sbTotalViews');
      const tEl = document.getElementById('sbTotalTokens');
      if (vEl) vEl.textContent = fmtN(totalViews);
      if (tEl) tEl.textContent = fmtN(totalTokens);
    }

    // ─── Pure text mode toggle ──────────────────────────────
    const plainBtn    = document.getElementById('sbPlainBtn');
    const plainStatus = document.getElementById('sbPlainStatus');
    let plainMode = sGet('hz-plain') === '1';

    function updatePlainBtn() {
      if (!plainStatus) return;
      plainStatus.textContent = plainMode ? '開' : '關';
      plainBtn?.classList.toggle('on', plainMode);
    }
    updatePlainBtn();

    plainBtn?.addEventListener('click', () => {
      plainMode = !plainMode;
      sSet('hz-plain', plainMode ? '1' : '0');
      if (plainMode) document.documentElement.setAttribute('data-plain', '1');
      else document.documentElement.removeAttribute('data-plain');
      updatePlainBtn();
    }, { signal: sig });

    // ─── Sidebar theme buttons ──────────────────────────────
    document.querySelectorAll<HTMLButtonElement>('.sb-theme-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const t = btn.dataset.sb ?? 'dark';
        document.documentElement.setAttribute('data-theme', t);
        sSet('hz-theme', t);
        document.querySelectorAll('.sb-theme-btn').forEach(b => b.classList.toggle('on', b === btn));
      }, { signal: sig });
    });
    {
      const saved = sGet('hz-theme') ?? 'dark';
      document.querySelector(`.sb-theme-btn[data-sb="${saved}"]`)?.classList.add('on');
    }

    // ─── Unlock modal ───────────────────────────────────────
    const unlockModal = document.getElementById('unlockModal');
    const unlockBtn   = document.getElementById('unlockBtn') as HTMLButtonElement | null;
    const storyHref   = unlockBtn?.dataset.href ?? '/stories';

    function openModal()  { unlockModal?.classList.add('open'); document.body.style.overflow = 'hidden'; }
    function closeModal() { unlockModal?.classList.remove('open'); document.body.style.overflow = ''; }

    unlockBtn?.addEventListener('click', openModal, { signal: sig });
    document.getElementById('closeModalBtn')?.addEventListener('click', closeModal, { signal: sig });
    document.getElementById('skipLoginBtn')?.addEventListener('click', () => {
      closeModal();
      if (plainMode && storyHref.match(/^\/stories\/[^/]+$/)) {
        window.location.href = storyHref + '/plain';
      } else {
        window.location.href = storyHref;
      }
    }, { signal: sig });
    unlockModal?.addEventListener('click', (e) => { if (e.target === unlockModal) closeModal(); }, { signal: sig });

    // ─── Close sidebar when clicking in-page anchor links ───
    document.querySelectorAll<HTMLAnchorElement>('.sb-link[href^="#"]').forEach(link => {
      link.addEventListener('click', closeAll, { signal: sig });
    });

    // ─── Category filter ────────────────────────────────────
    // Tag data is stored on cards so filtering works after re-init
    document.querySelectorAll<HTMLElement>('.story-card').forEach(card => {
      if (!card.dataset.tags) {
        card.dataset.tags = Array.from(card.querySelectorAll('.tag')).map(t => t.textContent?.trim() ?? '').join(',');
      }
    });

    function applyFilter(cat: string) {
      sSet('hz-cat', cat);
      document.querySelectorAll<HTMLElement>('.tag-btn').forEach(b => b.classList.toggle('on', b.dataset.cat === cat));
      let visible = 0;
      document.querySelectorAll<HTMLElement>('.story-card').forEach(card => {
        const tags = card.dataset.tags?.split(',') ?? [];
        const show = cat === '全部' || tags.includes(cat);
        card.style.display = show ? 'block' : 'none';
        if (show) visible++;
      });
      const noRes = document.getElementById('noResults');
      if (noRes) noRes.style.display = visible === 0 ? 'block' : 'none';
    }

    document.querySelectorAll<HTMLButtonElement>('.tag-btn').forEach(btn => {
      btn.addEventListener('click', () => applyFilter(btn.dataset.cat ?? '全部'), { signal: sig });
    });

    // Intercept story card clicks — carry active filter as list context
    document.querySelectorAll<HTMLAnchorElement>('.story-card[href]').forEach(card => {
      if (card.dataset.listBound) return;
      card.dataset.listBound = '1';
      card.addEventListener('click', (e) => {
        const href = card.getAttribute('href') ?? '';
        if (!href.startsWith('/stories/')) return;
        e.preventDefault();
        const cat = sGet('hz-cat') ?? '全部';
        const listParam = cat !== '全部' ? 'cat:' + cat : 'all';
        window.location.href = href.split('?')[0] + '?list=' + encodeURIComponent(listParam) + '&ref=home';
      }, { signal: sig });
    });

    // Restore saved category selection
    {
      const savedCat = sGet('hz-cat') ?? '全部';
      if (savedCat !== '全部') applyFilter(savedCat);
    }

    // ─── Mind Map ────────────────────────────────────────────
    initMindMap();

    // ─── Message send ────────────────────────────────────────
    document.getElementById('sendMsgBtn')?.addEventListener('click', async () => {
      const ta = document.getElementById('authorMsg') as HTMLTextAreaElement | null;
      const st = document.getElementById('msgStatus');
      const btn = document.getElementById('sendMsgBtn') as HTMLButtonElement | null;
      if (!ta || !st) return;
      if (!ta.value.trim()) {
        st.style.color = 'var(--danger)';
        st.textContent = '[ 錯誤：無法發送空訊號 ]';
        st.style.display = 'block';
        setTimeout(() => { if (st) st.style.display = 'none'; }, 3000);
        return;
      }
      if (btn) btn.disabled = true;
      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: ta.value.trim() }),
        });
        st.style.color = res.ok ? 'var(--accent)' : 'var(--danger)';
        st.textContent = res.ok ? '[ 訊號已加密傳送。觀測者會收到的。 ]' : '[ 傳送失敗，請稍後再試 ]';
        if (res.ok) ta.value = '';
      } catch {
        st.style.color = 'var(--danger)';
        st.textContent = '[ 網路中斷，無法傳送 ]';
      }
      if (btn) btn.disabled = false;
      st.style.display = 'block';
      setTimeout(() => { if (st) st.style.display = 'none'; }, 4000);
    }, { signal: sig });
  }

  // ─── Mind Map initializer ────────────────────────────────
  function initMindMap() {
    const svg   = document.getElementById('mindmapSvg') as SVGSVGElement | null;
    const eG    = document.getElementById('mmEdges');
    const nG    = document.getElementById('mmNodes');
    const lock  = document.getElementById('mmLock');
    const badge = document.getElementById('mmBadge');
    const tip   = document.getElementById('mmTooltip') as HTMLElement | null;
    if (!svg || !eG || !nG || !lock || !tip) return;

    // Clear previous elements to prevent accumulation on repeated calls
    eG.innerHTML = '';
    nG.innerHTML = '';

    // Category colors
    const CAT_COLOR: Record<string, string> = {
      '記憶科技': '#d90429',
      '地下城市': '#00b4d8',
      '生態復育': '#15803d',
      'AI社會':   '#7c3aed',
      '情感科技': '#ff5400',
      '🔍 彩蛋':  '#ffea00',
    };

    // Nodes: x/y in 0..1 space (mapped to 900x520 viewBox)
    const nodes = [
      { id:'file-001', label:'FILE-001', title:'通勤記憶出租',       cat:'記憶科技', level:'public',     x:.14, y:.28 },
      { id:'file-002', label:'FILE-002', title:'失憶申請書第三十七號', cat:'記憶科技', level:'restricted', x:.08, y:.54 },
      { id:'file-012', label:'FILE-012', title:'繼承記憶遺產',        cat:'記憶科技', level:'public',     x:.22, y:.74 },
      { id:'file-003', label:'FILE-003', title:'B17層的維修員',       cat:'地下城市', level:'public',     x:.78, y:.22 },
      { id:'file-004', label:'FILE-004', title:'錯誤的門號',          cat:'地下城市', level:'restricted', x:.88, y:.44 },
      { id:'file-013', label:'FILE-013', title:'捷運影子',            cat:'地下城市', level:'public',     x:.82, y:.66 },
      { id:'file-005', label:'FILE-005', title:'你的AI心理師知道太多了',cat:'AI社會',  level:'public',     x:.62, y:.12 },
      { id:'file-006', label:'FILE-006', title:'最後一位人類收銀員',   cat:'AI社會',  level:'restricted', x:.76, y:.07 },
      { id:'file-014', label:'FILE-014', title:'同理心2.0',           cat:'AI社會',  level:'public',     x:.88, y:.16 },
      { id:'file-007', label:'FILE-007', title:'仿生根系',            cat:'生態復育', level:'public',     x:.38, y:.86 },
      { id:'file-008', label:'FILE-008', title:'回歸計畫第二階段',     cat:'生態復育', level:'restricted', x:.54, y:.92 },
      { id:'file-015', label:'FILE-015', title:'雨的成分',            cat:'生態復育', level:'public',     x:.24, y:.91 },
      { id:'file-009', label:'FILE-009', title:'失戀補丁',            cat:'情感科技', level:'public',     x:.12, y:.09 },
      { id:'file-010', label:'FILE-010', title:'快樂配給',            cat:'情感科技', level:'restricted', x:.26, y:.13 },
      { id:'file-011', label:'FILE-011', title:'弦音觀測者的自白',     cat:'🔍 彩蛋', level:'top-secret', x:.50, y:.46 },
    ];

    // Edges: [from, to, label]
    const edges = [
      ['file-001','file-002','記憶販售→申請遺忘'],
      ['file-001','file-012','記憶所有權'],
      ['file-002','file-012','失去的記憶'],
      ['file-003','file-004','B層密室'],
      ['file-003','file-013','地下軌道'],
      ['file-004','file-013','消失的空間'],
      ['file-005','file-006','AI取代人類'],
      ['file-005','file-014','AI與情感'],
      ['file-006','file-014','人機界限'],
      ['file-007','file-008','生態干預'],
      ['file-007','file-015','人造自然'],
      ['file-008','file-015','復育的代價'],
      ['file-009','file-010','情感操縱'],
      ['file-001','file-009','快樂的真相'],
      ['file-005','file-010','控制快樂'],
      ['file-003','file-007','地下╳地表'],
      ['file-011','file-001','目擊者自白'],
      ['file-011','file-002','記憶迴圈'],
      ['file-011','file-005','AI全知'],
      ['file-011','file-010','情感配給'],
    ];

    const W = 900, H = 520;
    const px = (x: number) => x * W;
    const py = (y: number) => y * H;

    const ns = 'http://www.w3.org/2000/svg';
    const nsEl = (tag: string) => document.createElementNS(ns, tag);

    // O(1) node lookup map (avoids O(n) find inside loops)
    const nodeMap = new Map(nodes.map(n => [n.id, n]));

    // Draw edges
    edges.forEach(([a, b]) => {
      const na = nodeMap.get(a);
      const nb = nodeMap.get(b);
      if (!na || !nb) return;
      const line = nsEl('line') as SVGLineElement;
      line.setAttribute('x1', String(px(na.x)));
      line.setAttribute('y1', String(py(na.y)));
      line.setAttribute('x2', String(px(nb.x)));
      line.setAttribute('y2', String(py(nb.y)));
      line.setAttribute('stroke', CAT_COLOR[na.cat] || '#260000');
      line.setAttribute('stroke-width', na.cat === '🔍 彩蛋' || nb.cat === '🔍 彩蛋' ? '1.2' : '0.7');
      line.setAttribute('opacity', na.cat === '🔍 彩蛋' || nb.cat === '🔍 彩蛋' ? '0.7' : '0.3');
      line.setAttribute('stroke-dasharray', '3,4');
      eG!.appendChild(line);
    });

    // Auth state detection via Clerk
    let isMember = false;
    function checkAuth() {
      try {
        // @ts-ignore
        const clerk = window.Clerk;
        isMember = !!(clerk?.user);
      } catch(_) {}
    }

    // Draw nodes
    nodes.forEach(node => {
      const g = nsEl('g') as SVGGElement;
      g.setAttribute('class', 'mm-node');
      g.setAttribute('data-id', node.id);
      g.setAttribute('data-level', node.level);
      g.setAttribute('style', 'cursor:pointer');

      const isRestricted = node.level === 'restricted' || node.level === 'top-secret';
      const color = CAT_COLOR[node.cat] || '#d90429';
      const r = node.cat === '🔍 彩蛋' ? 16 : (node.level === 'public' ? 11 : 9);

      // Outer ring
      const ring = nsEl('circle') as SVGCircleElement;
      ring.setAttribute('cx', String(px(node.x)));
      ring.setAttribute('cy', String(py(node.y)));
      ring.setAttribute('r', String(r + 4));
      ring.setAttribute('fill', 'none');
      ring.setAttribute('stroke', color);
      ring.setAttribute('stroke-width', '0.5');
      ring.setAttribute('opacity', '0.25');
      g.appendChild(ring);

      // Main circle
      const circ = nsEl('circle') as SVGCircleElement;
      circ.setAttribute('cx', String(px(node.x)));
      circ.setAttribute('cy', String(py(node.y)));
      circ.setAttribute('r', String(r));
      circ.setAttribute('fill', '#050505');
      circ.setAttribute('stroke', color);
      circ.setAttribute('stroke-width', node.cat === '🔍 彩蛋' ? '2' : '1.2');
      g.appendChild(circ);

      // Label
      const txt = nsEl('text') as SVGTextElement;
      txt.setAttribute('x', String(px(node.x)));
      txt.setAttribute('y', String(py(node.y) + 4));
      txt.setAttribute('text-anchor', 'middle');
      txt.setAttribute('font-family', 'Share Tech Mono, monospace');
      txt.setAttribute('font-size', node.cat === '🔍 彩蛋' ? '8' : '7');
      txt.setAttribute('fill', color);
      txt.setAttribute('letter-spacing', '0.5');
      txt.textContent = isRestricted ? '🔒' : node.label.replace('FILE-', '');
      g.appendChild(txt);

      // Interactions
      g.addEventListener('mouseenter', (e: MouseEvent) => {
        circ.setAttribute('stroke-width', '2');
        ring.setAttribute('opacity', '0.5');
        // show tooltip
        const isLocked = isRestricted && !isMember;
        tip!.textContent = isLocked ? `${node.label} · 限會員查看` : `${node.label} · ${node.title}`;
        tip!.style.display = 'block';
        const rect = (svg as SVGSVGElement).getBoundingClientRect();
        tip!.style.left = (e.clientX - rect.left + 12) + 'px';
        tip!.style.top  = (e.clientY - rect.top  - 30) + 'px';
      });
      g.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = (svg as SVGSVGElement).getBoundingClientRect();
        tip!.style.left = (e.clientX - rect.left + 12) + 'px';
        tip!.style.top  = (e.clientY - rect.top  - 30) + 'px';
      });
      g.addEventListener('mouseleave', () => {
        circ.setAttribute('stroke-width', node.cat === '🔍 彩蛋' ? '2' : '1.2');
        ring.setAttribute('opacity', '0.25');
        tip!.style.display = 'none';
      });
      g.addEventListener('click', () => {
        checkAuth();
        if (isRestricted && !isMember) {
          window.location.href = '/sign-in?redirect_url=/stories/' + node.id;
        } else {
          window.location.href = '/stories/' + node.id;
        }
      });

      nG!.appendChild(g);
    });

    // Pulse animation on file-011 (the meta-story)
    const metaNode = nodes.find(n => n.cat === '🔍 彩蛋');
    if (metaNode) {
      const pulse = nsEl('circle') as SVGCircleElement;
      pulse.setAttribute('cx', String(px(metaNode.x)));
      pulse.setAttribute('cy', String(py(metaNode.y)));
      pulse.setAttribute('r', '20');
      pulse.setAttribute('fill', 'none');
      pulse.setAttribute('stroke', '#ffea00');
      pulse.setAttribute('stroke-width', '1');
      pulse.setAttribute('opacity', '0');
      pulse.setAttribute('class', 'mm-pulse');
      eG!.insertBefore(pulse, eG!.firstChild);
    }

    // Unlock lock if member (check on Clerk load)
    function applyAuthState() {
      checkAuth();
      if (isMember) {
        lock!.style.display = 'none';
        if (badge) { badge.textContent = '已解鎖'; badge.classList.add('unlocked'); }
        // Reveal restricted node labels
        nG!.querySelectorAll<SVGGElement>('[data-level="restricted"],[data-level="top-secret"]').forEach(g => {
          const id = g.dataset.id || '';
          const node = nodeMap.get(id);
          if (!node) return;
          const txt = g.querySelector('text');
          if (txt) txt.textContent = node.label.replace('FILE-', '');
        });
      }
    }

    // Retry until Clerk is available
    let authRetries = 0;
    function waitForClerk() {
      // @ts-ignore
      if (window.Clerk?.loaded) { applyAuthState(); return; }
      if (authRetries++ < 20) setTimeout(waitForClerk, 300);
    }
    waitForClerk();
  }

  // Module scripts run once per session — no deduplication flag needed
  // ─── Load user's reading lists into left sidebar ──────────
  async function loadSbLists() {
    const el = document.getElementById('sbMyLists');
    if (!el) return;
    try {
      const r = await fetch('/api/lists');
      if (!r.ok) { el.innerHTML = ''; return; }
      const lists: { id: string; name: string; slugs: string[] }[] = await r.json();
      if (lists.length === 0) {
        el.innerHTML = '<a href="/stories" class="sb-link sb-link-manage">> 建立第一個清單</a>';
        return;
      }
      el.innerHTML = lists.slice(0, 5).map(l =>
        `<a href="/stories" class="sb-link" data-list-id="${l.id}">
          > ${l.name.replace(/</g,'&lt;')}
          <span class="sb-list-cnt">${l.slugs.length}</span>
        </a>`
      ).join('') +
        (lists.length > 5 ? `<a href="/stories" class="sb-link sb-link-manage">> 還有 ${lists.length - 5} 個清單…</a>` : '');
    } catch (_) { el.innerHTML = ''; }
  }

  // Check Clerk login state then load lists + member stats
  async function maybeSbLists() {
    try {
      await new Promise<void>(res => {
        // @ts-ignore
        if (window.Clerk?.loaded) { res(); return; }
        let n = 0; const t = setInterval(() => {
          // @ts-ignore
          if (window.Clerk?.loaded || ++n > 20) { clearInterval(t); res(); }
        }, 200);
      });
      // @ts-ignore
      if (!(await window.Clerk?.user)) return;
      // Mark logged-in so other client code can read it
      const meta = document.getElementById('hp-meta');
      if (meta) meta.dataset.loggedIn = 'true';
      loadSbLists();
      // Fetch member-specific stats (未解之謎)
      const { totalStories, inaccessibleCount } = getHpMeta();
      fetch('/api/member/stats')
        .then(r => r.ok ? r.json() : Promise.reject())
        .then(data => {
          const mystEl = document.getElementById('statMysteries');
          if (mystEl) {
            const tokened = (data.tokenedSlugs ?? []).length;
            mystEl.textContent = String(Math.max(0, totalStories - tokened - inaccessibleCount));
          }
        })
        .catch(() => {});
    } catch (_) {}
  }
  maybeSbLists();

  document.addEventListener('astro:after-swap', () => {
    updateHeroStats();
    initHomepage();
    maybeSbLists();
    initNewsletter();
  });
  initHomepage();
  initNewsletter();

  function initNewsletter() {
    var form = document.getElementById('nlForm') as HTMLFormElement | null;
    var msg = document.getElementById('nlMsg');
    var btn = document.getElementById('nlBtn') as HTMLButtonElement | null;
    if (!form || (form as HTMLElement & { dataset: DOMStringMap }).dataset.init) return;
    (form as HTMLElement & { dataset: DOMStringMap }).dataset.init = '1';
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var email = (document.getElementById('nlEmail') as HTMLInputElement | null)?.value.trim() ?? '';
      if (!email) return;
      if (btn) btn.disabled = true;
      fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email }),
      })
        .then(function(r) { return r.ok ? r.json() : r.json().then(function(d: { error?: string }) { return Promise.reject(d.error); }); })
        .then(function() {
          if (msg) { msg.textContent = '✓ 已訂閱，新案件解封時將通知你。'; msg.className = 'nl-msg ok'; }
          form!.reset();
        })
        .catch(function(err: unknown) {
          if (msg) { msg.textContent = typeof err === 'string' ? err : '訂閱失敗，請稍後再試。'; msg.className = 'nl-msg err'; }
          if (btn) btn.disabled = false;
        });
    });
  }
</script>

<style>
  /* ─── Header ─────────────────────────────────────── */
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 16px;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    gap: 10px;
  }
  button.logo-icon {
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  button.logo-icon svg { width: 28px; height: 28px; }
  button.logo-icon:hover svg { stroke: var(--accent); }
  a.logo-text-btn {
    font-family: 'Noto Serif TC', serif;
    font-weight: 900;
    font-size: 1.1rem;
    color: var(--text);
    text-decoration: none;
    letter-spacing: 0.1em;
    flex-shrink: 0;
  }
  a.logo-text-btn em { color: var(--accent); font-style: normal; }
  .top-nav {
    display: flex;
    gap: 2px;
    flex: 1;
    justify-content: center;
  }
  .nav-a {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--text-dim);
    text-decoration: none;
    padding: 5px 8px;
    border: 1px solid transparent;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .nav-a:hover { border-color: var(--border); color: var(--text); }
  .burger {
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    flex-shrink: 0;
  }
  .burger span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--text);
    transition: all 0.2s;
  }
  .burger:hover span { background: var(--accent); }

  /* ─── Sidebar Overlay ─────────────────────────────── */
  .sidebar-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.75);
    z-index: 200;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }
  .sidebar-overlay.open { opacity: 1; pointer-events: all; }

  /* ─── Sidebars ─────────────────────────────────────── */
  .sidebar {
    position: fixed;
    top: 0;
    bottom: 0;
    width: 300px;
    max-width: 85vw;
    z-index: 300;
    background: var(--bg);
    overflow-y: auto;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
  }
  .sidebar.left  { left: 0;  transform: translateX(-100%); border-right: 1px solid var(--accent); }
  .sidebar.right { right: 0; transform: translateX(100%);  border-left:  1px solid var(--accent); }
  .sidebar.open  { transform: translateX(0); }
  .sb-drag { display: none; }
  .sb-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 10;
  }
  .sb-logo-text { font-family: 'Noto Serif TC', serif; font-weight: 900; font-size: 1rem; color: var(--text); letter-spacing: 0.1em; }
  .sb-logo-text em { color: var(--accent); font-style: normal; }
  .sb-close { background: none; border: none; cursor: pointer; font-family: 'Share Tech Mono', monospace; font-size: 0.8rem; color: var(--text-muted); padding: 4px 8px; transition: color 0.2s; }
  .sb-close:hover { color: var(--danger); }
  .sb-body { padding: 20px; flex: 1; }
  .sb-section { font-family: 'Share Tech Mono', monospace; font-size: 0.65rem; letter-spacing: 0.2em; color: var(--text-muted); text-transform: uppercase; margin-bottom: 10px; padding-bottom: 8px; border-bottom: 1px solid var(--border); }
  .sb-link { display: block; font-family: 'Share Tech Mono', monospace; font-size: 0.9rem; color: var(--text-dim); text-decoration: none; padding: 10px 0; letter-spacing: 0.05em; transition: color 0.2s; border-bottom: 1px solid rgba(255,255,255,0.04); }
  .sb-link:hover { color: var(--accent); }
  .sb-stat-box { display: flex; justify-content: space-between; align-items: center; padding: 9px 0; border-bottom: 1px solid rgba(255,255,255,0.04); font-family: 'Share Tech Mono', monospace; font-size: 0.82rem; }
  .sb-stat-lbl { color: var(--text-muted); }
  .sb-stat-val { color: var(--accent); font-weight: bold; }
  .sb-theme-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-top: 10px; }
  .sb-theme-btn { background: var(--surface); border: 1px solid var(--border); padding: 8px 4px; cursor: pointer; display: flex; flex-direction: column; align-items: center; gap: 5px; transition: border-color 0.2s; }
  .sb-theme-btn:hover, .sb-theme-btn.on { border-color: var(--accent); }
  .sb-dot { width: 14px; height: 14px; border-radius: 50%; }
  .sb-dot.dark      { background: #0a0a0a; border: 1px solid #444; }
  .sb-dot.clinical  { background: #f0f0f5; border: 1px solid #aaa; }
  .sb-dot.biohazard { background: #d1fae5; border: 1px solid #15803d; }
  .sb-dot.fog       { background: #1e2426; border: 1px solid #5b9ea6; }
  .sb-dot.dossier   { background: #e3dac9; border: 1px solid #9c1414; }
  .sb-dot.abyss     { background: #030b14; border: 1px solid #00b4d8; }
  .sb-dot.cctv      { background: #020a04; border: 1px solid #00ff41; }
  .sb-dot.noir      { background: #000;    border: 1px solid #ffea00; }
  .sb-theme-name { font-family: 'Share Tech Mono', monospace; font-size: 0.6rem; color: var(--text-muted); letter-spacing: 0.05em; }

  /* ─── Right sidebar message ───────────────────────── */
  .msg-box { margin-top: 10px; }
  .msg-textarea { width: 100%; background: var(--bg); border: 1px solid var(--border); color: var(--text); font-family: 'Share Tech Mono', monospace; font-size: 0.75rem; padding: 12px; resize: none; box-sizing: border-box; transition: border-color 0.2s; }
  .msg-textarea:focus { outline: none; border-color: var(--accent); }
  .msg-btn { margin-top: 8px; width: 100%; background: none; border: 1px solid var(--accent); color: var(--accent); font-family: 'Share Tech Mono', monospace; font-size: 0.75rem; padding: 10px; cursor: pointer; letter-spacing: 0.1em; transition: all 0.2s; }
  .msg-btn:hover { background: var(--accent); color: var(--bg); }
  .msg-status { display: none; margin-top: 8px; font-family: 'Share Tech Mono', monospace; font-size: 0.7rem; padding: 6px 0; }
  .rsb-item { display: block; padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.04); text-decoration: none; transition: all 0.2s; }
  .rsb-item:hover .rsb-title { color: var(--accent); }
  .rsb-title { font-family: 'Noto Serif TC', serif; font-size: 0.8rem; color: var(--text); margin-bottom: 3px; letter-spacing: 0.05em; transition: color 0.2s; }
  .rsb-tags { font-family: 'Share Tech Mono', monospace; font-size: 0.6rem; color: var(--text-muted); letter-spacing: 0.05em; }
  .rsb-more {
    display: block;
    margin-top: 16px;
    padding: 10px 0;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.75rem;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 0.15em;
    border-top: 1px solid var(--border);
    text-align: center;
    transition: color 0.2s;
  }
  .rsb-more:hover { color: var(--text); }

  /* ─── Hero ────────────────────────────────────────── */
  .hero { min-height: calc(100svh - 56px); display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative; overflow: hidden; text-align: center; }
  .hero-bg { position: absolute; inset: 0; background: radial-gradient(ellipse 80% 60% at 50% 50%, var(--accent-dim), transparent 70%); opacity: 0.5; }
  .hero-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,.018) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.018) 1px, transparent 1px); background-size: 40px 40px; }
  .hero-content { position: relative; z-index: 10; max-width: 760px; padding: 60px 24px 40px; }
  .hero-tag { font-family: 'Share Tech Mono', monospace; font-size: 0.6rem; letter-spacing: 0.3em; color: var(--text-muted); margin-bottom: 24px; }
  .hero-title { font-family: 'Noto Serif TC', serif; font-size: clamp(2rem, 6vw, 3.8rem); font-weight: 900; line-height: 1.2; color: var(--text); letter-spacing: 0.05em; margin-bottom: 24px; }
  .hero-title .line2 { display: block; color: var(--accent); font-size: 0.65em; margin-top: 8px; }
  .hero-title .line3 { display: block; font-size: 0.32em; color: var(--text-muted); letter-spacing: 0.2em; font-family: 'Share Tech Mono', monospace; font-weight: 400; margin-top: 16px; }
  .hero-desc { font-family: 'Share Tech Mono', monospace; font-size: 0.8rem; color: var(--text-dim); line-height: 1.9; letter-spacing: 0.05em; margin-bottom: 40px; }
  .hero-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; align-items: flex-start; }
  /* ─── Resume strip ─── */
  .resume-strip {
    flex-direction: column;
    gap: 5px;
    background: rgba(0,0,0,0.35);
    border: 1px solid var(--border);
    border-left: 2px solid var(--accent);
    padding: 8px 14px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.62rem;
    min-width: 200px;
    max-width: 280px;
  }
  .rs-top { display: flex; align-items: baseline; gap: 8px; overflow: hidden; }
  .rs-filenum { color: var(--accent); letter-spacing: 0.06em; flex-shrink: 0; }
  .rs-title { color: var(--text-dim); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .rs-prog-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
    height: 3px;
    position: relative;
  }
  .rs-prog-fill {
    position: absolute;
    left: 0; top: 0; bottom: 0;
    background: var(--accent);
    opacity: 0.6;
    width: 0;
    transition: width 0.4s;
  }
  .rs-pct {
    position: relative;
    margin-left: auto;
    color: var(--text-muted);
    font-size: 0.58rem;
    margin-top: 6px;
  }
  .rs-list { color: var(--text-muted); font-size: 0.58rem; letter-spacing: 0.04em; }
  .btn-primary { display: inline-flex; align-items: center; background: var(--accent); color: var(--bg); font-family: 'Share Tech Mono', monospace; font-size: 0.78rem; letter-spacing: 0.12em; padding: 13px 28px; text-decoration: none; transition: all 0.2s; border: 1px solid var(--accent); font-weight: bold; }
  .btn-primary:hover { background: transparent; color: var(--accent); }
  .btn-ghost { display: inline-flex; align-items: center; background: none; color: var(--text-dim); font-family: 'Share Tech Mono', monospace; font-size: 0.78rem; letter-spacing: 0.12em; padding: 13px 28px; cursor: pointer; transition: all 0.2s; border: 1px solid var(--border); }
  .btn-ghost:hover { border-color: var(--text); color: var(--text); }
  .hero-stats { position: relative; z-index: 10; display: flex; gap: 48px; justify-content: center; padding: 32px 24px 56px; flex-wrap: wrap; }
  .stat { text-align: center; }
  .stat-num { display: block; font-family: 'Share Tech Mono', monospace; font-size: 1.8rem; color: var(--accent); font-weight: bold; }
  .stat-label { font-family: 'Share Tech Mono', monospace; font-size: 0.58rem; color: var(--text-muted); letter-spacing: 0.15em; text-transform: uppercase; margin-top: 4px; }

  /* ─── Main content ────────────────────────────────── */
  main { max-width: 1100px; margin: 0 auto; padding: 60px 24px; }
  .section { margin-bottom: 60px; }
  .sec-hd { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 24px; padding-bottom: 10px; border-bottom: 1px solid var(--border); }
  .sec-title { font-family: 'Share Tech Mono', monospace; font-size: 0.85rem; color: var(--text); letter-spacing: 0.2em; text-transform: uppercase; font-weight: bold; }
  .sec-title::before { content: '[ '; color: var(--accent); }
  .sec-title::after  { content: ' ]'; color: var(--accent); }
  .see-all { font-family: 'Share Tech Mono', monospace; font-size: 0.7rem; color: var(--text-muted); text-decoration: none; letter-spacing: 0.1em; transition: color 0.2s; }
  .see-all:hover { color: var(--accent); }
  .tags-row { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 24px; }
  .tag-btn { background: var(--surface); border: 1px solid var(--border); color: var(--text-muted); font-family: 'Share Tech Mono', monospace; font-size: 0.7rem; letter-spacing: 0.1em; padding: 6px 14px; cursor: pointer; transition: all 0.2s; }
  .tag-btn:hover, .tag-btn.on { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }
  .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
  .divider { border: none; border-top: 1px solid var(--border); margin: 20px 0; }

  /* ─── Footer ──────────────────────────────────────── */
  footer { text-align: center; padding: 60px 24px; border-top: 1px solid var(--border); }
  .ft-logo { font-family: 'Noto Serif TC', serif; font-size: 1.4rem; font-weight: 900; color: var(--text); letter-spacing: 0.1em; margin-bottom: 12px; }
  .ft-logo em { color: var(--accent); font-style: normal; }
  .ft-txt { font-family: 'Share Tech Mono', monospace; font-size: 0.68rem; color: var(--text-muted); letter-spacing: 0.1em; line-height: 1.8; }

  /* ─── Bold emphasis ──────────────────────────────── */
  strong { font-weight: 700; text-decoration: underline; text-decoration-color: var(--accent); text-underline-offset: 3px; }

  /* ─── Sidebar bold links ─────────────────────────── */
  .sb-link-bold { font-weight: 700; color: var(--text) !important; }
  .sb-link-bold:hover { color: var(--accent) !important; }
  .sb-link-manage { color: var(--text-muted); font-size: .75rem; }
  .sb-link-paid { color: #d4a017 !important; }
  .sb-list-cnt {
    float: right;
    font-size: .65rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 1px 5px;
    letter-spacing: 0;
  }
  .sb-list-loading {
    font-family: 'Share Tech Mono', monospace;
    font-size: .65rem;
    color: var(--text-muted);
    padding: 4px 0;
    opacity: .5;
    display: block;
  }
  .sb-paid-note {
    font-family: 'Share Tech Mono', monospace;
    font-size: .65rem;
    color: var(--text-muted);
    padding: 6px 0;
    letter-spacing: .04em;
  }

  /* ─── Plain text toggle button ───────────────────── */
  .sb-plain-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.88rem;
    padding: 10px 12px;
    cursor: pointer;
    letter-spacing: 0.08em;
    transition: all 0.2s;
    margin-top: 10px;
  }
  .sb-plain-btn:hover, .sb-plain-btn.on { border-color: var(--accent); color: var(--accent); }
  .sb-plain-btn .sb-plain-lbl { flex: 1; text-align: left; }
  .sb-plain-status {
    font-size: 0.62rem;
    padding: 2px 7px;
    border: 1px solid var(--border);
    letter-spacing: 0.1em;
  }
  .sb-plain-btn.on .sb-plain-status { background: var(--accent); color: var(--bg); border-color: var(--accent); }

  /* ─── Unlock modal ───────────────────────────────── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 500;
    background: rgba(0,0,0,0.85);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s;
  }
  .modal-overlay.open { opacity: 1; pointer-events: all; }
  .modal-box {
    position: relative;
    background: var(--bg);
    border: 1px solid var(--accent);
    max-width: 420px;
    width: 100%;
    padding: 36px 32px;
    text-align: center;
  }
  .modal-tag { font-family: 'Share Tech Mono', monospace; font-size: 0.6rem; letter-spacing: 0.25em; color: var(--bg); background: var(--accent); display: inline-block; padding: 3px 12px; margin-bottom: 20px; }
  .modal-title { font-family: 'Noto Serif TC', serif; font-size: 1.3rem; font-weight: 900; color: var(--text); margin-bottom: 14px; letter-spacing: 0.05em; }
  .modal-desc { font-family: 'Share Tech Mono', monospace; font-size: 0.72rem; color: var(--text-dim); line-height: 1.8; margin-bottom: 28px; letter-spacing: 0.05em; }
  .modal-actions { display: flex; flex-direction: column; gap: 12px; }
  .modal-btn-primary { display: block; background: var(--accent); color: var(--bg); font-family: 'Share Tech Mono', monospace; font-size: 0.8rem; letter-spacing: 0.15em; padding: 14px; text-decoration: none; font-weight: bold; transition: opacity 0.2s; }
  .modal-btn-primary:hover { opacity: 0.85; }
  .modal-btn-ghost { background: none; border: 1px solid var(--border); color: var(--text-dim); font-family: 'Share Tech Mono', monospace; font-size: 0.72rem; letter-spacing: 0.08em; padding: 12px; cursor: pointer; transition: all 0.2s; }
  .modal-btn-ghost:hover { border-color: var(--text); color: var(--text); }
  .modal-close { position: absolute; top: 12px; right: 12px; background: none; border: none; color: var(--text-muted); font-family: 'Share Tech Mono', monospace; font-size: 0.75rem; cursor: pointer; padding: 4px 8px; transition: color 0.2s; }
  .modal-close:hover { color: var(--danger); }

  /* ─── Redacted text ───────────────────────────────── */
  .redacted { background: var(--text); color: transparent; user-select: none; transition: all 0.3s; cursor: pointer; border-radius: 2px; }
  .redacted:hover { background: transparent; color: var(--text); }

  /* ─── Plain text mode: minimal homepage layout ──────────── */
  /* Hero: strip all decoration, show only the site title */
  :global([data-plain="1"]) .hero-bg,
  :global([data-plain="1"]) .hero-grid,
  :global([data-plain="1"]) .hero-stats,
  :global([data-plain="1"]) .hero-tag,
  :global([data-plain="1"]) .hero-desc,
  :global([data-plain="1"]) .hero-actions { display: none; }
  :global([data-plain="1"]) .hero {
    background: none;
    min-height: auto;
    padding: 28px 24px 8px;
  }
  :global([data-plain="1"]) .hero-title .line2,
  :global([data-plain="1"]) .hero-title .line3 { display: none; }
  :global([data-plain="1"]) .hero-title {
    font-size: 1.6rem;
    margin-bottom: 0;
    color: var(--text);
  }
  /* Story cards: minimal in plain mode */
  :global([data-plain="1"]) .cards-grid { gap: 2px; }
  :global([data-plain="1"]) .story-card {
    border-radius: 0;
    border-left: none;
    border-right: none;
    border-top: none;
    background: none;
    padding: 12px 0;
  }
  /* Sidebar in plain mode */
  :global([data-plain="1"]) .sidebar { font-family: Georgia, serif; }
  /* Header plain mode */
  :global([data-plain="1"]) header { border-bottom: 2px solid var(--border); }

  /* ─── Mind Map ───────────────────────────────────── */
  .mm-warning {
    font-size: .78rem;
    color: var(--text-muted);
    font-family: 'Share Tech Mono', monospace;
    letter-spacing: .05em;
    margin-top: 14px;
    margin-bottom: 20px;
  }
  .sec-badge {
    font-family: 'Share Tech Mono', monospace;
    font-size: .58rem;
    letter-spacing: .15em;
    color: var(--bg);
    background: var(--accent);
    padding: 2px 10px;
    display: inline-block;
  }
  .sec-badge.unlocked { background: #15803d; }
  .mindmap-wrap {
    position: relative;
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .mindmap-svg {
    display: block;
    width: 100%;
    height: auto;
    min-height: 260px;
  }
  /* Pulse animation for the secret node */
  :global(.mm-pulse) {
    animation: mmPulse 2.4s ease-in-out infinite;
  }
  @keyframes mmPulse {
    0%   { r: 18; opacity: 0.7; }
    50%  { r: 28; opacity: 0; }
    100% { r: 18; opacity: 0.7; }
  }
  /* Lock overlay */
  .mm-lock {
    position: absolute;
    inset: 0;
    background: rgba(5,5,5,0.78);
    backdrop-filter: blur(3px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 20;
  }
  .mm-lock-inner {
    text-align: center;
    padding: 32px 24px;
    max-width: 320px;
  }
  .mm-lock-icon {
    font-size: 2rem;
    color: var(--accent);
    margin-bottom: 12px;
    font-family: 'Share Tech Mono', monospace;
  }
  .mm-lock-title {
    font-family: 'Noto Serif TC', serif;
    font-size: 1.1rem;
    font-weight: 900;
    color: var(--text);
    letter-spacing: .05em;
    margin-bottom: 10px;
  }
  .mm-lock-desc {
    font-family: 'Share Tech Mono', monospace;
    font-size: .7rem;
    color: var(--text-dim);
    line-height: 1.8;
    letter-spacing: .04em;
    margin-bottom: 20px;
  }
  .mm-lock-btn {
    display: inline-block;
    background: var(--accent);
    color: var(--bg);
    font-family: 'Share Tech Mono', monospace;
    font-size: .75rem;
    letter-spacing: .15em;
    padding: 11px 24px;
    text-decoration: none;
    font-weight: bold;
    transition: opacity .2s;
  }
  .mm-lock-btn:hover { opacity: .85; }
  /* Tooltip */
  .mm-tooltip {
    display: none;
    position: absolute;
    background: var(--bg);
    border: 1px solid var(--accent);
    color: var(--text);
    font-family: 'Share Tech Mono', monospace;
    font-size: .65rem;
    letter-spacing: .06em;
    padding: 5px 10px;
    pointer-events: none;
    z-index: 50;
    white-space: nowrap;
    max-width: 240px;
  }
  /* Legend */
  .mm-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 24px;
    margin-top: 14px;
  }
  .mm-legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: 'Share Tech Mono', monospace;
    font-size: .65rem;
    color: var(--text-muted);
    letter-spacing: .08em;
  }
  .mm-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
