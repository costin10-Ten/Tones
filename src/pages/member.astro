---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import Footer from '../components/Footer.astro';
import { SignedIn, SignedOut } from '@clerk/astro/components';
import { getCollection } from 'astro:content';

export const prerender = false;

const userId = Astro.locals.auth?.()?.userId ?? null;
if (!userId) {
  return Astro.redirect('/sign-in?redirect_url=/member');
}

const allStories = await getCollection('stories', ({ data }) => data.published);
const sorted = allStories.sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<Layout title="會員登入 — 弦音異象" description="你的觀測者身份資料與閱讀紀錄">
  <!-- ─── Header ─── -->
  <PageHeader />

  <main class="member-main">
    <div class="member-wrap">

      <!-- ─── Identity Card ─── -->
      <div class="id-card">
        <div class="id-tag">OBSERVER FILE · CLASSIFIED</div>
        <div class="id-body">
          <div class="id-avatar-wrap">
            <div class="id-avatar" id="avatarPlaceholder">👁</div>
          </div>
          <div class="id-info">
            <div class="id-label">識別代號</div>
            <div class="id-name" id="memberName">載入中…</div>
            <div class="id-label" style="margin-top:12px">觀測者狀態</div>
            <div class="id-status"><span class="status-dot"></span>已授權存取</div>
          </div>
        </div>
      </div>

      <!-- ─── Reading Stats ─── -->
      <div class="sec-hd"><div class="sec-title">閱讀紀錄</div></div>
      <div id="statsError" class="stats-error" style="display:none"></div>
      <div class="stats-grid">
        <div class="stat-box">
          <div class="stat-box-num skeleton" id="statViews">—</div>
          <div class="stat-box-lbl">個人瀏覽</div>
        </div>
        <div class="stat-box">
          <div class="stat-box-num skeleton" id="statTokens">—</div>
          <div class="stat-box-lbl">已給出金幣</div>
        </div>
        <div class="stat-box">
          <div class="stat-box-num skeleton" id="statRead">—</div>
          <div class="stat-box-lbl">已收藏卷宗</div>
        </div>
        <div class="stat-box">
          <div class="stat-box-num">{sorted.length}</div>
          <div class="stat-box-lbl">全部卷宗</div>
        </div>
      </div>

      <!-- ─── Achievement Badges ─── -->
      <div class="sec-hd" style="margin-top:40px"><div class="sec-title">成就徽章</div></div>
      <div class="badges-grid" id="badgesGrid">
        <!-- Rendered by JS -->
      </div>

      <!-- ─── Story List with read status ─── -->
      <div class="sec-hd" style="margin-top:40px">
        <div class="sec-title">卷宗追蹤</div>
        <div class="read-filter-group" id="readFilterGroup">
          <button class="rfg-btn on" data-rfg="all">全部</button>
          <button class="rfg-btn" data-rfg="unread">未讀</button>
          <button class="rfg-btn" data-rfg="read">已讀</button>
          <button class="rfg-btn" data-rfg="bookmarked">收藏</button>
        </div>
      </div>
      <div class="story-track-list" id="storyTrackList">
        {sorted.map(story => (
          <a href={`/stories/${story.slug}?ref=member`} class="track-item" data-slug={story.slug}>
            <div class="track-left">
              <div class="track-read-dot" data-slug={story.slug}></div>
              <div>
                <div class="track-title">
                  <span class="track-bookmark-icon" data-slug={story.slug}></span>
                  {story.data.title}<span class="track-read-stamp" data-slug={story.slug} style="display:none"></span>
                </div>
                <div class="track-meta">{story.data.fileNum} · {story.data.date}</div>
                <div class="track-progress-wrap">
                  <div class="track-progress-bar" data-slug={story.slug} style="width:0%"></div>
                </div>
              </div>
            </div>
            <div class="track-right">
              <span class="track-views" data-slug={story.slug}>👁 0</span>
              <span class="track-tokens" data-slug={story.slug}>⎔ 0</span>
            </div>
          </a>
        ))}
      </div>

      <!-- ─── Sign Out ─── -->
      <div class="signout-section">
        <a href="/" class="btn-ghost">[ 返回大廳 ]</a>
        <div id="signOutBtn" class="btn-ghost danger">[ 登出系統 ]</div>
      </div>

    </div>
  </main>

  <Footer active="member" />
</Layout>

<script>
  function fmtN(n) { return n >= 1000 ? (n / 1000).toFixed(1) + 'K' : String(n); }

  // 收藏清單 — 由 applyStats 更新，供 applyFilter 使用
  var _bookmarkedSet = new Set();

  function clearSkeleton() {
    document.querySelectorAll('.stat-box-num.skeleton').forEach(el => {
      el.classList.remove('skeleton');
    });
  }

  function showStatsError(msg: string) {
    clearSkeleton();
    ['statViews', 'statTokens', 'statRead'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.textContent = '—';
    });
    const errEl = document.getElementById('statsError');
    if (errEl) {
      errEl.style.display = '';
      errEl.innerHTML = msg +
        ' <button class="stats-retry-btn" id="statsRetry">重試</button>';
      document.getElementById('statsRetry')?.addEventListener('click', loadStats);
    }
  }

  function applyStats(data) {
    clearSkeleton();
    const errEl = document.getElementById('statsError');
    if (errEl) errEl.style.display = 'none';

    const svEl = document.getElementById('statViews');
    const stEl = document.getElementById('statTokens');
    const srEl = document.getElementById('statRead');
    if (svEl) svEl.textContent = fmtN(data.totalViews ?? 0);
    if (stEl) stEl.textContent = fmtN(data.userTokenCount ?? 0);
    if (srEl) srEl.textContent = String(data.bookmarkedSlugs?.length ?? 0);

    const tokenedSet = new Set(data.tokenedSlugs ?? []);
    const bookmarkedSet = new Set(data.bookmarkedSlugs ?? []);
    _bookmarkedSet = bookmarkedSet; // 供收藏篩選使用
    const statsMap = data.statsMap ?? {};

    // Sync server-authoritative read slugs to localStorage so the filter uses accurate data
    (data.readSlugs ?? []).forEach((slug: string) => {
      try { localStorage.setItem('hz-read:' + slug, '1'); } catch(_) {}
    });

    document.querySelectorAll('.track-views[data-slug]').forEach(el => {
      el.textContent = '👁 ' + fmtN(statsMap[el.dataset.slug]?.views ?? 0);
    });
    document.querySelectorAll('.track-tokens[data-slug]').forEach(el => {
      el.textContent = '⎔ ' + fmtN(statsMap[el.dataset.slug]?.tokens ?? 0);
    });
    document.querySelectorAll('.track-read-dot[data-slug]').forEach(el => {
      el.classList.toggle('read', tokenedSet.has(el.dataset.slug));
    });
    document.querySelectorAll('.track-bookmark-icon[data-slug]').forEach(el => {
      if (bookmarkedSet.has(el.dataset.slug)) el.textContent = '☑ ';
    });

    // Reading progress from localStorage
    document.querySelectorAll('.track-progress-bar[data-slug]').forEach(el => {
      const pct = parseInt(localStorage.getItem('hz-progress:' + el.dataset.slug) || '0', 10);
      if (pct > 0) (el as HTMLElement).style.width = pct + '%';
    });

    // Achievement badges — prefer server readSlugs count; fall back to localStorage
    const readCount = data.readSlugs != null
      ? data.readSlugs.length
      : Object.keys(localStorage).filter(k => k.startsWith('hz-read:')).length;
    const bookmarkCount = data.bookmarkedSlugs?.length ?? 0;
    const tokenCount = data.userTokenCount ?? 0;
    const totalStories = document.querySelectorAll('.track-item').length;
    renderBadges({ readCount, bookmarkCount, tokenCount, totalStories });

    // Refresh read filter and stamps after API data is loaded
    initReadFilter();
  }

  function loadStats() {
    // Re-apply skeleton on retry
    ['statViews', 'statTokens', 'statRead'].forEach(id => {
      const el = document.getElementById(id);
      if (el) { el.textContent = '—'; el.classList.add('skeleton'); }
    });

    const controller = new AbortController();
    const timer = setTimeout(() => controller.abort(), 8000);

    fetch('/api/member/stats', { signal: controller.signal })
      .then(r => { clearTimeout(timer); return r.ok ? r.json() : Promise.reject(r.status); })
      .then(data => {
        if (data?.error === 'timeout') {
          showStatsError('伺服器回應逾時。');
        } else {
          applyStats(data);
        }
      })
      .catch(err => {
        clearTimeout(timer);
        if (err?.name === 'AbortError') {
          showStatsError('讀取逾時，請稍後再試。');
        } else {
          showStatsError('無法載入資料。');
        }
      });
  }

  // Load stats from Supabase
  loadStats();

  // Render badges and filter immediately from localStorage (no API needed)
  // This ensures UI shows instantly; applyStats will re-render with full data later
  {
    const readCount   = Object.keys(localStorage).filter(k => k.startsWith('hz-read:')).length;
    const totalStories = document.querySelectorAll('.track-item').length;
    renderBadges({ readCount, bookmarkCount: 0, tokenCount: 0, totalStories });
  }
  initReadFilter();

  // Load Clerk user info — wait for Clerk to be fully initialized
  function loadMemberName() {
    function applyName() {
      try {
        // @ts-ignore
        const user = window.Clerk?.user;
        if (user) {
          const name = user.fullName || user.primaryEmailAddress?.emailAddress || '觀測者';
          const nameEl = document.getElementById('memberName');
          if (nameEl) nameEl.textContent = name;
          return true;
        }
      } catch(_) {}
      return false;
    }

    // @ts-ignore
    const c0 = window.Clerk;
    if (c0?.loaded && c0.user !== undefined) { applyName(); return; }

    let retries = 0;
    const t = setInterval(() => {
      // @ts-ignore
      const c = window.Clerk;
      if ((c?.loaded && c.user !== undefined) || ++retries > 30) {
        clearInterval(t);
        if (!applyName()) {
          const nameEl = document.getElementById('memberName');
          if (nameEl && nameEl.textContent === '載入中…') nameEl.textContent = '已驗證觀測者';
        }
      }
    }, 200);
  }

  loadMemberName();
  // Re-run on ViewTransitions navigation
  document.addEventListener('astro:page-load', loadMemberName);

  function renderBadges({ readCount, bookmarkCount, tokenCount, totalStories }: { readCount: number; bookmarkCount: number; tokenCount: number; totalStories: number }) {
    const grid = document.getElementById('badgesGrid');
    if (!grid) return;

    const defs = [
      { id: 'first',  icon: '◈', name: '初次接觸',   desc: '閱讀第一篇故事',       req: 1,            current: readCount,    unlocked: readCount >= 1 },
      { id: 'read5',  icon: '⎗', name: '深度追蹤',   desc: '閱讀 5 篇以上',        req: 5,            current: readCount,    unlocked: readCount >= 5 },
      { id: 'read10', icon: '⎜', name: '現場調查員', desc: '閱讀 10 篇以上',       req: 10,           current: readCount,    unlocked: readCount >= 10 },
      { id: 'read20', icon: '⊕', name: '資深觀測者', desc: '閱讀 20 篇以上',       req: 20,           current: readCount,    unlocked: readCount >= 20 },
      { id: 'half',   icon: '◑', name: '半程突破',   desc: '閱讀超過一半卷宗',    req: Math.ceil(totalStories / 2), current: readCount, unlocked: totalStories > 0 && readCount >= totalStories / 2 },
      { id: 'all',    icon: '●', name: '全部解封',   desc: '閱讀所有卷宗',         req: totalStories, current: readCount,    unlocked: totalStories > 0 && readCount >= totalStories },
      { id: 'bk1',   icon: '☑', name: '第一份書籤', desc: '收藏 1 篇故事',        req: 1,            current: bookmarkCount, unlocked: bookmarkCount >= 1 },
      { id: 'bk5',   icon: '◫', name: '個人檔案庫', desc: '收藏 5 篇以上',        req: 5,            current: bookmarkCount, unlocked: bookmarkCount >= 5 },
      { id: 'tk1',   icon: '⎔', name: '初次贊助',   desc: '給出第一枚金幣',       req: 1,            current: tokenCount,   unlocked: tokenCount >= 1 },
      { id: 'tk5',   icon: '◈', name: '金幣散播者', desc: '給出 5 枚以上金幣',    req: 5,            current: tokenCount,   unlocked: tokenCount >= 5 },
      { id: 'tk10',  icon: '⊛', name: '異象支持者', desc: '給出 10 枚以上金幣',   req: 10,           current: tokenCount,   unlocked: tokenCount >= 10 },
    ];

    grid.innerHTML = defs.map(b => {
      const pct = b.req > 0 ? Math.min(100, Math.round((b.current / b.req) * 100)) : 0;
      const progressBar = b.unlocked
        ? ''
        : `<div class="badge-prog-wrap"><div class="badge-prog-bar" style="width:${pct}%"></div></div>
           <div class="badge-prog-label">${b.current} / ${b.req}</div>`;
      return `<div class="badge-box${b.unlocked ? ' unlocked' : ' locked'}">
        <div class="badge-icon-wrap">
          <span class="badge-icon">${b.icon}</span>
          ${b.unlocked ? '<span class="badge-unlock-ring"></span>' : ''}
        </div>
        <div class="badge-name">${b.name}</div>
        <div class="badge-desc">${b.desc}</div>
        ${b.unlocked
          ? '<div class="badge-status">✓ 已解鎖</div>'
          : progressBar}
      </div>`;
    }).join('');
  }

  // ─── Read filter (全部 / 未讀 / 已讀) ────────────────────
  function initReadFilter() {
    const group = document.getElementById('readFilterGroup');
    const list  = document.getElementById('storyTrackList');
    if (!group || !list) return;

    // Update stamps from localStorage (idempotent — safe to call multiple times)
    document.querySelectorAll<HTMLElement>('.track-read-stamp[data-slug]').forEach(el => {
      const slug = el.dataset.slug ?? '';
      const isRead = localStorage.getItem('hz-read:' + slug) === '1' ||
                     parseInt(localStorage.getItem('hz-progress:' + slug) || '0', 10) >= 80;
      el.style.display = isRead ? '' : 'none';
      if (isRead) el.textContent = ' 已讀';
    });

    // Determine currently active mode (preserved across repeated calls)
    const activeBtn = group.querySelector<HTMLButtonElement>('.rfg-btn.on');
    const mode = activeBtn?.dataset.rfg ?? 'all';

    function applyFilter(m: string) {
      group.querySelectorAll<HTMLButtonElement>('.rfg-btn').forEach(btn => {
        btn.classList.toggle('on', btn.dataset.rfg === m);
      });

      const items = list.querySelectorAll<HTMLElement>('.track-item[data-slug]');
      let readCount = 0, unreadCount = 0, bookmarkedCount = 0;

      items.forEach(item => {
        const slug = item.dataset.slug ?? '';
        const isRead = localStorage.getItem('hz-read:' + slug) === '1' ||
                       parseInt(localStorage.getItem('hz-progress:' + slug) || '0', 10) >= 80;
        const isBookmarked = _bookmarkedSet.has(slug);
        if (isRead) readCount++; else unreadCount++;
        if (isBookmarked) bookmarkedCount++;
        const show = m === 'all'
          || (m === 'read'       && isRead)
          || (m === 'unread'     && !isRead)
          || (m === 'bookmarked' && isBookmarked);
        item.style.display = show ? '' : 'none';
      });

      // Empty state message
      let doneMsg = list.querySelector<HTMLElement>('.track-all-done');
      const showEmpty = (m === 'read' && readCount === 0)
        || (m === 'unread' && unreadCount === 0)
        || (m === 'bookmarked' && bookmarkedCount === 0);
      if (showEmpty) {
        if (!doneMsg) {
          doneMsg = document.createElement('div');
          doneMsg.className = 'track-all-done';
          list.appendChild(doneMsg);
        }
        if (m === 'read') {
          doneMsg.innerHTML = '<span class="done-icon">◯</span><span class="done-msg">尚無已讀卷宗<br><span class="done-sub">閱讀進度達 80% 即自動標記為已讀</span></span>';
        } else if (m === 'bookmarked') {
          doneMsg.innerHTML = '<span class="done-icon">☐</span><span class="done-msg">尚無收藏卷宗<br><span class="done-sub">在閱讀器中點擊「書籤」即可收藏</span></span>';
        } else {
          doneMsg.innerHTML = '<span class="done-icon">●</span><span class="done-msg">所有卷宗已閱覽完畢<br><span class="done-sub">你已調查了這個世界的每一個角落</span></span>';
        }
        doneMsg.style.display = 'flex';
      } else if (doneMsg) {
        doneMsg.style.display = 'none';
      }
    }

    // Set up button listeners only once (guard against repeated calls)
    if (!group.dataset.rfgReady) {
      group.dataset.rfgReady = '1';
      group.querySelectorAll<HTMLButtonElement>('.rfg-btn').forEach(btn => {
        btn.addEventListener('click', () => applyFilter(btn.dataset.rfg ?? 'all'));
      });
    }

    applyFilter(mode);
  }


  // Sign out via Clerk
  document.getElementById('signOutBtn')?.addEventListener('click', async () => {
    try {
      // @ts-ignore
      await window.Clerk?.signOut();
      window.location.href = '/';
    } catch(e) {
      window.location.href = '/sign-in';
    }
  });
</script>

<style>
  /* ─── Member main ────────────────────────────────── */
  .member-main {
    min-height: 100vh;
    background: var(--bg);
    overflow-x: hidden;
  }
  .member-wrap {
    max-width: 720px;
    margin: 0 auto;
    padding: 48px 24px 100px;
  }

  /* ─── Identity Card ─── */
  .id-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid var(--accent);
    margin-bottom: 40px;
    overflow: hidden;
  }
  .id-tag {
    background: var(--accent);
    color: var(--bg);
    font-family: 'Share Tech Mono', monospace;
    font-size: .6rem;
    letter-spacing: .2em;
    padding: 6px 16px;
    font-weight: bold;
  }
  .id-body {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 24px;
  }
  .id-avatar-wrap { flex-shrink: 0; }
  .id-avatar {
    width: 64px;
    height: 64px;
    border: 2px solid var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    background: var(--bg2);
  }
  .id-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: .6rem;
    color: var(--text-muted);
    letter-spacing: .2em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .id-name {
    font-family: 'Noto Serif TC', serif;
    font-size: 1.1rem;
    font-weight: 900;
    color: var(--text);
    letter-spacing: .05em;
  }
  .id-status {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Share Tech Mono', monospace;
    font-size: .7rem;
    color: var(--accent);
    letter-spacing: .1em;
  }
  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* ─── Section header ─── */
  .sec-hd {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 16px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 10px;
  }
  .sec-title {
    font-family: 'Share Tech Mono', monospace;
    font-size: .85rem;
    color: var(--text);
    letter-spacing: .2em;
    text-transform: uppercase;
    font-weight: bold;
  }
  .sec-title::before { content: '[ '; color: var(--accent); }
  .sec-title::after  { content: ' ]'; color: var(--accent); }

  /* ─── Stats Grid ─── */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }
  .stat-box {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 16px 12px;
    text-align: center;
  }
  .stat-box-num {
    font-family: 'Share Tech Mono', monospace;
    font-size: 1.4rem;
    color: var(--accent);
    font-weight: bold;
    margin-bottom: 6px;
  }
  .stat-box-lbl {
    font-family: 'Share Tech Mono', monospace;
    font-size: .6rem;
    color: var(--text-muted);
    letter-spacing: .1em;
    text-transform: uppercase;
  }

  /* ─── Story Track List ─── */
  .story-track-list { display: flex; flex-direction: column; gap: 4px; }
  .track-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid transparent;
    text-decoration: none;
    transition: all .2s;
    gap: 12px;
  }
  .track-item:hover {
    border-left-color: var(--accent);
    background: var(--bg2);
    transform: translateX(3px);
  }
  .track-left { display: flex; align-items: center; gap: 12px; flex: 1; min-width: 0; }
  .track-read-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--border);
    flex-shrink: 0;
    transition: background .2s;
  }
  .track-read-dot.read { background: var(--accent); }
  .track-bookmark-icon {
    color: var(--accent);
    font-family: 'Share Tech Mono', monospace;
    font-size: .75rem;
  }
  .track-progress-wrap {
    height: 2px;
    background: var(--border);
    margin-top: 5px;
    border-radius: 1px;
    overflow: hidden;
  }
  .track-progress-bar {
    height: 100%;
    background: var(--accent);
    transition: width .3s ease;
    border-radius: 1px;
  }
  .track-title {
    font-family: 'Noto Serif TC', serif;
    font-size: .85rem;
    font-weight: 700;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .track-meta {
    font-family: 'Share Tech Mono', monospace;
    font-size: .6rem;
    color: var(--text-muted);
    letter-spacing: .05em;
    margin-top: 2px;
  }
  .track-right {
    display: flex;
    gap: 12px;
    font-family: 'Share Tech Mono', monospace;
    font-size: .65rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  /* ─── Sign out ─── */
  .signout-section {
    display: flex;
    gap: 12px;
    margin-top: 48px;
    justify-content: flex-end;
    flex-wrap: wrap;
  }
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: 'Share Tech Mono', monospace;
    font-size: .8rem;
    letter-spacing: .1em;
    padding: 10px 20px;
    transition: all .2s;
