# ─── Clerk Authentication ─────────────────────────────────
# https://dashboard.clerk.com → Create application → API Keys
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# ─── Keystatic CMS (GitHub mode, production only) ─────────
# 1. Go to github.com/settings/developers → OAuth Apps → New OAuth App
# 2. Homepage URL: https://your-site.vercel.app
# 3. Callback URL: https://your-site.vercel.app/api/keystatic/github-oauth-callback
# 4. Copy Client ID and generate Client Secret below
KEYSTATIC_GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxx
KEYSTATIC_GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Random 32-char secret (run: openssl rand -base64 32)
KEYSTATIC_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Your GitHub username and repo name
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=your-repo-name

# ─── Stripe Payment (reserved for future) ─────────────────
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
